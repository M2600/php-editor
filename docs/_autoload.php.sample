<?php
/**
 * ライブラリ自動ロードスクリプト
 * 
 * このファイルを user-programs/{あなたのID}/_autoload.php としてコピーすることで、
 * すべてのPHPスクリプト実行時に自動的にロードされます。
 * 
 * 使用例:
 * 1. Composer autoloader のロード
 * 2. 共通ライブラリのインクルード
 * 3. 定数やグローバル変数の定義
 */

// 例1: Composer autoloader のロード
// user-programs/{あなたのID}/vendor/autoload.php が存在する場合
if (file_exists(__DIR__ . '/vendor/autoload.php')) {
    require_once __DIR__ . '/vendor/autoload.php';
}

// 例2: 共通ライブラリディレクトリの設定
// user-programs/{あなたのID}/lib/ 配下のファイルを自動ロード
spl_autoload_register(function ($class) {
    $libPath = __DIR__ . '/lib/' . str_replace('\\', '/', $class) . '.php';
    if (file_exists($libPath)) {
        require_once $libPath;
    }
});

// 例3: 共通の設定ファイルをロード
// if (file_exists(__DIR__ . '/config.php')) {
//     require_once __DIR__ . '/config.php';
// }

// 例4: よく使うライブラリを個別にロード
// if (file_exists(__DIR__ . '/lib/Parsedown.php')) {
//     require_once __DIR__ . '/lib/Parsedown.php';
// }
