{"timestamp":"2025-10-19 07:03:05","level":"INFO","level_num":1,"pid":5535,"user_id":"dev","message":"File save started","context":{"path":"/vibe_coding/fileEdit/post_message.php","file_size_bytes":975,"content":"<?php\n// post_message.php\nheader('Content-Type: application/json');\n\nif ($_SERVER['REQUEST_METHOD'] === 'POST') {\n    $data = json_decode(file_get_contents('php://input'), true);\n\n    if (isset($data['username'], $data['message'])) {\n        $path = 'messages.json';\n        $existing = file_exists($path) ? json_decode(file_get_contents($path), true) : [];\n\n        $existing[] = [\n            'username' => htmlspecialchars($data['username']),\n            'message' => htmlspecialchars($data['message']),\n            'timestamp' => date('c')\n        ];\n\n        // File locking for thread safety\n        $fp = fopen($path, 'w');\n        if (flock($fp, LOCK_EX)) {\n            fwrite($fp, json_encode($existing, JSON_PRETTY_PRINT));\n            flock($fp, LOCK_UN);\n        }\n        fclose($fp);\n\n        http_response_code(201);\n        echo json_encode(['status' => 'success']);\n    } else {\n        http_response_code(400);\n    }\n} else {\n    http_response_code(405);\n}\n"},"memory_usage":2097152,"script":"file_manager.php"}
