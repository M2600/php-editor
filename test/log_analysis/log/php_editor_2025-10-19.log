{"timestamp":"2025-10-19 07:51:02","level":"INFO","level_num":1,"pid":5535,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"/vibe_coding/fileEdit/api.php","content":"<?php\n\nheader('Content-Type: application/json');\n\n$dataFilePath = __DIR__ . '/messages.txt';\n\n// ヘルパー関数：エラー応答\nfunction errorResponse($message, $statusCode = 400) {\n    http_response_code($statusCode);\n    echo json_encode(['success' => false, 'message' => $message]);\n    exit();\n}\n\n// ヘルパー関数：成功応答\nfunction successResponse($message, $data = []) {\n    echo json_encode(array_merge(['success' => true, 'message' => $message], $data));\n    exit();\n}\n\n// GETリクエスト（メッセージの読み込み）\nif ($_SERVER['REQUEST_METHOD'] === 'GET') {\n    if (!file_exists($dataFilePath)) {\n        successResponse('まだメッセージはありません', ['data' => []]);\n    }\n\n    $messages = file($dataFilePath, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);\n    $posts = [];\n\n    foreach ($messages as $line) {\n        $decodedLine = json_decode($line, true);\n        if ($decodedLine) {\n            $posts[] = $decodedLine;\n        }\n    }\n    // 最新の投稿が一番上に来るように逆順にする (JS側でprependするので不要だが、PHP単体で表示する場合を考慮)\n    // $posts = array_reverse($posts);\n    \n    echo json_encode($posts);\n    exit();\n}\n\n// POSTリクエスト（メッセージの投稿）\nif ($_SERVER['REQUEST_METHOD'] === 'POST') {\n    $input = json_decode(file_get_contents('php://input'), true);\n\n    $username = trim($input['username'] ?? '');\n    $message = trim($input['message'] ?? '');\n\n    if (empty($username) || empty($message)) {\n        errorResponse('名前とメッセージは必須です。');\n    }\n\n    if (mb_strlen($username) > 50) {\n        errorResponse('名前は50文字以内で入力してください。');\n    }\n\n    if (mb_strlen($message) > 500) {\n        errorResponse('メッセージは500文字以内で入力してください。');\n    }\n\n    $timestamp = date('Y-m-d H:i:s');\n\n    $post = [\n        'username' => htmlspecialchars($username, ENT_QUOTES, 'UTF-8'),\n        'message' => htmlspecialchars($message, ENT_QUOTES, 'UTF-8'),\n        'timestamp' => $timestamp\n    ];\n\n    // ファイルに追記\n    if (file_put_contents($dataFilePath, json_encode($post) . \"\\n\", FILE_APPEND | LOCK_EX) === false) {\n        errorResponse('メッセージの保存に失敗しました。', 500);\n    }\n\n    successResponse('メッセージが正常に投稿されました。');\n}\n\n// サポートされていないメソッド\nerrorResponse('サポートされていないリクエストメソッドです。', 405);\n\n?>"},"status":"approved","result":{"status":"success","path":"vibe_coding/fileEdit/api.php","message":"ファイルを作成しました"},"approvalTime":1.168},"memory_usage":2097152,"script":"tool_history.php"}
