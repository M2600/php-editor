{"timestamp":"2025-10-20 02:19:28","level":"INFO","level_num":1,"pid":8501,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"create_post.php","content":"<?php\n// create_post.php\nheader('Content-Type: application/json');\n// 投稿データはJSONで受け取る\n$input = file_get_contents('php://input');\n$data = json_decode($input, true);\n\n$response = ['success' => false, 'error' => '不明'];\n\nif (json_last_error() !== JSON_ERROR_NONE) {\n    $response['error'] = 'JSON デコード失敗';\n} elseif (!isset($data['name'], $data['message'])) {\n    $response['error'] = '必要なデータが不足しています';\n} else {\n    $name = trim($data['name']);\n    $message = trim($data['message']);\n    if ($name === '' || $message === '') {\n        $response['error'] = '名前・メッセージは空でなくてください';\n    } else {\n        // JSON ファイルに保存\n        $post = [\n            'name'    => $name,\n            'message' => $message,\n            'time'    => time(),\n        ];\n        $file = __DIR__ . '/posts.json';\n        // 既存のレコードを読み込む\n        $posts = [];\n        if (file_exists($file)) {\n            $content = file_get_contents($file);\n            $posts = json_decode($content, true) ?: [];\n        }\n        $posts[] = $post;\n        // 上限は100件に抑えておく\n        if (count($posts) > 100) {\n            $posts = array_slice($posts, -100);\n        }\n        if (file_put_contents($file, json_encode($posts, JSON_PRETTY_PRINT)) !== false) {\n            $response['success'] = true;\n        } else {\n            $response['error'] = 'ファイルに書き込みできませんでした';\n        }\n    }\n}\n\necho json_encode($response);\n?>"},"status":"approved","result":{"status":"success","path":"vibe_coding/fileEdit/create_post.php","message":"ファイルを作成しました"},"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
