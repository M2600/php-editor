{"timestamp":"2025-10-21 10:40:32","level":"INFO","level_num":1,"pid":6885,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api.php","content":"<?php\n\nheader('Content-Type: application/json');\n\n// 投稿データを保存するファイルパス\n$dataFile = 'messages.json';\n\n// 投稿を読み込む関数\nfunction readMessages($dataFile) {\n    if (!file_exists($dataFile)) {\n        return [];\n    }\n    $json = file_get_contents($dataFile);\n    // ファイルが空の場合のハンドリング\n    if (empty($json)) {\n        return [];\n    }\n    $data = json_decode($json, true);\n    return is_array($data) ? $data : [];\n}\n\n// 投稿を書き込む関数\nfunction writeMessage($dataFile, $username, $message) {\n    $messages = readMessages($dataFile);\n\n    // 新しい投稿データ\n    $newMessage = [\n        'username' => htmlspecialchars($username, ENT_QUOTES, 'UTF-8'),\n        'message' => htmlspecialchars($message, ENT_QUOTES, 'UTF-8'),\n        'timestamp' => date('Y-m-d H:i:s'),\n    ];\n\n    // 配列の先頭に追加して、新しい投稿が上に来るようにする\n    array_unshift($messages, $newMessage);\n\n    // 最大投稿数を制限する場合（例: 100件）\n    // if (count($messages) > 100) {\n    //     $messages = array_slice($messages, 0, 100);\n    // }\n\n    if (file_put_contents($dataFile, json_encode($messages, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE))) {\n        return true;\n    } else {\n        return false;\n    }\n}\n\n// APIのエンドポイント処理\nif (isset($_GET['action'])) {\n    $action = $_GET['action'];\n\n    switch ($action) {\n        case 'read':\n            // 投稿履歴を読み込む\n            $messages = readMessages($dataFile);\n            echo json_encode($messages, JSON_UNESCAPED_UNICODE);\n            break;\n\n        case 'write':\n            // 新しい投稿を書き込む\n            $input = json_decode(file_get_contents('php://input'), true);\n            \n            if (isset($input['username']) && isset($input['message'])) {\n                $username = trim($input['username']);\n                $message = trim($input['message']);\n\n                if (empty($username) || empty($message)) {\n                    echo json_encode(['success' => false, 'message' => 'ユーザー名とメッセージは必須です。']);\n                } else {\n                    if (writeMessage($dataFile, $username, $message)) {\n                        echo json_encode(['success' => true, 'message' => '投稿が完了しました。']);\n                    } else {\n                        echo json_encode(['success' => false, 'message' => '投稿の保存に失敗しました。']);\n                    }\n                }\n            } else {\n                echo json_encode(['success' => false, 'message' => '無効なリクエストデータです。']);\n            }\n            break;\n\n        default:\n            echo json_encode(['success' => false, 'message' => '不明なアクションです。']);\n            break;\n    }\n} else {\n    echo json_encode(['success' => false, 'message' => 'アクションが指定されていません。']);\n}\n\n?>"},"status":"approved","result":{"status":"success","path":"vibe_coding/api.php","message":"ファイルを作成しました"},"approvalTime":3.06},"memory_usage":2097152,"script":"tool_history.php"}
