{"timestamp":"2025-10-21 10:14:04","level":"INFO","level_num":1,"pid":6882,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"contact-form.php","content":"<?php\n// contact-form.php\n// 送信データをテキストファイルに保存するPHPスクリプト\n\nif ($_SERVER['REQUEST_METHOD'] === 'POST') {\n    // 必須フィールドのチェック\n    if (empty($_POST['name']) || empty($_POST['email']) || empty($_POST['message'])) {\n        http_response_code(400);\n        echo json_encode(['error' => 'すべてのフィールドを入力してください']);\n        exit;\n    }\n\n    // シーク中文字列のクリーンアップ\n    $name = htmlspecialchars(trim($_POST['name']));\n    $email = filter_var(trim($_POST['email']), FILTER_SANITIZE_EMAIL);\n    $message = htmlspecialchars(trim($_POST['message']));\n\n    // メールアドレスの形式チェック\n    if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {\n        http_response_code(400);\n        echo json_encode(['error' => '有効なメールアドレスを入力してください']);\n        exit;\n    }\n\n    // テキストファイルへの保存\n    $data = \"[\" . date('Y-m-d H:i:s') . \"]\\n\";\n    $data .= \"名前: \" . $name . \"\\n\";\n    $data .= \"メールアドレス: \" . $email . \"\\n\";\n    $data .= \"内容: \" . $message . \"\\n\";\n    $data .= str_repeat('-', 80) . \"\\n\";\n\n    // ファイルへの追記\n    if ($file = fopen('contacts.txt', 'a')) {\n        fwrite($file, $data);\n        fclose($file);\n        \n        // 成功レスポンス\n        echo json_encode(['success' => '送信が完了しました！']);\n    } else {\n        http_response_code(500);\n        echo json_encode(['error' => 'サーバーエラーが発生しました']);\n    }\n} else {\n    http_response_code(405);\n    echo json_encode(['error' => '不正なリクエスト方法']);\n}\n?>"},"status":"approved","result":{"status":"success","path":"vibe_coding/contact-form.php","message":"ファイルを作成しました"},"approvalTime":7.745},"memory_usage":2097152,"script":"tool_history.php"}
