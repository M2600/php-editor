{"timestamp":"2025-10-21 03:04:26","level":"INFO","level_num":1,"pid":6884,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"submit.php","content":"<?php\n// submit.php - Handle AJAX form submission and store data in JSON file\n\n// 受付時のエラーレスポンス用ヘッダー\nheader('Content-Type: application/json; charset=utf-8');\n\n// JSON データを受け取る\n$rawData = file_get_contents('php://input');\n$payload = json_decode($rawData, true);\nif ($payload === null) {\n    http_response_code(400);\n    echo json_encode(['error' => 'Invalid JSON data.']);\n    exit;\n}\n\n// 必須フィールドの検証\n$required = ['name', 'email', 'message'];\nforeach ($required as $field) {\n    if (empty($payload[$field])) {\n        http_response_code(400);\n        echo json_encode(['error' => \"Field '{$field}' is required.\"]);\n        exit;\n    }\n}\n\n// データを保存するファイルパス\n$storageFile = __DIR__ . '/data.json';\n$entries = [];\n\nif (file_exists($storageFile)) {\n    $json = file_get_contents($storageFile);\n    $entries = json_decode($json, true) ?? [];\n}\n\n$entries[] = [\n    'name'    => $payload['name'],\n    'email'   => $payload['email'],\n    'message' => $payload['message'],\n    'date'    => date('c'),\n];\n\nfile_put_contents($storageFile, json_encode($entries, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT));\n\n// 成功レスポンス\nhttp_response_code(200);\necho json_encode(['success' => true]);\n?>"},"status":"approved","result":{"status":"success","path":"vibe_coding/weather/submit.php","message":"ファイルを作成しました"},"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
