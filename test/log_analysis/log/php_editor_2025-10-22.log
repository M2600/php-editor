{"timestamp":"2025-10-22 14:16:09","level":"INFO","level_num":1,"pid":136970,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"admin_api.php","content":"<?php\n// admin_api.php\n\nheader('Content-Type: application/json');\n\n// 投稿データを保存するファイルパス\n$dataFile = 'messages.json';\n\n// 管理者パスワード (!!! ここをより強力なパスワードに変更してください !!!)\ndefine('ADMIN_PASSWORD', 'your_admin_password_here'); \n\n/**\n * 投稿を読み込む関数\n * api.php と同じロジックを使用\n * @param string $dataFile メッセージデータファイルへのパス\n * @return array メッセージの配列\n */\nfunction readMessages($dataFile) {\n    if (!file_exists($dataFile)) {\n        return [];\n    }\n    $json = file_get_contents($dataFile);\n    // ファイルが空の場合のハンドリング\n    if (empty($json)) {\n        return [];\n    }\n    $data = json_decode($json, true);\n    return is_array($data) ? $data : [];\n}\n\n/**\n * 認証チェック関数\n * @param string $providedPassword ユーザーが提供したパスワード\n * @return bool 認証が成功したかどうか\n */\nfunction authenticate($providedPassword) {\n    // 実際のアプリケーションでは、パスワードはハッシュ化して比較するべきです。\n    // 今回はシンプルな文字列比較ですが、PHPEditorの制約内で安全性を考慮しています。\n    return $providedPassword === ADMIN_PASSWORD;\n}\n\n// APIのエンドポイント処理\nif (isset($_GET['action'])) {\n    $action = $_GET['action'];\n\n    // POSTデータからパスワードを取得\n    // admin.html からの全てのPOSTリクエストには password を含める想定\n    $input = json_decode(file_get_contents('php://input'), true);\n    $providedPassword = isset($input['password']) ? $input['password'] : '';\n\n    // 認証が必要なアクション\n    if ($action === 'read_all' || $action === 'delete') {\n        if (!authenticate($providedPassword)) {\n            echo json_encode(['success' => false, 'message' => '認証に失敗しました。正しいパスワードを入力してください。']);\n            exit; // 認証失敗時は処理を停止\n        }\n    }\n\n    switch ($action) {\n        case 'read_all':\n            // 全投稿を読み込む (認証済み)\n            $messages = readMessages($dataFile);\n            echo json_encode($messages, JSON_UNESCAPED_UNICODE);\n            break;\n\n        case 'delete':\n            // 投稿を削除する (認証済み)\n            if (isset($input['timestamp'])) {\n                $timestampToDelete = $input['timestamp'];\n                $messages = readMessages($dataFile);\n\n                // タイムスタンプが一致するメッセージをフィルタリングして削除\n                $updatedMessages = array_filter($messages, function($msg) use ($timestampToDelete) {\n                    return $msg['timestamp'] !== $timestampToDelete;\n                });\n\n                // array_filter はキーを保持するため、インデックスをリセット\n                $updatedMessages = array_values($updatedMessages);\n\n                if (file_put_contents($dataFile, json_encode($updatedMessages, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE))) {\n                    echo json_encode(['success' => true, 'message' => 'メッセージが正常に削除されました。']);\n                } else {\n                    echo json_encode(['success' => false, 'message' => 'メッセージの削除に失敗しました。']);\n                }\n            } else {\n                echo json_encode(['success' => false, 'message' => '削除するメッセージのタイムスタンプが指定されていません。']);\n            }\n            break;\n\n        default:\n            echo json_encode(['success' => false, 'message' => '不明なアクションです。']);\n            break;\n    }\n} else {\n    echo json_encode(['success' => false, 'message' => 'アクションが指定されていません。']);\n}\n"},"status":"rejected","result":null,"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
