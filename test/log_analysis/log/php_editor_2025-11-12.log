{"timestamp":"2025-11-12 13:08:42","level":"INFO","level_num":1,"pid":14583,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api.php","content":"<?php\n// =========================================\n// 掲示板API - PHPコード\n// =========================================\n\n// ヘッダー設定\nheader('Content-Type: application/json; charset=utf-8');\nheader('Access-Control-Allow-Origin: *');\nheader('Access-Control-Allow-Methods: GET, POST, OPTIONS');\nheader('Access-Control-Allow-Headers: Content-Type');\n\n// データファイルのパス\n$DATA_FILE = __DIR__ . '/posts_data.json';\n\n// リクエスト方式別の処理\n$method = $_SERVER['REQUEST_METHOD'];\n$action = isset($_GET['action']) ? $_GET['action'] : (isset($_POST['action']) ? $_POST['action'] : null);\n\n// JSONデータの取得\n$input = json_decode(file_get_contents('php://input'), true);\nif ($input) {\n    $action = $input['action'] ?? $action;\n}\n\n// アクション処理のルーティング\nswitch ($action) {\n    case 'list':\n        handleList();\n        break;\n    case 'get':\n        handleGet();\n        break;\n    case 'create':\n        handleCreate($input);\n        break;\n    case 'update':\n        handleUpdate($input);\n        break;\n    case 'delete':\n        handleDelete($input);\n        break;\n    default:\n        sendError('不正なアクションです');\n}\n\n/**\n * 投稿一覧を取得\n */\nfunction handleList() {\n    global $DATA_FILE;\n\n    if (!file_exists($DATA_FILE)) {\n        sendSuccess(array());\n        return;\n    }\n\n    $data = file_get_contents($DATA_FILE);\n    $posts = json_decode($data, true);\n\n    if (!is_array($posts)) {\n        $posts = array();\n    }\n\n    // 新しい順にソート\n    usort($posts, function($a, $b) {\n        return strtotime($b['createdAt']) - strtotime($a['createdAt']);\n    });\n\n    sendSuccess($posts);\n}\n\n/**\n * 特定の投稿を取得\n */\nfunction handleGet() {\n    global $DATA_FILE;\n\n    $id = isset($_GET['id']) ? $_GET['id'] : null;\n\n    if (!$id) {\n        sendError('IDが指定されていません');\n        return;\n    }\n\n    if (!file_exists($DATA_FILE)) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    $data = file_get_contents($DATA_FILE);\n    $posts = json_decode($data, true);\n\n    if (!is_array($posts)) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    foreach ($posts as $post) {\n        if ($post['id'] === $id) {\n            sendSuccess($post);\n            return;\n        }\n    }\n\n    sendError('投稿が見つかりません');\n}\n\n/**\n * 新規投稿を作成\n */\nfunction handleCreate($input) {\n    global $DATA_FILE;\n\n    // バリデーション\n    if (!isset($input['authorName']) || !isset($input['content'])) {\n        sendError('投稿者名と投稿内容は必須です');\n        return;\n    }\n\n    $authorName = trim($input['authorName']);\n    $content = trim($input['content']);\n\n    if (empty($authorName)) {\n        sendError('投稿者名を入力してください');\n        return;\n    }\n\n    if (empty($content)) {\n        sendError('投稿内容を入力してください');\n        return;\n    }\n\n    // 既存データを読み込む\n    $posts = array();\n    if (file_exists($DATA_FILE)) {\n        $data = file_get_contents($DATA_FILE);\n        $posts = json_decode($data, true);\n        if (!is_array($posts)) {\n            $posts = array();\n        }\n    }\n\n    // 新しい投稿を作成\n    $newPost = array(\n        'id' => uniqid('post_'),\n        'authorName' => $authorName,\n        'content' => $content,\n        'createdAt' => date('Y-m-d H:i:s'),\n    );\n\n    $posts[] = $newPost;\n\n    // ファイルに保存\n    if (file_put_contents($DATA_FILE, json_encode($posts, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)) === false) {\n        sendError('投稿の保存に失敗しました');\n        return;\n    }\n\n    sendSuccess($newPost);\n}\n\n/**\n * 投稿を更新\n */\nfunction handleUpdate($input) {\n    global $DATA_FILE;\n\n    // バリデーション\n    if (!isset($input['id']) || !isset($input['authorName']) || !isset($input['content'])) {\n        sendError('IDと投稿内容は必須です');\n        return;\n    }\n\n    $id = $input['id'];\n    $authorName = trim($input['authorName']);\n    $content = trim($input['content']);\n\n    if (empty($authorName)) {\n        sendError('投稿者名を入力してください');\n        return;\n    }\n\n    if (empty($content)) {\n        sendError('投稿内容を入力してください');\n        return;\n    }\n\n    if (!file_exists($DATA_FILE)) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    $data = file_get_contents($DATA_FILE);\n    $posts = json_decode($data, true);\n\n    if (!is_array($posts)) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    $found = false;\n    foreach ($posts as &$post) {\n        if ($post['id'] === $id) {\n            $post['authorName'] = $authorName;\n            $post['content'] = $content;\n            $found = true;\n            break;\n        }\n    }\n\n    if (!$found) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    // ファイルに保存\n    if (file_put_contents($DATA_FILE, json_encode($posts, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)) === false) {\n        sendError('更新に失敗しました');\n        return;\n    }\n\n    sendSuccess(array('message' => '更新しました'));\n}\n\n/**\n * 投稿を削除\n */\nfunction handleDelete($input) {\n    global $DATA_FILE;\n\n    if (!isset($input['id'])) {\n        sendError('IDが指定されていません');\n        return;\n    }\n\n    $id = $input['id'];\n\n    if (!file_exists($DATA_FILE)) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    $data = file_get_contents($DATA_FILE);\n    $posts = json_decode($data, true);\n\n    if (!is_array($posts)) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    $found = false;\n    $posts = array_filter($posts, function($post) use ($id, &$found) {\n        if ($post['id'] === $id) {\n            $found = true;\n            return false;\n        }\n        return true;\n    });\n\n    if (!$found) {\n        sendError('投稿が見つかりません');\n        return;\n    }\n\n    // インデックスを再設定\n    $posts = array_values($posts);\n\n    // ファイルに保存\n    if (file_put_contents($DATA_FILE, json_encode($posts, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)) === false) {\n        sendError('削除に失敗しました');\n        return;\n    }\n\n    sendSuccess(array('message' => '削除しました'));\n}\n\n/**\n * 成功レスポンスを送信\n */\nfunction sendSuccess($data) {\n    echo json_encode(array(\n        'success' => true,\n        'data' => $data,\n    ), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);\n    exit;\n}\n\n/**\n * エラーレスポンスを送信\n */\nfunction sendError($message) {\n    http_response_code(400);\n    echo json_encode(array(\n        'success' => false,\n        'message' => $message,\n    ), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);\n    exit;\n}\n?>\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/api.php","message":"ファイルを作成しました"},"approvalTime":3.835},"memory_usage":2097152,"script":"tool_history.php"}
