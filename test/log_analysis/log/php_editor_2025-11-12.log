{"timestamp":"2025-11-12 13:08:27","level":"INFO","level_num":1,"pid":14584,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"app.js","content":"// =========================================\n// 掲示板アプリケーション - JavaScriptコード\n// =========================================\n\nconst API_BASE_URL = 'api.php';\n\n// ページ読み込み時に投稿一覧を取得\ndocument.addEventListener('DOMContentLoaded', function() {\n    loadPosts();\n\n    // フォーム送信イベント\n    document.getElementById('postForm').addEventListener('submit', handlePostSubmit);\n});\n\n/**\n * 新規投稿フォーム送信処理\n */\nasync function handlePostSubmit(e) {\n    e.preventDefault();\n\n    const authorName = document.getElementById('authorName').value.trim();\n    const postContent = document.getElementById('postContent').value.trim();\n\n    // バリデーション\n    if (!authorName || !postContent) {\n        alert('投稿者名と投稿内容を入力してください');\n        return;\n    }\n\n    try {\n        const response = await fetch(API_BASE_URL, {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/json',\n            },\n            body: JSON.stringify({\n                action: 'create',\n                authorName: authorName,\n                content: postContent,\n            }),\n        });\n\n        const result = await response.json();\n\n        if (result.success) {\n            // フォームをリセット\n            document.getElementById('postForm').reset();\n            // 投稿一覧を再読み込み\n            loadPosts();\n        } else {\n            alert('投稿に失敗しました: ' + result.message);\n        }\n    } catch (error) {\n        console.error('エラー:', error);\n        alert('通信エラーが発生しました');\n    }\n}\n\n/**\n * 投稿一覧を読み込む\n */\nasync function loadPosts() {\n    try {\n        const response = await fetch(`${API_BASE_URL}?action=list`);\n        const result = await response.json();\n\n        if (result.success) {\n            displayPosts(result.data);\n        } else {\n            alert('投稿の読み込みに失敗しました');\n        }\n    } catch (error) {\n        console.error('エラー:', error);\n        alert('通信エラーが発生しました');\n    }\n}\n\n/**\n * 投稿一覧を画面に表示\n */\nfunction displayPosts(posts) {\n    const postsList = document.getElementById('postsList');\n\n    if (!posts || posts.length === 0) {\n        postsList.innerHTML = '<p class=\"loading\">投稿がまだありません</p>';\n        return;\n    }\n\n    postsList.innerHTML = posts.map((post) => `\n        <div class=\"post-item\" data-post-id=\"${post.id}\">\n            <div class=\"post-header\">\n                <span class=\"post-author\">${escapeHtml(post.authorName)}</span>\n                <span class=\"post-date\">${formatDate(post.createdAt)}</span>\n            </div>\n            <div class=\"post-content\">${escapeHtml(post.content)}</div>\n            <div class=\"post-actions\">\n                <button class=\"btn btn-edit\" onclick=\"openEditForm('${post.id}')\">編集</button>\n                <button class=\"btn btn-danger\" onclick=\"deletePost('${post.id}')\">削除</button>\n            </div>\n            <div id=\"edit-form-${post.id}\"></div>\n        </div>\n    `).join('');\n}\n\n/**\n * 編集フォームを開く\n */\nasync function openEditForm(postId) {\n    try {\n        const response = await fetch(`${API_BASE_URL}?action=get&id=${postId}`);\n        const result = await response.json();\n\n        if (!result.success) {\n            alert('投稿の読み込みに失敗しました');\n            return;\n        }\n\n        const post = result.data;\n        const editFormContainer = document.getElementById(`edit-form-${postId}`);\n\n        editFormContainer.innerHTML = `\n            <div class=\"edit-form\">\n                <h3>投稿を編集</h3>\n                <div class=\"form-group\">\n                    <label for=\"edit-author-${postId}\">投稿者名:</label>\n                    <input type=\"text\" id=\"edit-author-${postId}\" value=\"${escapeHtml(post.authorName)}\">\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"edit-content-${postId}\">投稿内容:</label>\n                    <textarea id=\"edit-content-${postId}\">${escapeHtml(post.content)}</textarea>\n                </div>\n                <div class=\"edit-actions\">\n                    <button class=\"btn btn-save\" onclick=\"saveEdit('${postId}')\">保存</button>\n                    <button class=\"btn btn-cancel\" onclick=\"closeEditForm('${postId}')\">キャンセル</button>\n                </div>\n            </div>\n        `;\n    } catch (error) {\n        console.error('エラー:', error);\n        alert('通信エラーが発生しました');\n    }\n}\n\n/**\n * 編集フォームを閉じる\n */\nfunction closeEditForm(postId) {\n    document.getElementById(`edit-form-${postId}`).innerHTML = '';\n}\n\n/**\n * 投稿を保存（編集）\n */\nasync function saveEdit(postId) {\n    const authorName = document.getElementById(`edit-author-${postId}`).value.trim();\n    const content = document.getElementById(`edit-content-${postId}`).value.trim();\n\n    if (!authorName || !content) {\n        alert('投稿者名と投稿内容を入力してください');\n        return;\n    }\n\n    try {\n        const response = await fetch(API_BASE_URL, {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/json',\n            },\n            body: JSON.stringify({\n                action: 'update',\n                id: postId,\n                authorName: authorName,\n                content: content,\n            }),\n        });\n\n        const result = await response.json();\n\n        if (result.success) {\n            loadPosts();\n        } else {\n            alert('更新に失敗しました: ' + result.message);\n        }\n    } catch (error) {\n        console.error('エラー:', error);\n        alert('通信エラーが発生しました');\n    }\n}\n\n/**\n * 投稿を削除\n */\nasync function deletePost(postId) {\n    if (!confirm('この投稿を削除しますか？')) {\n        return;\n    }\n\n    try {\n        const response = await fetch(API_BASE_URL, {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/json',\n            },\n            body: JSON.stringify({\n                action: 'delete',\n                id: postId,\n            }),\n        });\n\n        const result = await response.json();\n\n        if (result.success) {\n            loadPosts();\n        } else {\n            alert('削除に失敗しました: ' + result.message);\n        }\n    } catch (error) {\n        console.error('エラー:', error);\n        alert('通信エラーが発生しました');\n    }\n}\n\n/**\n * HTMLエスケープ（XSS対策）\n */\nfunction escapeHtml(text) {\n    const map = {\n        '&': '&amp;',\n        '<': '&lt;',\n        '>': '&gt;',\n        '\"': '&quot;',\n        \"'\": '&#039;',\n    };\n    return text.replace(/[&<>\"']/g, (char) => map[char]);\n}\n\n/**\n * 日時をフォーマット\n */\nfunction formatDate(dateString) {\n    const date = new Date(dateString);\n    const year = date.getFullYear();\n    const month = String(date.getMonth() + 1).padStart(2, '0');\n    const day = String(date.getDate()).padStart(2, '0');\n    const hours = String(date.getHours()).padStart(2, '0');\n    const minutes = String(date.getMinutes()).padStart(2, '0');\n\n    return `${year}/${month}/${day} ${hours}:${minutes}`;\n}\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/app.js","message":"ファイルを作成しました"},"approvalTime":1.717},"memory_usage":2097152,"script":"tool_history.php"}
