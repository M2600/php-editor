{"timestamp":"2025-11-13 01:17:38","level":"INFO","level_num":1,"pid":12222,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api.php","content":"<?php\n// api.php\nheader('Content-Type: application/json; charset=utf-8');\n\n// データファイルのパス\n$DATA_DIR = __DIR__ . '/data';\n$DATA_FILE = $DATA_DIR . '/comments.json';\n\n// データファイルがなければ初期化\nif (!is_dir($DATA_DIR)) {\n    mkdir($DATA_DIR, 0777, true);\n}\nif (!file_exists($DATA_FILE)) {\n    file_put_contents($DATA_FILE, json_encode([]));\n}\n\n// ヘルパー関数\nfunction respond($code, $payload) {\n    http_response_code($code);\n    echo json_encode($payload);\n    exit;\n}\n\n// 入力を取得\n$method = $_SERVER['REQUEST_METHOD'] ?? 'GET';\n$body = trim(file_get_contents('php://input'));\n$data = json_decode($body, true);\n\n// 読み込み用関数\nfunction readAll($path) {\n    $f = fopen($path, 'c+');\n    if (!$f) return [];\n    flock($f, LOCK_SH);\n    $contents = stream_get_contents($f);\n    flock($f, LOCK_UN);\n    fclose($f);\n    $arr = json_decode($contents, true);\n    if (!is_array($arr)) return [];\n    return $arr;\n}\n\n// 書き込み用関数\nfunction writeAll($path, $arr) {\n    $f = fopen($path, 'c+');\n    if (!$f) return false;\n    flock($f, LOCK_EX);\n    ftruncate($f, 0);\n    fwrite($f, json_encode($arr, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE));\n    fflush($f);\n    flock($f, LOCK_UN);\n    fclose($f);\n    return true;\n}\n\n// API ルーティング\nswitch ($method) {\n    case 'GET':\n        // 投稿一覧を返す\n        $posts = readAll(__DIR__ . '/data/comments.json');\n        // created_at がないと困るので、補完\n        foreach ($posts as &$p) {\n            if (!isset($p['created_at'])) {\n                $p['created_at'] = isset($p['timestamp']) ? $p['timestamp'] : date('Y-m-d H:i:s');\n            }\n        }\n        unset($p);\n        echo json_encode($posts);\n        exit;\n\n    case 'POST':\n        // 新規投稿\n        if (!is_array($data) || empty($data['name']) && empty($data['message'])) {\n            respond(400, ['error' => 'Invalid input']);\n        }\n        $name = isset($data['name']) ? trim($data['name']) : '名無し';\n        $message = isset($data['message']) ? trim($data['message']) : '';\n\n        if ($message === '') {\n            respond(400, ['error' => 'Message is required']);\n        }\n\n        $posts = readAll($DATA_FILE);\n        $new = [\n            'id' => uniqid('p_', true),\n            'name' => $name,\n            'message' => $message,\n            'created_at' => date('Y-m-d H:i:s')\n        ];\n\n        // 配列の先頭に追加（新規投稿を最新に表示したい場合は先頭へ）\n        $posts[] = $new;\n\n        if (writeAll($DATA_FILE, $posts)) {\n            respond(201, ['ok' => true, 'post' => $new]);\n        } else {\n            respond(500, ['error' => 'Failed to save post']);\n        }\n        break;\n\n    case 'DELETE':\n        // オプション: id 指定で削除\n        if (!isset($_GET['id'])) {\n            respond(400, ['error' => 'id is required']);\n        }\n        $id = $_GET['id'];\n        $posts = readAll($DATA_FILE);\n        $filtered = array_filter($posts, function($p) use ($id) {\n            return isset($p['id']) && $p['id'] !== $id;\n        });\n        if (writeAll($DATA_FILE, array_values($filtered))) {\n            respond(200, ['ok' => true]);\n        } else {\n            respond(500, ['error' => 'Failed to delete']);\n        }\n        break;\n\n    case 'PUT':\n        // 更新機能の簡易対応（未実装のまま拡張可能）\n        respond(405, ['error' => 'PUT not implemented']);\n        break;\n\n    default:\n        header('HTTP/1.1 405 Method Not Allowed');\n        echo json_encode(['error' => 'Method Not Allowed']);\n        break;\n}\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/api.php","message":"ファイルを作成しました"},"approvalTime":1.661},"memory_usage":2097152,"script":"tool_history.php"}
