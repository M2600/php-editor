{"timestamp":"2025-11-13 01:17:37","level":"INFO","level_num":1,"pid":12221,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"index.html","content":"<!-- index.html -->\n<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\" />\n    <title>簡易掲示板 - API版</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n</head>\n<body>\n    <header>\n        <h1>簡易掲示板</h1>\n        <p>PHP API を叩いて投稿・取得を行います</p>\n    </header>\n\n    <main class=\"container\">\n        <section class=\"post-form\">\n            <h2>新規投稿</h2>\n            <form id=\"newPostForm\" autocomplete=\"off\">\n                <div class=\"field\">\n                    <label for=\"name\">名前</label>\n                    <input type=\"text\" id=\"name\" name=\"name\" placeholder=\"名無し\" required />\n                </div>\n                <div class=\"field\">\n                    <label for=\"message\">メッセージ</label>\n                    <textarea id=\"message\" name=\"message\" rows=\"4\" placeholder=\"ここに投稿内容を入力\" required></textarea>\n                </div>\n                <button type=\"submit\">投稿</button>\n            </form>\n            <p id=\"formStatus\" class=\"status\"></p>\n        </section>\n\n        <section class=\"board\">\n            <h2>投稿一覧</h2>\n            <div id=\"posts\" class=\"posts\"></div>\n        </section>\n    </main>\n\n    <footer>\n        <p>© 2025 簡易掲示板</p>\n    </footer>\n\n    <script>\n        // API のエンドポイント\n        const API_URL = 'api.php';\n\n        // 初期ロード時に投稿一覧を取得\n        document.window = document.window || window;\n        document.addEventListener('DOMContentLoaded', () => {\n            loadPosts();\n        });\n\n        // 投稿ボタン挙動\n        const form = document.getElementById('newPostForm');\n        const nameInput = document.getElementById('name');\n        const messageInput = document.getElementById('message');\n        const statusP = document.getElementById('formStatus');\n        form.addEventListener('submit', async (e) => {\n            e.preventDefault();\n            const name = nameInput.value.trim() || '名無し';\n            const message = messageInput.value.trim();\n            if (!message) {\n                statusP.textContent = 'メッセージを入力してください。';\n                statusP.style.color = 'red';\n                return;\n            }\n\n            const payload = { name, message };\n\n            try {\n                const res = await fetch(API_URL, {\n                    method: 'POST',\n                    headers: { 'Content-Type': 'application/json' },\n                    body: JSON.stringify(payload)\n                });\n                const data = await res.json();\n                if (res.ok) {\n                    statusP.style.color = 'green';\n                    statusP.textContent = '投稿しました';\n                    nameInput.value = '';\n                    messageInput.value = '';\n                    loadPosts();\n                } else {\n                    statusP.style.color = 'red';\n                    statusP.textContent = data.error || '投稿に失敗しました';\n                }\n            } catch (err) {\n                statusP.style.color = 'red';\n                statusP.textContent = 'エラーが発生しました';\n                console.error(err);\n            }\n        });\n\n        // 投稿の読み込み\n        async function loadPosts() {\n            try {\n                const res = await fetch(API_URL, { method: 'GET' });\n                if (!res.ok) throw new Error('Failed to fetch');\n                const posts = await res.json();\n                renderPosts(posts);\n            } catch (err) {\n                console.error(err);\n                const postsBox = document.getElementById('posts');\n                postsBox.innerHTML = '<p class=\"muted\">投稿を取得できませんでした。</p>';\n            }\n        }\n\n        // 投稿の描画\n        function renderPosts(posts) {\n            const container = document.getElementById('posts');\n            container.innerHTML = '';\n            if (!Array.isArray(posts) || posts.length === 0) {\n                container.innerHTML = '<p class=\"muted\">投稿はまだありません。</p>';\n                return;\n            }\n            // 投稿を新しい順に表示\n            posts.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));\n            posts.forEach(p => {\n                const card = document.createElement('div');\n                card.className = 'post';\n                card.innerHTML = `\n                    <div class=\"post-header\">\n                        <span class=\"post-name\">${escapeHTML(p.name)}</span>\n                        <span class=\"post-date\">${escapeHTML(p.created_at)}</span>\n                    </div>\n                    <div class=\"post-message\">${autoLink(escapeHTML(p.message))}</div>\n                `;\n                container.appendChild(card);\n            });\n        }\n\n        // 簡易エスケープ\n        function escapeHTML(str) {\n            return str\n                .replace(/&/g, \"&amp;\")\n                .replace(/</g, \"&lt;\")\n                .replace(/>/g, \"&gt;\");\n        }\n\n        // メッセージ中の URL をリンク化\n        function autoLink(str) {\n            const urlPattern = /(https?:\\/\\/[^\\s]+)/g;\n            return str.replace(urlPattern, '<a href=\"$1\" target=\"_blank\" rel=\"noopener\">$1</a>');\n        }\n    </script>\n</body>\n</html>"},"status":"approved","result":{"status":"success","path":"vibe_coding/index.html","message":"ファイルを作成しました"},"approvalTime":2.818},"memory_usage":2097152,"script":"tool_history.php"}
