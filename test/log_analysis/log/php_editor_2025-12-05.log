{"timestamp":"2025-12-05 12:15:21","level":"INFO","level_num":1,"pid":302166,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"editFileByReplace","parameters":{"filename":"index.html","searchText":"","replaceText":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>3D 骨格スキャンシステム</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Arial', sans-serif;\n            background: #1a1a1a;\n            color: #fff;\n            overflow: hidden;\n            height: 100vh;\n        }\n\n        .container {\n            display: flex;\n            height: 100vh;\n            gap: 10px;\n            padding: 10px;\n        }\n\n        .camera-section {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            gap: 10px;\n        }\n\n        .camera-container {\n            flex: 1;\n            position: relative;\n            background: #000;\n            border-radius: 8px;\n            overflow: hidden;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);\n        }\n\n        video {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n\n        canvas {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n        }\n\n        .camera-label {\n            position: absolute;\n            top: 10px;\n            left: 10px;\n            background: rgba(0, 0, 0, 0.7);\n            padding: 8px 12px;\n            border-radius: 4px;\n            font-weight: bold;\n            z-index: 10;\n        }\n\n        .viewport-3d {\n            flex: 2;\n            position: relative;\n            background: #000;\n            border-radius: 8px;\n            overflow: hidden;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);\n        }\n\n        #canvas3d {\n            width: 100%;\n            height: 100%;\n        }\n\n        .controls {\n            display: flex;\n            gap: 10px;\n            flex-wrap: wrap;\n        }\n\n        button {\n            padding: 10px 20px;\n            background: #007bff;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n            font-weight: bold;\n            transition: background 0.3s;\n        }\n\n        button:hover {\n            background: #0056b3;\n        }\n\n        button:disabled {\n            background: #6c757d;\n            cursor: not-allowed;\n        }\n\n        button.success {\n            background: #28a745;\n        }\n\n        button.success:hover {\n            background: #218838;\n        }\n\n        .status {\n            padding: 12px;\n            background: #2a2a2a;\n            border-radius: 4px;\n            font-size: 14px;\n            line-height: 1.6;\n        }\n\n        .status-item {\n            display: flex;\n            justify-content: space-between;\n            margin: 4px 0;\n        }\n\n        .status-label {\n            font-weight: bold;\n            color: #aaa;\n        }\n\n        .status-value {\n            color: #0f0;\n        }\n\n        .status-value.error {\n            color: #f00;\n        }\n\n        .status-value.warning {\n            color: #ff9800;\n        }\n\n        .info-panel {\n            position: absolute;\n            bottom: 10px;\n            right: 10px;\n            background: rgba(0, 0, 0, 0.8);\n            padding: 10px 15px;\n            border-radius: 4px;\n            font-size: 12px;\n            z-index: 10;\n            max-width: 300px;\n        }\n\n        .info-panel h4 {\n            margin-bottom: 5px;\n            color: #0f0;\n        }\n\n        .landmark-label {\n            font-size: 10px;\n            position: absolute;\n            background: rgba(255, 0, 0, 0.7);\n            padding: 2px 4px;\n            border-radius: 2px;\n            pointer-events: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <!-- カメラセクション -->\n        <div class=\"camera-section\">\n            <!-- カメラ1 -->\n            <div class=\"camera-container\">\n                <video id=\"video1\" playsinline></video>\n                <canvas id=\"canvas1\"></canvas>\n                <div class=\"camera-label\">カメラ 1 (左)</div>\n            </div>\n\n            <!-- カメラ2 -->\n            <div class=\"camera-container\">\n                <video id=\"video2\" playsinline></video>\n                <canvas id=\"canvas2\"></canvas>\n                <div class=\"camera-label\">カメラ 2 (右)</div>\n            </div>\n\n            <!-- コントロール -->\n            <div class=\"controls\">\n                <button id=\"btnStartCameras\">カメラ起動</button>\n                <button id=\"btnCalibrate\" disabled>Tポーズでキャリブレーション</button>\n                <button id=\"btnStartTracking\" disabled>3D追跡開始</button>\n                <button id=\"btnReset\">リセット</button>\n            </div>\n\n            <!-- ステータス -->\n            <div class=\"status\">\n                <div class=\"status-item\">\n                    <span class=\"status-label\">状態:</span>\n                    <span class=\"status-value\" id=\"statusState\">準備中</span>\n                </div>\n                <div class=\"status-item\">\n                    <span class=\"status-label\">カメラ1:</span>\n                    <span class=\"status-value\" id=\"statusCam1\">未起動</span>\n                </div>\n                <div class=\"status-item\">\n                    <span class=\"status-label\">カメラ2:</span>\n                    <span class=\"status-value\" id=\"statusCam2\">未起動</span>\n                </div>\n                <div class=\"status-item\">\n                    <span class=\"status-label\">キャリブレーション:</span>\n                    <span class=\"status-value\" id=\"statusCalib\">未実施</span>\n                </div>\n                <div class=\"status-item\">\n                    <span class=\"status-label\">検出キーポイント:</span>\n                    <span class=\"status-value\" id=\"statusKeypoints\">0</span>\n                </div>\n            </div>\n        </div>\n\n        <!-- 3Dビューポート -->\n        <div class=\"viewport-3d\">\n            <canvas id=\"canvas3d\"></canvas>\n            <div class=\"info-panel\">\n                <h4>操作方法</h4>\n                <div>マウスドラッグ: 回転</div>\n                <div>スクロール: ズーム</div>\n                <div>右ドラッグ: パン</div>\n            </div>\n        </div>\n    </div>\n\n    <!-- ライブラリのロード -->\n    <script async src=\"https://cdn.jsdelivr.net/npm/@mediapipe/pose@0.5.1635794155/pose.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@r128/build/three.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@r128/examples/js/controls/OrbitControls.js\"></script>\n\n    <!-- メインスクリプト -->\n    <script src=\"app.js\"></script>\n</body>\n</html>","options":[]},"status":"approved","result":{"status":"success"},"approvalTime":2.9},"memory_usage":2097152,"script":"tool_history.php"}
