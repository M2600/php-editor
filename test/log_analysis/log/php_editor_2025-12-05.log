{"timestamp":"2025-12-05 12:24:58","level":"INFO","level_num":1,"pid":302166,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"OrbitControls.js","content":"/**\n * OrbitControls.js\n * \n * マウスでカメラを制御するコンポーネント\n * Three.jsのPerspectiveCameraと組み合わせて使用\n */\n\nTHREE.OrbitControls = class OrbitControls {\n    constructor(camera, domElement) {\n        this.camera = camera;\n        this.domElement = domElement;\n        \n        // カメラパラメータ\n        this.target = new THREE.Vector3(0, 0, 0);\n        this.enableDamping = false;\n        this.dampingFactor = 0.05;\n        this.autoRotate = false;\n        this.autoRotateSpeed = 2;\n        \n        // マウス制御\n        this.enableRotate = true;\n        this.rotateSpeed = 1;\n        this.enableZoom = true;\n        this.zoomSpeed = 1;\n        this.enablePan = true;\n        this.panSpeed = 0.5;\n        \n        // 内部状態\n        this.spherical = { radius: 100, phi: Math.PI / 4, theta: 0 };\n        this._previousMousePosition = { x: 0, y: 0 };\n        this._isMouseDown = false;\n        this._isPanning = false;\n        \n        // イベントリスナー\n        this.domElement.addEventListener('mousedown', this._onMouseDown.bind(this), false);\n        this.domElement.addEventListener('mousemove', this._onMouseMove.bind(this), false);\n        this.domElement.addEventListener('mouseup', this._onMouseUp.bind(this), false);\n        this.domElement.addEventListener('wheel', this._onMouseWheel.bind(this), false);\n        this.domElement.addEventListener('contextmenu', (e) => e.preventDefault(), false);\n        \n        this.update();\n    }\n    \n    _onMouseDown(event) {\n        if (!this.enableRotate && !this.enablePan && !this.enableZoom) return;\n        \n        this._isMouseDown = true;\n        this._previousMousePosition = { x: event.clientX, y: event.clientY };\n        this._isPanning = event.button === 2; // 右クリック\n    }\n    \n    _onMouseMove(event) {\n        if (!this._isMouseDown) return;\n        \n        const deltaX = event.clientX - this._previousMousePosition.x;\n        const deltaY = event.clientY - this._previousMousePosition.y;\n        \n        if (this._isPanning && this.enablePan) {\n            // パン処理\n            const distance = this.camera.position.distanceTo(this.target);\n            const panSpeed = this.panSpeed * (distance / 1000);\n            \n            const right = new THREE.Vector3();\n            right.crossVectors(this.camera.up, this.camera.position.clone().sub(this.target).normalize());\n            right.normalize();\n            \n            const up = this.camera.up.clone().normalize();\n            \n            this.target.sub(right.multiplyScalar(deltaX * panSpeed));\n            this.target.add(up.multiplyScalar(deltaY * panSpeed));\n        } else if (this.enableRotate) {\n            // 回転処理\n            this.spherical.theta -= deltaX * 0.005 * this.rotateSpeed;\n            this.spherical.phi -= deltaY * 0.005 * this.rotateSpeed;\n            \n            // phi の制約\n            this.spherical.phi = Math.max(0.1, Math.min(Math.PI - 0.1, this.spherical.phi));\n        }\n        \n        this._previousMousePosition = { x: event.clientX, y: event.clientY };\n    }\n    \n    _onMouseUp(event) {\n        this._isMouseDown = false;\n        this._isPanning = false;\n    }\n    \n    _onMouseWheel(event) {\n        if (!this.enableZoom) return;\n        \n        event.preventDefault();\n        \n        const deltaZoom = event.deltaY > 0 ? 1.1 : 0.9;\n        this.spherical.radius *= deltaZoom;\n        this.spherical.radius = Math.max(10, Math.min(5000, this.spherical.radius));\n    }\n    \n    update() {\n        // カメラ位置を球面座標から計算\n        const x = this.target.x + this.spherical.radius * Math.sin(this.spherical.phi) * Math.sin(this.spherical.theta);\n        const y = this.target.y + this.spherical.radius * Math.cos(this.spherical.phi);\n        const z = this.target.z + this.spherical.radius * Math.sin(this.spherical.phi) * Math.cos(this.spherical.theta);\n        \n        if (this.enableDamping) {\n            this.camera.position.x += (x - this.camera.position.x) * this.dampingFactor;\n            this.camera.position.y += (y - this.camera.position.y) * this.dampingFactor;\n            this.camera.position.z += (z - this.camera.position.z) * this.dampingFactor;\n        } else {\n            this.camera.position.x = x;\n            this.camera.position.y = y;\n            this.camera.position.z = z;\n        }\n        \n        // カメラが target を向くように設定\n        this.camera.lookAt(this.target.x, this.target.y, this.target.z);\n        \n        if (this.autoRotate) {\n            this.spherical.theta += this.autoRotateSpeed * 0.01;\n        }\n    }\n    \n    dispose() {\n        this.domElement.removeEventListener('mousedown', this._onMouseDown, false);\n        this.domElement.removeEventListener('mousemove', this._onMouseMove, false);\n        this.domElement.removeEventListener('mouseup', this._onMouseUp, false);\n        this.domElement.removeEventListener('wheel', this._onMouseWheel, false);\n    }\n};\n"},"status":"rejected","result":null,"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
{"timestamp":"2025-12-05 12:24:59","level":"INFO","level_num":1,"pid":302167,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"pose.js","content":"/**\n * MediaPipe Pose - Local Polyfill\n * \n * CDNからのロード問題を回避するためのローカル実装\n * 完全な機能が必要な場合は以下から置き換えてください：\n * https://cdn.jsdelivr.net/npm/@mediapipe/pose@0.5.1635794155/pose.js\n */\n\nwindow.MediaPipe = window.MediaPipe || {};\n\n/**\n * Poseクラス - 骨格検出\n */\nMediaPipe.Pose = class Pose {\n    constructor(options = {}) {\n        this.options = options;\n        this.onResults = null;\n        this._initialized = false;\n    }\n\n    async initialize() {\n        this._initialized = true;\n        console.log('MediaPipe Pose initialized');\n        return this;\n    }\n\n    async send(input) {\n        if (!this._initialized) {\n            await this.initialize();\n        }\n        \n        // ダミー結果を返す\n        return {\n            poseLandmarks: [],\n            worldLandmarks: [],\n            segmentationMask: null\n        };\n    }\n\n    close() {\n        this._initialized = false;\n    }\n};\n\n/**\n * SelfieSegmentationクラス\n */\nMediaPipe.SelfieSegmentation = class SelfieSegmentation {\n    constructor(options = {}) {\n        this.options = options;\n        this.onResults = null;\n        this._initialized = false;\n    }\n\n    async initialize() {\n        this._initialized = true;\n        return this;\n    }\n\n    async send(input) {\n        if (!this._initialized) {\n            await this.initialize();\n        }\n        return { segmentationMask: null };\n    }\n\n    close() {\n        this._initialized = false;\n    }\n};\n\n// モジュールエクスポート\nif (typeof module !== 'undefined' && module.exports) {\n    module.exports = MediaPipe;\n}\n"},"status":"rejected","result":null,"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
