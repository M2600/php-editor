{"timestamp":"2025-12-05 12:15:57","level":"INFO","level_num":1,"pid":302167,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"app.js","content":"// =====================================\n// 3D骨格スキャンシステム\n// MediaPipe Pose + Three.js + 三角測量\n// =====================================\n\n// グローバル変数\nconst app = {\n    // ビデオ・キャンバス要素\n    video1: null,\n    video2: null,\n    canvas1: null,\n    canvas2: null,\n    ctx1: null,\n    ctx2: null,\n\n    // MediaPipe\n    pose: null,\n    poseResults: {\n        cam1: null,\n        cam2: null\n    },\n\n    // キャメラパラメータ\n    cameraParams: {\n        cam1: null,\n        cam2: null\n    },\n\n    // Three.js\n    scene: null,\n    camera: null,\n    renderer: null,\n    controls: null,\n    skeletonGroup: null,\n\n    // 状態\n    state: 'idle', // idle, cameras_ready, calibrated, tracking\n    calibrationData: null,\n\n    // 骨格線の接続\n    connections: [\n        [11, 13], [13, 15], // 左腕\n        [12, 14], [14, 16], // 右腕\n        [11, 23], [12, 24], // 肩から腰\n        [23, 25], [25, 27], // 左脚\n        [24, 26], [26, 28], // 右脚\n        [11, 12], // 肩\n        [23, 24], // 腰\n    ]\n};\n\n// =====================================\n// 初期化\n// =====================================\nasync function init() {\n    // DOM要素を取得\n    app.video1 = document.getElementById('video1');\n    app.video2 = document.getElementById('video2');\n    app.canvas1 = document.getElementById('canvas1');\n    app.canvas2 = document.getElementById('canvas2');\n    app.ctx1 = app.canvas1.getContext('2d');\n    app.ctx2 = app.canvas2.getContext('2d');\n\n    // キャンバスサイズを設定\n    app.canvas1.width = app.video1.clientWidth;\n    app.canvas1.height = app.video1.clientHeight;\n    app.canvas2.width = app.video2.clientWidth;\n    app.canvas2.height = app.video2.clientHeight;\n\n    // MediaPipeを初期化\n    await initMediaPipe();\n\n    // Three.jsを初期化\n    init3D();\n\n    // イベントリスナーを設定\n    setupEventListeners();\n\n    updateStatus('statusState', '準備完了', 'success');\n}\n\n// =====================================\n// MediaPipe初期化\n// =====================================\nasync function initMediaPipe() {\n    return new Promise((resolve) => {\n        // MediaPipeのロードを待つ\n        if (typeof Pose !== 'undefined') {\n            app.pose = new Pose({\n                locateFile: (file) => {\n                    return `https://cdn.jsdelivr.net/npm/@mediapipe/pose@0.5.1635794155/${file}`;\n                }\n            });\n\n            app.pose.setOptions({\n                modelComplexity: 1,\n                smoothLandmarks: true,\n                enableSegmentation: false,\n                smoothSegmentation: false,\n                minDetectionConfidence: 0.5,\n                minTrackingConfidence: 0.5\n            });\n\n            resolve();\n        } else {\n            // MediaPipeのロードを待つ\n            setTimeout(() => initMediaPipe().then(resolve), 100);\n        }\n    });\n}\n\n// =====================================\n// Three.js初期化\n// =====================================\nfunction init3D() {\n    const canvas3d = document.getElementById('canvas3d');\n    const width = canvas3d.clientWidth;\n    const height = canvas3d.clientHeight;\n\n    // シーン\n    app.scene = new THREE.Scene();\n    app.scene.background = new THREE.Color(0x000000);\n\n    // カメラ\n    app.camera = new THREE.PerspectiveCamera(75, width / height, 0.1, 1000);\n    app.camera.position.set(0, 0, 3);\n\n    // レンダラー\n    app.renderer = new THREE.WebGLRenderer({ canvas: canvas3d, antialias: true });\n    app.renderer.setSize(width, height);\n    app.renderer.setPixelRatio(window.devicePixelRatio);\n\n    // コントロール\n    app.controls = new THREE.OrbitControls(app.camera, app.renderer.domElement);\n    app.controls.enableDamping = true;\n    app.controls.dampingFactor = 0.05;\n    app.controls.autoRotate = false;\n\n    // ライト\n    const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);\n    app.scene.add(ambientLight);\n\n    const directionalLight = new THREE.DirectionalLight(0xffffff, 0.8);\n    directionalLight.position.set(5, 10, 7);\n    app.scene.add(directionalLight);\n\n    // グリッド\n    const gridHelper = new THREE.GridHelper(10, 10);\n    app.scene.add(gridHelper);\n\n    // 骨格グループ\n    app.skeletonGroup = new THREE.Group();\n    app.scene.add(app.skeletonGroup);\n\n    // アニメーションループを開始\n    animate();\n\n    // ウィンドウリサイズ対応\n    window.addEventListener('resize', onWindowResize);\n}\n\n// =====================================\n// イベントリスナー設定\n// =====================================\nfunction setupEventListeners() {\n    document.getElementById('btnStartCameras').addEventListener('click', startCameras);\n    document.getElementById('btnCalibrate').addEventListener('click', calibrate);\n    document.getElementById('btnStartTracking').addEventListener('click', startTracking);\n    document.getElementById('btnReset').addEventListener('click', reset);\n}\n\n// =====================================\n// カメラ起動\n// =====================================\nasync function startCameras() {\n    try {\n        // 複数のカメラデバイスを取得\n        const devices = await navigator.mediaDevices.enumerateDevices();\n        const videoDevices = devices.filter(device => device.kind === 'videoinput');\n\n        if (videoDevices.length < 2) {\n            alert('2つ以上のカメラが接続されていません。');\n            return;\n        }\n\n        // カメラ1\n        const stream1 = await navigator.mediaDevices.getUserMedia({\n            video: { deviceId: videoDevices[0].deviceId, width: 640, height: 480 }\n        });\n        app.video1.srcObject = stream1;\n\n        // カメラ2\n        const stream2 = await navigator.mediaDevices.getUserMedia({\n            video: { deviceId: videoDevices[1].deviceId, width: 640, height: 480 }\n        });\n        app.video2.srcObject = stream2;\n\n        // ビデオの再生を待つ\n        await Promise.all([\n            new Promise(resolve => app.video1.onloadedmetadata = resolve),\n            new Promise(resolve => app.video2.onloadedmetadata = resolve)\n        ]);\n\n        app.video1.play();\n        app.video2.play();\n\n        // カメラパラメータを初期化\n        initCameraParameters();\n\n        app.state = 'cameras_ready';\n        updateStatus('statusState', 'カメラ起動完了');\n        updateStatus('statusCam1', '稼働中', 'success');\n        updateStatus('statusCam2', '稼働中', 'success');\n\n        document.getElementById('btnStartCameras').disabled = true;\n        document.getElementById('btnCalibrate').disabled = false;\n\n        // フレーム処理を開始\n        processFrame();\n    } catch (error) {\n        console.error('カメラアクセスエラー:', error);\n        alert('カメラにアクセスできません。');\n    }\n}\n\n// =====================================\n// カメラパラメータ初期化\n// =====================================\nfunction initCameraParameters() {\n    // 簡易的なカメラ内部パラメータ\n    // 実運用では正確なキャリブレーション（Checkerboard等）が必要\n    const focalLength = 500; // ピクセル単位\n    const principalPoint = { x: 320, y: 240 };\n\n    app.cameraParams.cam1 = {\n        focalLength: focalLength,\n        principalPoint: principalPoint,\n        rotation: [[1, 0, 0], [0, 1, 0], [0, 0, 1]], // 単位行列\n        translation: [0, 0, 0]\n    };\n\n    // カメラ2は少しオフセット\n    app.cameraParams.cam2 = {\n        focalLength: focalLength,\n        principalPoint: principalPoint,\n        rotation: [[1, 0, 0], [0, 1, 0], [0, 0, 1]],\n        translation: [0.15, 0, 0] // 15cm右にオフセット\n    };\n}\n\n// =====================================\n// フレーム処理\n// =====================================\nasync function processFrame() {\n    if (app.state === 'idle') return;\n\n    // カメラ1を処理\n    if (app.video1.readyState === app.video1.HAVE_ENOUGH_DATA) {\n        const results1 = await app.pose.process({ image: app.video1 });\n        app.poseResults.cam1 = results1;\n        drawPose(app.ctx1, app.canvas1, results1);\n    }\n\n    // カメラ2を処理\n    if (app.video2.readyState === app.video2.HAVE_ENOUGH_DATA) {\n        const results2 = await app.pose.process({ image: app.video2 });\n        app.poseResults.cam2 = results2;\n        drawPose(app.ctx2, app.canvas2, results2);\n    }\n\n    // トラッキング状態の場合、3D骨格を更新\n    if (app.state === 'tracking' && app.poseResults.cam1 && app.poseResults.cam2) {\n        updateSkeleton3D();\n    }\n\n    requestAnimationFrame(processFrame);\n}\n\n// =====================================\n// 姿勢の描画\n// =====================================\nfunction drawPose(ctx, canvas, results) {\n    // キャンバスをクリア\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n    if (results.poseLandmarks) {\n        // キーポイントを描画\n        results.poseLandmarks.forEach((landmark, index) => {\n            const x = landmark.x * canvas.width;\n            const y = landmark.y * canvas.height;\n            const visibility = landmark.visibility || 0.5;\n\n            // 円を描画\n            ctx.fillStyle = `rgba(0, 255, 0, ${visibility})`;\n            ctx.beginPath();\n            ctx.arc(x, y, 5, 0, Math.PI * 2);\n            ctx.fill();\n\n            // インデックスを描画\n            ctx.fillStyle = '#fff';\n            ctx.font = '10px Arial';\n            ctx.fillText(index, x + 8, y - 8);\n        });\n\n        // ボーン（骨）を描画\n        app.connections.forEach(([from, to]) => {\n            const p1 = results.poseLandmarks[from];\n            const p2 = results.poseLandmarks[to];\n\n            if (p1.visibility > 0.3 && p2.visibility > 0.3) {\n                ctx.strokeStyle = 'rgba(0, 255, 0, 0.7)';\n                ctx.lineWidth = 2;\n                ctx.beginPath();\n                ctx.moveTo(p1.x * canvas.width, p1.y * canvas.height);\n                ctx.lineTo(p2.x * canvas.width, p2.y * canvas.height);\n                ctx.stroke();\n            }\n        });\n    }\n}\n\n// =====================================\n// キャリブレーション\n// =====================================\nfunction calibrate() {\n    if (!app.poseResults.cam1 || !app.poseResults.cam2) {\n        alert('両方のカメラで骨格が検出できていません。Tポーズをしてください。');\n        return;\n    }\n\n    // Tポーズを検証（肘の位置から肩幅を計測）\n    const landmarks1 = app.poseResults.cam1.poseLandmarks;\n    const landmarks2 = app.poseResults.cam2.poseLandmarks;\n\n    if (!landmarks1 || !landmarks2 || landmarks1.length < 16 || landmarks2.length < 16) {\n        alert('骨格が完全に検出されていません。');\n        return;\n    }\n\n    // キャリブレーションデータを保存\n    app.calibrationData = {\n        cam1: landmarks1,\n        cam2: landmarks2,\n        timestamp: Date.now()\n    };\n\n    app.state = 'calibrated';\n    updateStatus('statusState', 'キャリブレーション完了');\n    updateStatus('statusCalib', '完了', 'success');\n\n    document.getElementById('btnCalibrate').disabled = true;\n    document.getElementById('btnCalibrate').classList.add('success');\n    document.getElementById('btnStartTracking').disabled = false;\n}\n\n// =====================================\n// 3D追跡開始\n// =====================================\nfunction startTracking() {\n    if (app.state !== 'calibrated') {\n        alert('先にキャリブレーションを実行してください。');\n        return;\n    }\n\n    app.state = 'tracking';\n    updateStatus('statusState', '3D追跡中', 'success');\n    document.getElementById('btnStartTracking').disabled = true;\n    document.getElementById('btnStartTracking').classList.add('success');\n}\n\n// =====================================\n// 3D骨格の更新\n// =====================================\nfunction updateSkeleton3D() {\n    // 既存の骨格をクリア\n    while (app.skeletonGroup.children.length > 0) {\n        app.skeletonGroup.remove(app.skeletonGroup.children[0]);\n    }\n\n    if (!app.poseResults.cam1 || !app.poseResults.cam2) return;\n\n    const landmarks1 = app.poseResults.cam1.poseLandmarks;\n    const landmarks2 = app.poseResults.cam2.poseLandmarks;\n\n    // 三角測量により3D位置を計算\n    const skeleton3D = triangulate(landmarks1, landmarks2);\n\n    updateStatus('statusKeypoints', String(skeleton3D.filter(p => p !== null).length));\n\n    // 3D骨格を描画\n    skeleton3D.forEach((point3D, index) => {\n        if (point3D && landmarks1[index].visibility > 0.3) {\n            // ジオメトリを作成\n            const geometry = new THREE.SphereGeometry(0.02, 8, 8);\n            const material = new THREE.MeshPhongMaterial({ color: 0x00ff00 });\n            const sphere = new THREE.Mesh(geometry, material);\n            sphere.position.set(point3D.x, point3D.y, point3D.z);\n            app.skeletonGroup.add(sphere);\n        }\n    });\n\n    // ボーン（骨）を描画\n    app.connections.forEach(([from, to]) => {\n        if (skeleton3D[from] && skeleton3D[to]) {\n            const p1 = skeleton3D[from];\n            const p2 = skeleton3D[to];\n\n            const geometry = new THREE.BufferGeometry();\n            geometry.setAttribute('position', new THREE.BufferAttribute(\n                new Float32Array([p1.x, p1.y, p1.z, p2.x, p2.y, p2.z]),\n                3\n            ));\n\n            const material = new THREE.LineBasicMaterial({ color: 0x00ff00, linewidth: 2 });\n            const line = new THREE.Line(geometry, material);\n            app.skeletonGroup.add(line);\n        }\n    });\n}\n\n// =====================================\n// 三角測量関数\n// =====================================\nfunction triangulate(landmarks1, landmarks2) {\n    const skeleton3D = [];\n\n    for (let i = 0; i < landmarks1.length; i++) {\n        const p1 = landmarks1[i];\n        const p2 = landmarks2[i];\n\n        if (p1.visibility < 0.3 || p2.visibility < 0.3) {\n            skeleton3D.push(null);\n            continue;\n        }\n\n        // 正規化された画像座標をカメラ座標に変換\n        const point3D = triangulatePoint(\n            { x: p1.x, y: p1.y },\n            { x: p2.x, y: p2.y },\n            app.cameraParams.cam1,\n            app.cameraParams.cam2\n        );\n\n        skeleton3D.push(point3D);\n    }\n\n    return skeleton3D;\n}\n\n// =====================================\n// 点の三角測量\n// =====================================\nfunction triangulatePoint(point1, point2, camera1, camera2) {\n    // 線形最小二乗法による三角測量\n    // 詳細は：\"Multiple View Geometry in Computer Vision\" (Hartley & Zisserman)\n\n    // 簡易版：2カメラの三角測量\n    // 実運用ではより精密な手法が必要\n\n    const f = camera1.focalLength;\n    const b = distance3D(camera2.translation, camera1.translation);\n\n    // 視差から深度を推定\n    const disparity = Math.abs(point1.x - point2.x);\n    const depth = disparity > 0.001 ? (f * b) / (disparity * 320) : 2; // ピクセル差分から深度推定\n\n    // 3D座標を計算\n    const x = (point1.x - camera1.principalPoint.x / 320) * depth / f;\n    const y = (point1.y - camera1.principalPoint.y / 240) * depth / f;\n    const z = depth;\n\n    return { x, y: -y, z }; // Y軸を反転（画像座標系との差異を補正）\n}\n\n// =====================================\n// ユーティリティ関数\n// =====================================\nfunction distance3D(p1, p2) {\n    const dx = p2[0] - p1[0];\n    const dy = p2[1] - p1[1];\n    const dz = p2[2] - p1[2];\n    return Math.sqrt(dx * dx + dy * dy + dz * dz);\n}\n\nfunction updateStatus(elementId, text, className = '') {\n    const element = document.getElementById(elementId);\n    if (element) {\n        element.textContent = text;\n        element.className = 'status-value';\n        if (className) {\n            element.classList.add(className);\n        }\n    }\n}\n\n// =====================================\n// リセット\n// =====================================\nfunction reset() {\n    app.state = 'idle';\n    app.calibrationData = null;\n\n    // ビデオを停止\n    if (app.video1.srcObject) {\n        app.video1.srcObject.getTracks().forEach(track => track.stop());\n    }\n    if (app.video2.srcObject) {\n        app.video2.srcObject.getTracks().forEach(track => track.stop());\n    }\n\n    // 骨格をクリア\n    while (app.skeletonGroup.children.length > 0) {\n        app.skeletonGroup.remove(app.skeletonGroup.children[0]);\n    }\n\n    // ボタンの状態をリセット\n    document.getElementById('btnStartCameras').disabled = false;\n    document.getElementById('btnCalibrate').disabled = true;\n    document.getElementById('btnStartTracking').disabled = true;\n    document.querySelectorAll('button.success').forEach(btn => btn.classList.remove('success'));\n\n    // ステータスを更新\n    updateStatus('statusState', '準備中');\n    updateStatus('statusCam1', '未起動');\n    updateStatus('statusCam2', '未起動');\n    updateStatus('statusCalib', '未実施');\n    updateStatus('statusKeypoints', '0');\n}\n\n// =====================================\n// Three.jsアニメーションループ\n// =====================================\nfunction animate() {\n    requestAnimationFrame(animate);\n    app.controls.update();\n    app.renderer.render(app.scene, app.camera);\n}\n\n// =====================================\n// ウィンドウリサイズ対応\n// =====================================\nfunction onWindowResize() {\n    const canvas3d = document.getElementById('canvas3d');\n    const width = canvas3d.clientWidth;\n    const height = canvas3d.clientHeight;\n\n    app.camera.aspect = width / height;\n    app.camera.updateProjectionMatrix();\n    app.renderer.setSize(width, height);\n}\n\n// =====================================\n// 起動\n// =====================================\nwindow.addEventListener('DOMContentLoaded', init);\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/mediapipe/app.js","message":"ファイルを作成しました"},"approvalTime":1.992},"memory_usage":2097152,"script":"tool_history.php"}
