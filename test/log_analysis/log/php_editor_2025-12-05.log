{"timestamp":"2025-12-05 12:29:45","level":"INFO","level_num":1,"pid":302170,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"index.html","content":"<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>3D 骨格スキャンシステム</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Arial', sans-serif;\n            background: #1a1a1a;\n            color: #fff;\n            overflow: hidden;\n            height: 100vh;\n        }\n\n        .container {\n            display: flex;\n            height: 100vh;\n            gap: 10px;\n            padding: 10px;\n        }\n\n        .section {\n            flex: 1;\n            border: 1px solid #333;\n            border-radius: 8px;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            background: #222;\n        }\n\n        .section h2 {\n            background: #111;\n            padding: 10px;\n            font-size: 16px;\n            border-bottom: 1px solid #333;\n        }\n\n        .section-content {\n            flex: 1;\n            position: relative;\n            overflow: hidden;\n        }\n\n        canvas {\n            width: 100% !important;\n            height: 100% !important;\n            display: block;\n        }\n\n        .info-panel {\n            background: rgba(0, 0, 0, 0.7);\n            padding: 10px;\n            font-size: 12px;\n            border-top: 1px solid #333;\n        }\n\n        .info-panel h4 {\n            margin-bottom: 5px;\n            color: #4a9eff;\n        }\n\n        .info-panel div {\n            margin: 2px 0;\n        }\n\n        .stats {\n            background: rgba(0, 0, 0, 0.7);\n            padding: 10px;\n            font-size: 12px;\n            border-top: 1px solid #333;\n        }\n\n        .stats-item {\n            display: flex;\n            justify-content: space-between;\n            margin: 3px 0;\n        }\n\n        .stats-label {\n            color: #888;\n            min-width: 80px;\n        }\n\n        .stats-value {\n            color: #4a9eff;\n            font-weight: bold;\n        }\n\n        .button-group {\n            display: flex;\n            gap: 5px;\n            padding: 10px;\n            flex-wrap: wrap;\n        }\n\n        button {\n            padding: 8px 12px;\n            background: #0066cc;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n            font-size: 12px;\n            transition: background 0.3s;\n        }\n\n        button:hover {\n            background: #0052a3;\n        }\n\n        button:disabled {\n            background: #666;\n            cursor: not-allowed;\n        }\n\n        .status-indicator {\n            display: inline-block;\n            width: 10px;\n            height: 10px;\n            border-radius: 50%;\n            margin-right: 5px;\n        }\n\n        .status-ok {\n            background: #00cc00;\n        }\n\n        .status-loading {\n            background: #ffaa00;\n        }\n\n        .status-error {\n            background: #ff3333;\n        }\n\n        .slider-group {\n            padding: 10px;\n            border-top: 1px solid #333;\n        }\n\n        .slider-group label {\n            display: block;\n            margin-bottom: 5px;\n            font-size: 12px;\n            color: #888;\n        }\n\n        .slider-group input[type=\"range\"] {\n            width: 100%;\n        }\n\n        .slider-value {\n            display: inline-block;\n            color: #4a9eff;\n            font-weight: bold;\n            margin-left: 5px;\n        }\n\n        .left-panel, .right-panel {\n            width: 250px;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .center-panel {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .top-section, .bottom-section {\n            flex: 1;\n            border: 1px solid #333;\n            border-radius: 8px;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n            background: #222;\n            margin-bottom: 10px;\n        }\n\n        .bottom-section {\n            margin-bottom: 0;\n        }\n\n        .top-section h2, .bottom-section h2 {\n            background: #111;\n            padding: 10px;\n            font-size: 16px;\n            border-bottom: 1px solid #333;\n        }\n\n        .top-content, .bottom-content {\n            flex: 1;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .keypoints-list {\n            padding: 10px;\n            font-size: 11px;\n            overflow-y: auto;\n            flex: 1;\n        }\n\n        .keypoint-item {\n            background: #333;\n            padding: 5px;\n            margin: 3px 0;\n            border-radius: 3px;\n            display: flex;\n            justify-content: space-between;\n            border-left: 3px solid #4a9eff;\n        }\n\n        .keypoint-name {\n            font-weight: bold;\n        }\n\n        .keypoint-coords {\n            color: #888;\n            font-size: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <!-- 左パネル: コントロール -->\n        <div class=\"left-panel\">\n            <div class=\"section\">\n                <h2>コントロール</h2>\n                <div class=\"button-group\">\n                    <button id=\"startBtn\">開始</button>\n                    <button id=\"stopBtn\" disabled>停止</button>\n                    <button id=\"captureBtn\" disabled>スクリーン</button>\n                </div>\n                <div class=\"button-group\">\n                    <button id=\"resetBtn\">リセット</button>\n                    <button id=\"toggleGridBtn\">グリッド切替</button>\n                </div>\n                <div class=\"slider-group\">\n                    <label>\n                        回転速度: <span class=\"slider-value\" id=\"rotationValue\">0</span>\n                    </label>\n                    <input type=\"range\" id=\"rotationSlider\" min=\"0\" max=\"2\" step=\"0.1\" value=\"0\">\n                </div>\n                <div class=\"slider-group\">\n                    <label>\n                        スケール: <span class=\"slider-value\" id=\"scaleValue\">1.0</span>\n                    </label>\n                    <input type=\"range\" id=\"scaleSlider\" min=\"0.5\" max=\"3\" step=\"0.1\" value=\"1\">\n                </div>\n                <div class=\"stats\">\n                    <h4>ステータス</h4>\n                    <div class=\"stats-item\">\n                        <span class=\"stats-label\">ポーズ検出:</span>\n                        <span class=\"stats-value\">\n                            <span class=\"status-indicator status-loading\"></span>準備中\n                        </span>\n                    </div>\n                    <div class=\"stats-item\">\n                        <span class=\"stats-label\">フレーム:</span>\n                        <span class=\"stats-value\" id=\"frameCount\">0</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 中央パネル: ビデオと3D表示 -->\n        <div class=\"center-panel\">\n            <!-- 上段: ビデオ入力 -->\n            <div class=\"top-section\">\n                <h2>ウェブカメラ入力</h2>\n                <div class=\"top-content\">\n                    <video id=\"video\" style=\"width: 100%; height: 100%; object-fit: cover;\"></video>\n                </div>\n            </div>\n\n            <!-- 下段: 3D表示 -->\n            <div class=\"bottom-section\">\n                <h2>3D 骨格ビューア</h2>\n                <div class=\"bottom-content\">\n                    <canvas id=\"canvas3d\"></canvas>\n                    <div class=\"info-panel\">\n                        <h4>操作方法</h4>\n                        <div>マウスドラッグ: 回転</div>\n                        <div>スクロール: ズーム</div>\n                        <div>右ドラッグ: パン</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <!-- 右パネル: キーポイント情報 -->\n        <div class=\"right-panel\">\n            <div class=\"section\">\n                <h2>検出キーポイント</h2>\n                <div class=\"keypoints-list\" id=\"keypointsList\">\n                    <div style=\"color: #888; text-align: center; padding: 20px;\">\n                        ポーズ検出開始を待機中...\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- ライブラリのロード -->\n    <script src=\"https://cdn.jsdelivr.net/npm/@mediapipe/pose@0.5.1675469404/pose.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@r128/build/three.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/three@r128/examples/js/controls/OrbitControls.js\"></script>\n\n    <!-- メインスクリプト -->\n    <script src=\"app.js\"></script>\n</body>\n</html>"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":7.791},"memory_usage":2097152,"script":"tool_history.php"}
