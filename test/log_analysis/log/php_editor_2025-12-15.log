{"timestamp":"2025-12-15 12:52:02","level":"INFO","level_num":1,"pid":67665,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"editFileByLines","parameters":{"filename":"index.php","lineStart":1,"lineEnd":165,"newContent":"<?php\n// index.php\n// -------------------------------------------------------\n// ① PHP側でページのベースを出力（HTML＋CSS）\n// ② JavaScriptで 1 秒ごとに各種時刻を計算・表示\n// -------------------------------------------------------\n?>\n<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>マルチタイム時計</title>\n    <style>\n        /* -------------------------------------------------------\n           基本レイアウト & 見た目\n           ------------------------------------------------ */\n        body {\n            font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n            background: #f5f5f5;\n            color: #333;\n            margin: 0;\n            padding: 20px;\n        }\n        h1 {\n            text-align: center;\n            margin-bottom: 30px;\n        }\n        .clock-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 20px;\n        }\n        .clock-item {\n            background: #fff;\n            border-radius: 8px;\n            padding: 15px 20px;\n            box-shadow: 0 2px 6px rgba(0,0,0,0.1);\n            word-break: break-all;\n        }\n        .clock-item h2 {\n            font-size: 1rem;\n            margin: 0 0 8px;\n            color: #555;\n        }\n        .clock-item p {\n            margin: 0;\n            font-size: 1.1rem;\n            font-weight: 500;\n            color: #111;\n        }\n        .clock-canvas {\n            display: block;\n            margin: 10px auto 0;\n            background: #fafafa;\n            border: 1px solid #ddd;\n            border-radius: 50%;\n        }\n    </style>\n</head>\n<body>\n    <h1>🕰️ マルチタイム時計</h1>\n    <div class=\"clock-grid\">\n        <div class=\"clock-item\">\n            <h2>ローカル日時（YYYY/MM/DD HH:MM:SS）</h2>\n            <p id=\"local\"></p>\n            <canvas id=\"localCanvas\" class=\"clock-canvas\" width=\"150\" height=\"150\"></canvas>\n        </div>\n        <div class=\"clock-item\">\n            <h2>UTC（協定世界時）</h2>\n            <p id=\"utc\"></p>\n            <canvas id=\"utcCanvas\" class=\"clock-canvas\" width=\"150\" height=\"150\"></canvas>\n        </div>\n        <div class=\"clock-item\">\n            <h2>Unix Time（秒）</h2>\n            <p id=\"unix\"></p>\n            <canvas id=\"unixCanvas\" class=\"clock-canvas\" width=\"150\" height=\"150\"></canvas>\n        </div>\n        <div class=\"clock-item\">\n            <h2>ISO 8601（文字列）</h2>\n            <p id=\"iso\"></p>\n        </div>\n        <div class=\"clock-item\">\n            <h2>Julian Date（ユリウス日）</h2>\n            <p id=\"julian\"></p>\n        </div>\n        <div class=\"clock-item\">\n            <h2>GPS Time（秒・2019‑01‑01 00:00:00 起算）</h2>\n            <p id=\"gps\"></p>\n            <canvas id=\"gpsCanvas\" class=\"clock-canvas\" width=\"150\" height=\"150\"></canvas>\n        </div>\n        <div class=\"clock-item\">\n            <h2>宇宙誕生からの経過時間</h2>\n            <p id=\"sinceBigBang\"></p>\n        </div>\n        <div class=\"clock-item\">\n            <h2>経過ミリ秒（1970‑01‑01T00:00:00Z 基準）</h2>\n            <p id=\"millis\"></p>\n        </div>\n    </div>\n    <script>\n        // -------------------------------------------------------\n        //   時刻計算ロジック（全て JavaScript で実装）\n        // -------------------------------------------------------\n        const BIG_BANG_MS = new Date('1970-01-01T00:00:00Z').getTime(); // placeholder, actual value will be replaced later\n        const BIG_BANG_YEAR = -1380000000; // Approx. 13.8 billion years ago in seconds\n\n        const BIG_BANG_DATE = new Date('1970-01-01T00:00:00Z'); // not used directly, kept for reference\n\n        function drawAnalogClock(ctx, time) {\n            const radius = ctx.canvas.width / 2;\n            ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);\n            ctx.save();\n            ctx.translate(radius, radius);\n            ctx.rotate(-Math.PI / 2);\n            // 背景円\n            ctx.beginPath();\n            ctx.arc(0, 0, radius - 5, 0, Math.PI * 2);\n            ctx.fillStyle = '#fff';\n            ctx.fill();\n            ctx.strokeStyle = '#333';\n            ctx.lineWidth = 4;\n            ctx.stroke();\n            // 時・分・秒の針\n            const sec = time.getSeconds();\n            const min = time.getMinutes();\n            const hr = time.getHours() % 12;\n            // 秒針\n            ctx.save();\n            ctx.rotate(sec * Math.PI / 30);\n            ctx.beginPath();\n            ctx.moveTo(0, 0);\n            ctx.lineTo(radius - 20, 0);\n            ctx.strokeStyle = '#d33';\n            ctx.lineWidth = 2;\n            ctx.stroke();\n            ctx.restore();\n            // 分針\n            ctx.save();\n            ctx.rotate((min + sec / 60) * Math.PI / 30);\n            ctx.beginPath();\n            ctx.moveTo(0, 0);\n            ctx.lineTo(radius - 40, 0);\n            ctx.strokeStyle = '#555';\n            ctx.lineWidth = 4;\n            ctx.stroke();\n            ctx.restore();\n            // 時針\n            ctx.save();\n            ctx.rotate((hr + min / 60) * Math.PI / 6);\n            ctx.beginPath();\n            ctx.moveTo(0, 0);\n            ctx.lineTo(radius - 60, 0);\n            ctx.strokeStyle = '#000';\n            ctx.lineWidth = 6;\n            ctx.stroke();\n            ctx.restore();\n            ctx.restore();\n        }\n\n        function updateClocks() {\n            const now = new Date();\n            // ローカル\n            const localStr = now.toLocaleString('ja-JP', {year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',second:'2-digit'}).replace(/\\//g, '/');\n            document.getElementById('local').textContent = localStr;\n            drawAnalogClock(document.getElementById('localCanvas').getContext('2d'), now);\n            // UTC\n            const utc = new Date(now.getTime() + now.getTimezoneOffset() * 60000);\n            const utcStr = utc.toISOString().replace('T', ' ').replace('Z', '');\n            document.getElementById('utc').textContent = utcStr + ' UTC';\n            drawAnalogClock(document.getElementById('utcCanvas').getContext('2d'), utc);\n            // Unix Time\n            const unixSec = Math.floor(now.getTime() / 1000);\n            document.getElementById('unix').textContent = unixSec.toLocaleString();\n            drawAnalogClock(document.getElementById('unixCanvas').getContext('2d'), now);\n            // ISO 8601\n            document.getElementById('iso').textContent = now.toISOString();\n            // Julian Date\n            const jd = (now / 86400000) + 2440587.5;\n            document.getElementById('julian').textContent = jd.toFixed(5);\n            // GPS Time (起算: 2019‑01‑01 00:00:00 UTC)\n            const gpsEpoch = new Date('2019-01-01T00:00:00Z');\n            const gpsSec = Math.floor((now - gpsEpoch) / 1000);\n            document.getElementById('gps').textContent = gpsSec.toLocaleString();\n            // 宇宙誕生からの経過時間（ビッグバンから約13.8 十億年）\n            const bigBangMs = now - new Date('1970-01-01T00:00:00Z'); // placeholder, will be replaced by actual calculation\n            // ここでは簡易的に「年・日・時間」へ換算\n            const years = Math.floor((now - new Date('1970-01-01')) / (365.25 * 24 * 60 * 60 * 1000));\n            document.getElementById('sinceBigBang').textContent = years + ' 年';\n            // 経過ミリ秒（1970‑01‑01 基準）\n            document.getElementById('millis').textContent = now.getTime().toLocaleString();\n        }\n        // 初回実行 & 1 秒ごとに更新\n        updateClocks();\n        setInterval(updateClocks, 1000);\n    </script>\n</body>\n</html>"},"status":"error","result":{"error":"can't access property \"split\", currentContent is undefined"},"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
