{"timestamp":"2025-12-15 12:21:14","level":"INFO","level_num":1,"pid":67665,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"calculate.php","content":"<?php\n// calculate.php - 宇宙時間換算エンジン\n// 火星時間・ケレス時間・冥王星時間への換算を実行\n\n// セッション開始\nsession_start();\n\n// フォーム送信時の処理\nif ($_SERVER['REQUEST_METHOD'] === 'GET' && isset($_GET['number'], $_GET['unit'])) {\n    // 入力検証\n    $number = filter_input(INPUT_GET, 'number', FILTER_VALIDATE_FLOAT);\n    $unit = filter_input(INPUT_GET, 'unit', FILTER_SANITIZE_STRING);\n    \n    $errors = [];\n    $result = null;\n    \n    if (!$number) {\n        $errors[] = '有効な数字を入力してください';\n    }\n    \n    $valid_units = ['celsius', 'fahrenheit', 'kelvin'];\n    if (!in_array($unit, $valid_units)) {\n        $errors[] = '有効な単位を選択してください';\n    }\n    \n    // 換算ロジック\n    if (empty($errors)) {\n        switch($unit) {\n            case 'celsius':\n                $fahrenheit = ($number * 9/5) + 32;\n                $kelvin = $number + 273.15;\n                break;\n            case 'fahrenheit':\n                $celsius = ($number - 32) * 5/9;\n                $kelvin = ($number - 32) * 5/9 + 273.15;\n                break;\n            case 'kelvin':\n                $celsius = $number - 273.15;\n                $fahrenheit = ($number - 273.15) * 9/5 + 32;\n                break;\n        }\n        \n        // 宇宙単位換算\n        $mars_time = $number * 1.0275; // 火星の1日は24時間39分\n        $ceres_time = $number * 0.084; // ケレスの1日\n        $pluto_time = $number * 6.39; // 冥王星の1日\n        \n        $result = [\n            'celsius' => isset($celsius) ? round($celsius, 2) : null,\n            'fahrenheit' => isset($fahrenheit) ? round($fahrenheit, 2) : null,\n            'kelvin' => isset($kelvin) ? round($kelvin, 2) : null,\n            'mars' => round($mars_time, 2),\n            'ceres' => round($ceres_time, 2),\n            'pluto' => round($pluto_time, 2)\n        ];\n    }\n}\n\n// クライアントサイドデータ生成\n$clientData = [\n    'errors' => $errors ?? [],\n    'result' => $result ?? null\n];\n\n// JSONでクライアントに返すデータ形式\nheader('Content-Type: application/json');\necho json_encode($clientData);\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/a/calculate.php","message":"ファイルを作成しました"},"approvalTime":25.812},"memory_usage":2097152,"script":"tool_history.php"}
