{"timestamp":"2025-12-15 12:38:27","level":"INFO","level_num":1,"pid":67662,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"index.php","content":"<?php\n// index.php - アナログ針・ゲージで時間を可視化\n?>\n<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>マルチタイム時計（針・ゲージ版）</title>\n    <style>\n        body {\n            font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n            background: #f0f4f8;\n            color: #333;\n            margin: 0;\n            padding: 20px;\n        }\n        h1 { text-align: center; margin-bottom: 30px; }\n        .clock-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 20px;\n        }\n        .clock-item {\n            background: #fff;\n            border-radius: 8px;\n            padding: 15px 20px;\n            box-shadow: 0 2px 6px rgba(0,0,0,0.1);\n            text-align: center;\n        }\n        .clock-item h2 { font-size: 1rem; margin: 0 0 8px; color: #555; }\n        canvas { display: block; margin: 0 auto; }\n        /* ---------- ゲージ（円形プログレス） ---------- */\n        .gauge {\n            position: relative;\n            width: 150px; height: 150px;\n            margin: 0 auto;\n            border-radius: 50%;\n            background: conic-gradient(#4caf50 0deg, #e0e0e0 0deg);\n        }\n        .gauge .center {\n            position: absolute;\n            top: 50%; left: 50%;\n            width: 110px; height: 110px;\n            margin:-55px 0 0 -55px;\n            border-radius: 50%;\n            background: #fff;\n            line-height: 110px;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <h1>🕰️ マルチタイム時計（針・ゲージ版）</h1>\n    <div class=\"clock-grid\">\n        <!-- ローカル時間：アナログ時計 -->\n        <div class=\"clock-item\">\n            <h2>ローカル日時（アナログ）</h2>\n            <canvas id=\"localCanvas\" width=\"200\" height=\"200\"></canvas>\n        </div>\n        <!-- UTC：アナログ時計 -->\n        <div class=\"clock-item\">\n            <h2>UTC（アナログ）</h2>\n            <canvas id=\"utcCanvas\" width=\"200\" height=\"200\"></canvas>\n        </div>\n        <!-- Unix Time：ゲージ（1日内の秒） -->\n        <div class=\"clock-item\">\n            <h2>Unix Time（1日内秒ゲージ）</h2>\n            <div class=\"gauge\" id=\"unixGauge\"><div class=\"center\" id=\"unixGaugeLabel\"></div></div>\n        </div>\n        <!-- ISO 8601：数値（そのまま） -->\n        <div class=\"clock-item\">\n            <h2>ISO 8601（文字列）</h2>\n            <p id=\"iso\"></p>\n        </div>\n        <!-- Julian Date：ゲージ（小数部） -->\n        <div class=\"clock-item\">\n            <h2>Julian Date（ゲージ）</h2>\n            <div class=\"gauge\" id=\"julianGauge\"><div class=\"center\" id=\"julianGaugeLabel\"></div></div>\n        </div>\n        <!-- GPS Time：アナログ時計（UTC+0 の時計に近い） -->\n        <div class=\"clock-item\">\n            <h2>GPS Time（アナログ）</h2>\n            <canvas id=\"gpsCanvas\" width=\"200\" height=\"200\"></canvas>\n        </div>\n        <!-- 宇宙誕生からの経過時間：ゲージ（年の進捗） -->\n        <div class=\"clock-item\">\n            <h2>宇宙誕生からの経過（年ゲージ）</h2>\n            <div class=\"gauge\" id=\"bigBangGauge\"><div class=\"center\" id=\"bigBangGaugeLabel\"></div></div>\n        </div>\n        <!-- ミリ秒：数値 -->\n        <div class=\"clock-item\">\n            <h2>経過ミリ秒（1970‑01‑01）</h2>\n            <p id=\"millis\"></p>\n        </div>\n    </div>\n    <script>\n        // ---------- 共通定数 ----------\n        const BIG_BANG_AGE_YEARS = 13.79e9;            // 宇宙年齢（年）\n        const SECONDS_IN_YEAR   = 365.25 * 24 * 3600; // 1 年の秒数（平均）\n        const GPS_EPOCH = new Date(Date.UTC(1980, 0, 6, 0, 0, 0)); // GPS基点\n\n        // ---------- アナログ時計描画 ----------\n        function drawAnalog(ctx, date, radius) {\n            ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);\n            const width = ctx.canvas.width, height = ctx.canvas.height;\n            const cx = width/2, cy = height/2;\n            // 時計盤\n            ctx.beginPath();\n            ctx.arc(cx, cy, radius, 0, 2*Math.PI);\n            ctx.fillStyle = '#fafafa';\n            ctx.fill();\n            ctx.strokeStyle = '#333';\n            ctx.lineWidth = 2;\n            ctx.stroke();\n            // 時間・分・秒の角度\n            const sec = date.getSeconds();\n            const min = date.getMinutes() + sec/60;\n            const hour = (date.getHours()%12) + min/60;\n            // 時針\n            const hourAngle = (hour/12)*2*Math.PI - Math.PI/2;\n            ctx.save();\n            ctx.translate(cx, cy);\n            ctx.rotate(hourAngle);\n            ctx.beginPath();\n            ctx.moveTo(0,0);\n            ctx.lineTo(radius*0.5,0);\n            ctx.strokeStyle = '#000';\n            ctx.lineWidth = 6;\n            ctx.stroke();\n            ctx.restore();\n            // 分針\n            const minAngle = (min/60)*2*Math.PI - Math.PI/2;\n            ctx.save();\n            ctx.translate(cx, cy);\n            ctx.rotate(minAngle);\n            ctx.beginPath();\n            ctx.moveTo(0,0);\n            ctx.lineTo(radius*0.75,0);\n            ctx.strokeStyle = '#000';\n            ctx.lineWidth = 4;\n            ctx.stroke();\n            ctx.restore();\n            // 秒針\n            const secAngle = (sec/60)*2*Math.PI - Math.PI/2;\n            ctx.save();\n            ctx.translate(cx, cy);\n            ctx.rotate(secAngle);\n            ctx.beginPath();\n            ctx.moveTo(0,0);\n            ctx.lineTo(radius*0.85,0);\n            ctx.strokeStyle = '#d00';\n            ctx.lineWidth = 2;\n            ctx.stroke();\n            ctx.restore();\n            // 中心点\n            ctx.beginPath();\n            ctx.arc(cx, cy, 4, 0, 2*Math.PI);\n            ctx.fillStyle = '#000';\n            ctx.fill();\n        }\n\n        // ---------- ゲージ更新 ----------\n        function updateGauge(elem, percent, label) {\n            const deg = percent * 360;\n            elem.style.background = `conic-gradient(#4caf50 ${deg}deg, #e0e0e0 ${deg}deg)`;\n            if(label) elem.querySelector('.center').textContent = label;\n        }\n\n        function updateClocks(){\n            const now = new Date();\n            // ---- ローカル時間（アナログ） ----\n            const localCanvas = document.getElementById('localCanvas');\n            drawAnalog(localCanvas.getContext('2d'), now, 90);\n            // ---- UTC（アナログ） ----\n            const utc = new Date(now.getTime() + now.getTimezoneOffset()*60000);\n            const utcCanvas = document.getElementById('utcCanvas');\n            drawAnalog(utcCanvas.getContext('2d'), utc, 90);\n            // ---- Unix Time ゲージ（1日内の秒） ----\n            const unixSec = Math.floor(now.getTime()/1000);\n            const secsInDay = 86400;\n            const dayProgress = (unixSec % secsInDay) / secsInDay; // 0-1\n            const unixGauge = document.getElementById('unixGauge');\n            updateGauge(unixGauge, dayProgress, `${Math.floor(dayProgress*100)}%`);\n            // ---- ISO 8601（テキスト） ----\n            document.getElementById('iso').textContent = now.toISOString();\n            // ---- Julian Date ゲージ（小数部 0‑1） ----\n            const jd = (now / 86400000) + 2440587.5; // 小数部は日付の進行\n            const jdFraction = jd - Math.floor(jd);\n            const julianGauge = document.getElementById('julianGauge');\n            updateGauge(julianGauge, jdFraction, jdFraction.toFixed(3));\n            // ---- GPS Time（アナログ） ----\n            const gpsSec = Math.floor((now - GPS_EPOCH)/1000);\n            const gpsDate = new Date(gpsSec*1000); // treat as epoch\n            const gpsCanvas = document.getElementById('gpsCanvas');\n            drawAnalog(gpsCanvas.getContext('2d'), gpsDate, 90);\n            // ---- 宇宙誕生からの経過時間（年ゲージ） ----\n            const universeAgeSec = BIG_BANG_AGE_YEARS * SECONDS_IN_YEAR;\n            const elapsedSec = universeAgeSec + unixSec - Math.floor(universeAgeSec);\n            const years = Math.floor(elapsedSec / SECONDS_IN_YEAR);\n            const progressYear = (elapsedSec % SECONDS_IN_YEAR) / SECONDS_IN_YEAR;\n            const bigBangGauge = document.getElementById('bigBangGauge');\n            updateGauge(bigBangGauge, progressYear, `${years.toLocaleString()} 年`);\n            // ---- ミリ秒（テキスト） ----\n            document.getElementById('millis').textContent = now.getTime().toLocaleString() + ' ms';\n        }\n\n        // 初回と定期実行\n        updateClocks();\n        setInterval(updateClocks, 1000);\n    </script>\n</body>\n</html>\n"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":1.868},"memory_usage":2097152,"script":"tool_history.php"}
