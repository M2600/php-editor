{"timestamp":"2026-01-03 14:15:03","level":"INFO","level_num":1,"pid":12039,"user_id":"dev","message":"File save started","context":{"path":"/vibe_coding/hcp2504/get.php","file_size_bytes":632,"content":"<?php\n$query = $_POST[\"query\"];\n$min_price = $_POST[\"min_price\"];\n$max_price = $_POST[\"max_price\"];\n$file = file(\"items.txt\", FILE_IGNORE_NEW_LINES);\n$response = [];\nforeach ($file as $line){\n    $item = explode(\",\", $line);\n    if(($query == \"\" || mb_strpos($item[0], $query) !== false)\n    && ($min_price == \"\" || (int)$item[2] >= (int)$min_price)\n    && ($max_price == \"\" || (int)$item[2] <= (int)$max_price)){\n        $response[] = [\n            $item[0],\n            $item[1],\n            \"￥$item[2]\",\n            \"<img src='$item[3]' height='250px'>\"\n        ];\n    }\n}\necho (json_encode($response, JSON_UNESCAPED_UNICODE));"},"memory_usage":2097152,"script":"file_manager.php"}
