{"timestamp":"2026-01-05 04:32:18","level":"INFO","level_num":1,"pid":12039,"user_id":"dev","message":"File save started","context":{"path":"/vibe_coding/hcp2504/get.php","file_size_bytes":659,"content":"<?php\n$query = $_POST['query'];\n$min_price = $_POST['min_price'];\n$max_price = $_POST['max_price'];\n$file = file('items.txt', FILE_IGNORE_NEW_LINES);\n$response = [];\nforeach ($file as $line) {\n    $item = explode(',', $line);\n    if ($query !== '' && mb_strpos($item[0], $query) === false) {\n        continue;\n    }\n    $price = (float) $item[2];\n    if ($min_price !== '' && $price < (float) $min_price) {\n        continue;\n    }\n    if ($max_price !== '' && $price > (float) $max_price) {\n        continue;\n    }\n    $response[] = [$item[0], $item[1], \"$item[2]\", \"<img src='$item[3]' height='250px'>\"];}\necho json_encode($response, JSON_UNESCAPED_UNICODE);"},"memory_usage":2097152,"script":"file_manager.php"}
