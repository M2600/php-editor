{"timestamp":"2026-04-19 14:24:38","level":"INFO","level_num":1,"pid":214523,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"/vibe_coding/mytube2/js/app.js","content":"// ============================================\n// API 呼び出し関数\n// ============================================\nasync function apiRequest(url, method = 'GET', body = null) {\n    const options = {\n        method,\n        headers: {},\n    };\n    \n    if (body) {\n        if (body instanceof FormData) {\n            options.body = body;\n        } else {\n            options.headers['Content-Type'] = 'application/json';\n            options.body = JSON.stringify(body);\n        }\n    }\n    \n    const response = await fetch(url, options);\n    \n    if (!response.ok) {\n        const text = await response.text();\n        throw new Error(text || 'APIエラーが発生しました');\n    }\n    \n    // 画像ファイルなどバイナリデータのときはそのまま返す\n    if (url.includes('thumbnail') || url.includes('type=image')) {\n        return await response.blob();\n    }\n    \n    return await response.json();\n}\n\n// ============================================\n// ホームページ用\n// ============================================\nasync function loadVideos() {\n    console.log('loadVideos called');\n    const container = document.getElementById('video-list');\n    \n    if (!container) {\n        console.log('Container not found');\n        return;\n    }\n    \n    try {\n        const searchParams = window.location.search;\n        const response = await apiRequest(`api/videos.php${searchParams}`);\n        \n        container.innerHTML = '';\n        \n        if (response.videos.length === 0) {\n            container.innerHTML = '<p>動画が見つかりません</p>';\n            return;\n        }\n        \n        response.videos.forEach(video => {\n            const card = createVideoCard(video);\n            container.appendChild(card);\n        });\n    } catch (error) {\n        container.innerHTML = `<p>動画の読み込みに失敗しました: ${escapeHtml(error.message)}</p>`;\n    }\n}\n\n// ============================================\n// アップロードページ用\n// ============================================\nasync function handleUpload() {\n    console.log('handleUpload called');\n    const form = document.getElementById('upload-form');\n    const fileInfo = document.getElementById('file-info');\n    \n    if (!form) {\n        console.log('Form not found');\n        return;\n    }\n    \n    console.log('Form found, adding submit listener');\n    form.addEventListener('submit', async (e) => {\n        console.log('submit event triggered');\n        e.preventDefault();\n        \n        // 動画ファイルサイズ制限（50MB）\n        const MAX_SIZE = 50 * 1024 * 1024;\n        const videoInput = document.getElementById('video-file');\n        \n        if (videoInput.files[0]?.size > MAX_SIZE) {\n            showStatus('ファイルサイズが大きすぎます', 'error');\n            return;\n        }\n        \n        const file = videoInput.files[0];\n        if (!file) {\n            showStatus('動画ファイルを選択してください', 'error');\n            return;\n        }\n        \n        // formDataを作成\n        const formData = new FormData();\n        formData.append('video', file);\n        \n        if (videoInput.files[1]) {\n            formData.append('thumbnail', videoInput.files[1]);\n        }\n        \n        const title = document.getElementById('video-title').value;\n        const description = document.getElementById('video-description').value;\n        formData.append('title', title);\n        formData.append('description', description);\n        \n        try {\n            showStatus('アップロード中...', 'info');\n            const response = await apiRequest('api/upload.php', 'POST', formData);\n            showStatus(response.message, 'success');\n            form.reset();\n            fileInfo.textContent = '';\n            \n            // 3秒後にホームへリダイレクト\n            setTimeout(() => {\n                window.location.href = 'index.html';\n            }, 3000);\n        } catch (error) {\n            showStatus(`アップロードに失敗しました: ${error.message}`, 'error');\n        }\n    });\n}\n\n// ============================================\n// 動画視聴ページ用\n// ============================================\nasync function loadVideo() {\n    const VIDEO_ID = window.location.search.split('id=')[1]?.split('&')[0];\n    \n    if (typeof VIDEO_ID !== 'undefined') {\n        loadVideoDetail(VIDEO_ID);\n        return;\n    }\n    \n    try {\n        \n    } catch (error) {\n    }\n}\n\nasync function loadVideoDetail(videoId) {\n    const player = document.getElementById('player');\n    const titleEl = document.getElementById('watch-title');\n    const likesEl = document.getElementById('like-count');\n    const viewsEl = document.getElementById('watch-views');\n    const dateEl = document.getElementById('watch-date');\n    const durationEl = document.getElementById('watch-duration');\n    const descriptionEl = document.getElementById('watch-description');\n    \n    try {\n        const response = await apiRequest(`api/videos.php?id=${videoId}`);\n        \n        // 動画の表示\n        player.src = `api/videos.php/${videoId}/video.mp4`;\n        \n        // タイトル\n        titleEl.textContent = response.title;\n        \n        // いいね\n        likesEl.textContent = `${response.likes_count || 0} いいね`;\n        \n        // 再生回数\n        viewsEl.textContent = `${formatViews(response.views)} 回視聴`;\n        \n        // 日付\n        dateEl.textContent = formatDate(response.created_at);\n        \n        // 動画の長さ\n        durationEl.textContent = formatDuration(response.duration || 0);\n        \n        // 説明\n        descriptionEl.textContent = response.description || '説明なし';\n        \n        // いいねボタンの状態\n        if (response.liked) {\n            likesEl.style.color = '#e74c3c';\n        }\n        \n        // いいねボタンクリックイベント\n        document.getElementById('like-btn').addEventListener('click', async () => {\n            try {\n                const likeResponse = await apiRequest(`api/videos.php/${videoId}/like`, 'POST');\n                likesEl.textContent = `${likeResponse.likes_count} いいね`;\n                likesEl.style.color = '#e74c3c';\n            } catch (error) {\n                console.error('いいねに失敗しました:', error);\n            }\n        });\n        \n        // コメントの読み込み\n        loadComments(videoId);\n        \n        // 関連動画の読み込み\n        loadRelatedVideos(videoId);\n        \n    } catch (error) {\n        // エラー処理\n    }\n}\n\nasync function loadComments(videoId) {\n    const commentList = document.getElementById('comment-list');\n    \n    if (!commentList) return;\n    \n    try {\n        const response = await apiRequest(`api/comments.php?video_id=${videoId}`);\n        \n        commentList.innerHTML = '';\n        \n        if (response.comments.length === 0) {\n            commentList.innerHTML = '<p>まだコメントがありません</p>';\n            return;\n        }\n        \n        response.comments.forEach(comment => {\n            const commentEl = document.createElement('div');\n            commentEl.className = 'comment-item';\n            commentEl.innerHTML = `\n                <div class=\"comment-header\">\n                    <div class=\"comment-user\">${escapeHtml(comment.username)}</div>\n                    <div class=\"comment-date\">${formatDate(comment.created_at)}</div>\n                </div>\n                <p class=\"comment-text\">\n                    <span class=\"comment-text\">${escapeHtml(comment.text)}</span>\n                </p>\n            `;\n            \n            // コメント削除ボタン（動画アップロード者のみ）\n            if (comment.owned) {\n                const deleteBtn = document.createElement('button');\n                deleteBtn.className = 'btn-delete-comment';\n                deleteBtn.innerText = '削除';\n                deleteBtn.addEventListener('click', async (e) => {\n                    e.stopPropagation();\n                    if (!confirm('このコメントを削除しますか？')) return;\n                    \n                    try {\n                        await apiRequest(`api/comments.php/${comment.id}`, 'DELETE');\n                        commentList.removeChild(commentEl);\n                        showStatus('コメントを削除しました', 'success');\n                    } catch (error) {\n                        showStatus(`削除に失敗しました: ${error.message}`, 'error');\n                    }\n                });\n                commentEl.appendChild(deleteBtn);\n            }\n            \n            commentList.appendChild(commentEl);\n        });\n    } catch (error) {\n        commentList.innerHTML = `<p>コメントの読み込みに失敗しました</p>`;\n    }\n}\n\nasync function addComment() {\n    const VIDEO_ID = window.location.search.split('id=')[1]?.split('&')[0];\n    const commentList = document.getElementById('comment-list');\n    const nameInput = document.getElementById('comment-name');\n    const textInput = document.getElementById('comment-text');\n    \n    const name = nameInput.value.trim();\n    const text = textInput.value.trim();\n    \n    if (!name) {\n        showStatus('名前を入力してください', 'error');\n        nameInput.focus();\n        return;\n    }\n    \n    if (!text) {\n        showStatus('コメントを入力してください', 'error');\n        textInput.focus();\n        return;\n    }\n    \n    try {\n        const response = await apiRequest('api/comments.php', 'POST', {\n            video_id: VIDEO_ID,\n            username: name,\n            text: text\n        });\n        \n        const commentEl = document.createElement('div');\n        commentEl.className = 'comment-item';\n        commentEl.innerHTML = `\n            <div class=\"comment-header\">\n                <div class=\"comment-user\">${escapeHtml(name)}</div>\n                <div class=\"comment-date\">${formatDate(response.created_at)}</div>\n            </div>\n            <p class=\"comment-text\">\n                <span class=\"comment-text\">${escapeHtml(text)}</span>\n            </p>\n        `;\n        \n        if (true) {\n            const deleteBtn = document.createElement('button');\n            deleteBtn.className = 'btn-delete-comment';\n            deleteBtn.innerText = '削除';\n            deleteBtn.addEventListener('click', async (e) => {\n                e.stopPropagation();\n                if (!confirm('このコメントを削除しますか？')) return;\n                await apiRequest(`api/comments.php/${response.id}`, 'DELETE');\n                commentList.removeChild(commentEl);\n            });\n            commentEl.appendChild(deleteBtn);\n        }\n        \n        commentList.insertBefore(commentEl, commentList.firstChild);\n        \n        nameInput.value = '';\n        textInput.value = '';\n        showStatus('コメントを投稿しました', 'success');\n    } catch (error) {\n        showStatus(`コメント投稿に失敗しました: ${error.message}`, 'error');\n    }\n}\n\nasync function loadRelatedVideos(videoId) {\n    const sidebar = document.getElementById('sidebar');\n    \n    if (!sidebar) return;\n    \n    try {\n        const response = await apiRequest(`api/videos.php?related=${videoId}`);\n        \n        sidebar.innerHTML = '';\n        \n        if (response.videos.length === 0) {\n            sidebar.innerHTML = '<p class=\"related-none\">関連動画はありません</p>';\n            return;\n        }\n        \n        const relatedList = document.createElement('div');\n        relatedList.className = 'video-list';\n        \n        response.related.forEach(video => {\n            const card = createVideoCard(video);\n            relatedList.appendChild(card);\n        });\n        \n        sidebar.appendChild(relatedList);\n        \n    } catch (error) {\n        sidebar.innerHTML = '<p>関連動画の読み込みに失敗しました</p>';\n    }\n}\n\n// ============================================\n// 共通：ステータス表示\n// ============================================\nfunction showStatus(message, type = 'info') {\n    // 既存のステータスがあれば削除\n    const existing = document.querySelector('.status');\n    if (existing) existing.remove();\n    \n    // スタンドアロンのstatus作成\n    const statusEl = document.createElement('div');\n    statusEl.className = `status status-${type}`;\n    statusEl.textContent = message;\n    statusEl.style.position = 'fixed';\n    statusEl.style.top = '20px';\n    statusEl.style.right = '20px';\n    statusEl.style.zIn"},"status":"approved","result":{"status":"success","path":"vibe_coding/mytube2/js/app.js","message":"ファイルを作成しました"},"approvalTime":77.482},"memory_usage":2097152,"script":"tool_history.php"}
