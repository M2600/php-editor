{"timestamp":"2026-04-19 14:37:59","level":"INFO","level_num":1,"pid":214530,"user_id":"dev","message":"File save started","context":{"path":"/vibe_coding/mytube2/api/videos.php","file_size_bytes":3689,"content":"<?php\nrequire_once __DIR__ . '/config.php';\n/** 動画一覧取得 API */\n\n\n\n// PHP用 time format helper\nfunction formatDuration(int|float|string $seconds): string {\n    $seconds = (int)$seconds;\n    if ($seconds < 0) $seconds = 0;\n    $h = intdiv($seconds, 3600);\n    $m = intdiv($seconds % 3600, 60);\n    $s = $seconds % 60;\n    if ($h > 0) {\n        return sprintf('%d:%02d:%02d', $h, $m, $s);\n    }\n    return sprintf('%d:%02d', $m, $s);\n}\n\n// クエリパラメータ取得\nif (isset($_GET['id'])) {\n    // 単一動画取得\n    $videos = readJsonFile(VIDEOS_JSON, ['videos' => []]);\n    $allVideos = $videos['videos'] ?? [];\n    $found = null;\n    foreach ($allVideos as $v) {\n        if ($v['id'] === $_GET['id']) {\n            $found = $v;\n            break;\n        }\n    }\n    if (!$found) {\n        jsonResponse(['error' => '動画が見つかりません'], 404);\n        exit;\n    }\n    $found['duration'] = formatDuration($found['duration'] ?? 0);\n    \n    // 動画ファイルのパ... (truncated)"},"memory_usage":2097152,"script":"file_manager.php"}
