nnel\">${formatViews(video.views)} 回再生</div>\n                <div class=\"related-date\">${formatDate(video.created_at)}</div>\n            </div>\n        </a>\n    `;\n    return div;\n}\n\n/** HTMLエスケープ */\nfunction escapeHtml(str) {\n    const div = document.createElement('div');\n    div.textContent = str;\n    return div.innerHTML;\n}"},"status":"approved","result":{"status":"success"},"approvalTime":5.78},"memory_usage":2097152,"script":"tool_history.php"}
