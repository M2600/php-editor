{"timestamp":"2026-04-19 10:16:27","level":"INFO","level_num":1,"pid":83015,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/config.php","content":"<?php\n/** API共通設定ファイル */\n\n// ストレージ設定\ndefine('BASE_PATH', __DIR__ . '/..');\ndefine('UPLOADS_DIR', BASE_PATH . '/uploads');\ndefine('DATA_DIR', BASE_PATH . '/data');\ndefine('VIDEOS_JSON', DATA_DIR . '/videos.json');\ndefine('CONFIG_JSON', DATA_DIR . '/config.json');\n\n// 容量制限 (デフォルト50MB)\ndefine('MAX_UPLOAD_SIZE', 50 * 1024 * 1024);\n\n// 許可拡張子\ndefine('ALLOWED_EXTENSIONS', ['mp4', 'webm', 'mkv', 'avi']);\n\n// ページング設定\ndefine('PAGE_SIZE', 20);\n\n/** メタ情報ファイル(動画)の読み込み/書き込み用 */\nfunction readJsonFile(string $filePath, mixed $default = []): mixed {\n    if (!file_exists($filePath)) {\n        return is_array($default) ? $default : json_decode($default, true);\n    }\n    $data = file_get_contents($filePath);\n    $decoded = json_decode($data, true);\n    return $decoded ?? $default;\n}\n\n/** メタ情報ファイル(動画)の読み込み/書き込み用 */\nfunction writeJsonFile(string $filePath, mixed $data): bool {\n    return file_put_contents($filePath, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE | JSON_THROW_ON_ERROR)) !== false;\n}\n\n/** レスポンスヘッダーの設定 */\nfunction jsonResponse(mixed $data, int $code = 200): void {\n    http_response_code($code);\n    header('Content-Type: application/json; charset=utf-8');\n    echo json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);\n    exit;\n}\n\n/** エラーレスポンス */\nfunction jsonResponseError(string $message, int $code = 400): void {\n    jsonResponse(['success' => false, 'message' => $message], $code);\n}"},"status":"approved","result":{"status":"success","path":"vibe_coding/mytube2/api/config.php","message":"ファイルを作成しました"},"approvalTime":2.395},"memory_usage":2097152,"script":"tool_history.php"}
