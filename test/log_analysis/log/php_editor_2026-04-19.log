{"timestamp":"2026-04-19 10:19:02","level":"INFO","level_num":1,"pid":83012,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/videos.php","content":"<?php\n/** 動画一覧取得 API */\nrequire_once __DIR__ . '/config.php';\n\n// GETリクエストのみ許可\nif ($_SERVER['REQUEST_METHOD'] !== 'GET') {\n    jsonResponseError('GETメソッドのみ許可されています', 405);\n}\n\n// クエリパラメータ取得\n$page = isset($_GET['page']) ? (int)$_GET['page'] : 1;\nif ($page < 1) $page = 1;\n\n$sort = isset($_GET['sort']) ? $_GET['sort'] : 'newest';\nif (!in_array($sort, ['newest', 'views', 'likes'])) {\n    $sort = 'newest';\n}\n\n$q = isset($_GET['q']) ? trim($_GET['q']) : '';\n\n// JSONファイル読み込み\n$videos = readJsonFile(VIDEOS_JSON, ['videos' => []]);\n$allVideos = $videos['videos'] ?? [];\n\n// 検索フィルタ\nif ($q !== '') {\n    $allVideos = array_filter($allVideos, function($video) use ($q) {\n        return stripos($video['title'] ?? '', $q) !== false\n            || stripos($video['description'] ?? '', $q) !== false;\n    });\n    $allVideos = array_values($allVideos);\n}\n\n// 並び替え\nswitch ($sort) {\n    case 'views':\n        usort($allVideos, function($a, $b) {\n            return ($b['views'] ?? 0) - ($a['views'] ?? 0);\n        });\n        break;\n    case 'likes':\n        usort($allVideos, function($a, $b) {\n            return ($b['likes'] ?? 0) - ($a['likes'] ?? 0);\n        });\n        break;\n    default:\n        usort($allVideos, function($a, $b) {\n            return strtotime($b['created_at'] ?? '') - strtotime($a['created_at'] ?? '');\n        });\n}\n\n// ページング処理\n$totalCount = count($allVideos);\n$totalPages = ceil($totalCount / PAGE_SIZE);\n$start = ($page - 1) * PAGE_SIZE;\n$paginatedVideos = array_slice($allVideos, $start, PAGE_SIZE);\n\n// 検索結果\n$result = [];\nforeach ($paginatedVideos as $video) {\n    $result[] = [\n        'id' => $video['id'],\n        'title' => $video['title'] ?? 'タイトルなし',\n        'thumbnail' => $video['thumbnail'] ?? '',\n        'duration' => formatDuration($video['duration'] ?? 0),\n        'views' => $video['views'] ?? 0,\n        'created_at' => $video['created_at'] ?? '',\n    ];\n}\n\njsonResponse([\n    'videos' => $result,\n    'total_count' => $totalCount,\n    'current_page' => $page,\n    'total_pages' => $totalPages,\n]);"},"status":"approved","result":{"status":"success","path":"vibe_coding/mytube2/api/videos.php","message":"ファイルを作成しました"},"approvalTime":0.902},"memory_usage":2097152,"script":"tool_history.php"}
