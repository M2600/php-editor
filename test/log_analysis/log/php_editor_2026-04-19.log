{"timestamp":"2026-04-19 14:10:14","level":"INFO","level_num":1,"pid":214526,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"/vibe_coding/mytube2/js/app.js","content":"/** アプリケーションロジック */\n\n// 定数\nconst API_BASE = 'api';\n\n// 状態管理\nconst state = {\n    videos: [],\n    currentVideo: null,\n    loading: false,\n    error: null\n};\n\n// API共通関数\nasync function apiRequest(url, method = 'GET', body = null) {\n    const options = {\n        method,\n        headers: {},\n    };\n    \n    if (body) {\n        if (body instanceof FormData) {\n            options.body = body;\n        } else {\n            options.headers['Content-Type'] = 'application/json';\n            options.body = JSON.stringify(body);\n        }\n    }\n    \n    const response = await fetch(url, options);\n    \n    if (!response.ok) {\n        response.text().then(text => { throw new Error(text); });\n    }\n    \n    return response.json();\n}\n\n// ユーザー入力から安全なHTMLを生成\nfunction escapeHtml(unsafe) {\n    return unsafe\n        .replace(/&/g, \"&amp;\")\n        .replace(/</g, \"&lt;\")\n        .replace(/>/g, \"&gt;\")\n        .replace(/\"/g, \"&quot;\")\n        .replace(/'/g, \"&#039;\");\n}\n\n// 動画カードを生成\nfunction createVideoCard(video) {\n    const card = document.createElement('div');\n    card.className = 'video-card';\n    \n    const thumbnail = document.createElement('img');\n    thumbnail.src = video.thumbnail || 'https://via.placeholder.com/320x180?text=No+Thumbnail';\n    thumbnail.alt = video.title;\n    thumbnail.loading = 'lazy';\n    \n    const content = document.createElement('div');\n    content.className = 'video-card-content';\n    \n    const title = document.createElement('h3');\n    title.textContent = video.title;\n    title.className = 'video-card-title';\n    \n    const channel = document.createElement('p');\n    channel.textContent = video.channel_name;\n    channel.className = 'video-card-channel';\n    \n    const views = document.createElement('p');\n    views.textContent = `${video.view_count.toLocaleString()} 回視聴`;\n    views.className = 'video-card-views';\n    \n    content.appendChild(title);\n    content.appendChild(channel);\n    content.appendChild(views);\n    \n    card.appendChild(thumbnail);\n    card.appendChild(content);\n    \n    card.addEventListener('click', () => {\n        window.location.href = `watch.html?id=${video.id}`;\n    });\n    \n    return card;\n}\n\n// ステータスメッセージを表示\nfunction showStatus(message, type = 'loading') {\n    const statusEl = document.getElementById('status-message');\n    if (!statusEl) return;\n    \n    statusEl.textContent = message;\n    statusEl.className = `status status-${type}`;\n    statusEl.style.display = 'block';\n    \n    // 3秒後に非表示\n    if (type !== 'success' && type !== 'error') {\n        setTimeout(() => {\n            statusEl.style.display = 'none';\n        }, 3000);\n    }\n}\n\n/** 一覧ページ用 */\nasync function loadVideos() {\n    const container = document.getElementById('video-list');\n    \n    if (!container) return;\n    \n    if (state.loading) return;\n    \n    state.loading = true;\n    state.error = null;\n    \n    container.innerHTML = '<p>動画を読み込み中...</p>';\n    \n    try {\n        const searchParams = window.location.search;\n        const response = await apiRequest(`api/videos.php${searchParams}`);\n        \n        container.innerHTML = '';\n        \n        if (response.videos.length === 0) {\n            container.innerHTML = '<p>動画が見つかりません</p>';\n            return;\n        }\n        \n        response.videos.forEach(video => {\n            const card = createVideoCard(video);\n            container.appendChild(card);\n        });\n        \n    } catch (error) {\n        console.error('動画の読み込みエラー:', error);\n        container.innerHTML = `<p>動画の読み込みに失敗しました: ${escapeHtml(error.message)}</p>`;\n    } finally {\n        state.loading = false;\n    }\n}\n\n/** アップロードページ用 */\nasync function handleUpload() {\n    console.log('handleUpload called');\n    const form = document.getElementById('upload-form');\n    const fileInfo = document.getElementById('file-info');\n    \n    if (!form) return;\n    \n    // ファイル入力の変更イベント\n    const fileInput = document.getElementById('video_file');\n    if (fileInput) {\n        fileInput.addEventListener('change', (e) => {\n            const file = e.target.files[0];\n            \n            if (file) {\n                fileInfo.textContent = `${file.name} (${(file.size / 1024 / 1024).toFixed(2)} MB)`;\n            } else {\n                fileInfo.textContent = '';\n            }\n        });\n    }\n    \n    // フォーム送信イベント\n    form.addEventListener('submit', async (e) => {\n        e.preventDefault();\n        \n        const file = fileInput.files[0];\n        \n        if (!file) {\n            showStatus('動画ファイルを選択してください', 'error');\n            return;\n        }\n        \n        // ファイルタイプの検査\n        const validTypes = ['video/mp4', 'video/webm', 'video/ogg'];\n        if (!validTypes.includes(file.type) && !file.name.match(/\\.(mp4|webm|ogg)$/i)) {\n            showStatus('有効な動画ファイル（MP4, WebM）を選択してください', 'error');\n            return;\n        }\n        \n        const formData = new FormData();\n        formData.append('video_file', file);\n        formData.append('title', form.title.value);\n        formData.append('description', form.description.value);\n        \n        showStatus('アップロード中...', 'loading');\n        \n        try {\n            const response = await apiRequest('api/upload.php', 'POST', formData);\n            \n            showStatus('アップロードしました！', 'success');\n            form.reset();\n            fileInfo.textContent = '';\n            \n            // 動画詳細ページにリダイレクト\n            setTimeout(() => {\n                window.location.href = `watch.html?id=${response.video_id}`;\n            }, 1500);\n            \n        } catch (error) {\n            console.error('アップロードエラー:', error);\n            showStatus(`アップロードに失敗しました: ${error.message}`, 'error');\n        }\n    });\n}\n\n/** 動画再生ページ用 */\nasync function loadVideo() {\n    const videoContainer = document.getElementById('video-container');\n    const videoPlayer = document.getElementById('video-player');\n    const videoTitle = document.getElementById('video-title');\n    const videoDescription = document.getElementById('video-description');\n    const videoInfo = document.getElementById('video-info');\n    const videoFileInput = document.getElementById('video_file');\n    const relatedList = document.getElementById('related-videos');\n    \n    if (!videoContainer) return;\n    \n    // URLパラメーターから動画IDを取得\n    const searchParams = new URLSearchParams(window.location.search);\n    const videoId = searchParams.get('id');\n    \n    if (!videoId) {\n        videoContainer.innerHTML = '<p>動画IDが指定されていません</p>';\n        return;\n    }\n    \n    videoContainer.innerHTML = '<p>動画を読み込み中...</p>';\n    \n    try {\n        const response = await apiRequest(`api/videos.php?id=${videoId}`);\n        \n        if (!response.video) {\n            videoContainer.innerHTML = '<p>動画が見つかりません</p>';\n            return;\n        }\n        \n        const video = response.video;\n        \n        // ビデオ情報を設定\n        if (videoPlayer) {\n            videoPlayer.src = video.video_url;\n            videoPlayer.poster = video.thumbnail;\n            videoPlayer.controls = true;\n        }\n        \n        if (videoTitle) videoTitle.textContent = video.title;\n        \n        if (videoDescription) {\n            videoDescription.textContent = video.description;\n        }\n        \n        if (videoInfo) {\n            const views = document.createElement('div');\n            views.innerHTML = `<span>${video.view_count.toLocaleString()} 回視聴</span>\n                             <span>${video.uploaded_at}</span>`;\n            videoInfo.appendChild(views);\n        }\n        \n        // サムネイル画像の保存\n        if (response.thumbnail_path) {\n            videoFileInput.value = response.thumbnail_path;\n        }\n        \n        // 関連動画の読み込み\n        loadRelatedVideos(videoId);\n        \n    } catch (error) {\n        console.error('動画の読み込みエラー:', error);\n        videoContainer.innerHTML = `<p>動画の読み込みに失敗しました: ${escapeHtml(error.message)}</p>`;\n    }\n}\n\n/** 関連動画の読み込み */\nasync function loadRelatedVideos(videoId) {\n    const relatedList = document.getElementById('related-videos');\n    \n    if (!relatedList) return;\n    \n    try {\n        const response = await apiRequest(`api/related.php?video_id=${videoId}`);\n        \n        if (!response.related || response.related.length === 0) {\n            relatedList.innerHTML = '<p>関連動画はありません</p>';\n            return;\n        }\n        \n        relatedList.innerHTML = '';\n        \n        response.related.forEach(video => {\n            const card = createVideoCard(video);\n            relatedList.appendChild(card);\n        });\n        \n    } catch (error) {\n        console.error('関連動画の読み込みエラー:', error);\n        relatedList.innerHTML = '<p>関連動画の読み込みに失敗しました</p>';\n    }\n}\n\n// ページ初期化\ndocument.addEventListener('DOMContentLoaded', () => {\n    const pagePath = window.location.pathname.split('/').pop();\n    \n    if (pagePath === 'index.html' || pagePath === '' || pagePath === '/') {\n        loadVideos();\n    } else if (pagePath === 'upload.html') {\n        handleUpload();\n    } else if (pagePath === 'watch.html') {\n        loadVideo();\n    }\n});"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":271.933},"memory_usage":2097152,"script":"tool_history.php"}
