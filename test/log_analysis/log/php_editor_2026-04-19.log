{"timestamp":"2026-04-19 12:38:27","level":"INFO","level_num":1,"pid":83011,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"js/main.js","content":"/** 動画の長さのフォーマット */\nfunction formatDuration(sec) {\n    const h = Math.floor(sec / 3600);\n    const m = Math.floor((sec % 3600) / 60);\n    const s = Math.floor(sec % 60);\n    if (h > 0) {\n        return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;\n    }\n    return `${m}:${String(s).padStart(2, '0')}`;\n}\n\n/** 再生回数のフォーマット */\nfunction formatViews(num) {\n    if (num >= 1000000) {\n        return `${(num / 1000000).toFixed(1)}M`;\n    }\n    if (num >= 1000) {\n        return `${(num / 1000).toFixed(1)}K`;\n    }\n    return `${num}回視聴`;\n}\n\n/** 日時のフォーマット */\nfunction formatDate(dateStr) {\n    const date = new Date(dateStr);\n    const now = new Date();\n    const diff = now - date;\n    const days = Math.floor(diff / (1000 * 60 * 60 * 24));\n    if (days < 1) {\n        const hours = Math.floor(diff / (1000 * 60 * 60));\n        if (hours > 0) return `${hours}時間前`;\n        const mins = Math.floor(diff / (1000 * 60));\n        return `${mins}分前`;\n    }\n    if (days < 30) return `${days}日前`;\n    if (days < 365) return `${Math.floor(days / 30)}ヶ月前`;\n    return `${Math.floor(days / 365)}年前`;\n}\n\n/** 動画カードの作成 */\nfunction createVideoCard(video, isSmall = false) {\n    const div = document.createElement('div');\n    div.className = isSmall ? 'related-video' : 'video-card';\n    \n    const thumbUrl = video.thumbnail\n        ? `<img src=\"${video.thumbnail}\" style=\"width: 100%; height: 100%; object-fit: cover;\" />`\n        : `<div style=\"width: 100%; height: 100%; background: #ccc; display: flex; align-items: center; justify-content: center; color: #666; font-size: 24px;\">▶</div>`;\n    \n    div.innerHTML = `\n        <a href=\"watch.html?id=${video.id}\">\n            <div class=\"video-thumbnail\">\n                ${thumbUrl}\n                ${video.duration ? `<span class=\"duration\">${formatDuration(video.duration)}</span>` : ''}\n            </div>\n            <div class=\"video-info\">\n                <div class=\"video-title\">${escapeHtml(video.title)}</div>\n                <div class=\"video-meta\">\n                    <span>${formatViews(video.views)}回視聴</span>\n                    <span>•</span>\n                    <span>${formatDate(video.created_at)}</span>\n                </div>\n            </div>\n        </a>\n    `;\n    return div;\n}\n\n/** 関連動画カードの作成 */\nfunction createRelatedVideoCard(video) {\n    const div = document.createElement('div');\n    div.className = 'related-video';\n    \n    const thumbUrl = video.thumbnail\n        ? `<img src=\"${video.thumbnail}\" style=\"width: 100%; height: 100%; object-fit: cover;\" />`\n        : `<div style=\"width: 100%; height: 100%; background: #ccc; display: flex; align-items: center; justify-content: center; color: #666; font-size: 18px;\">▶</div>`;\n    \n    div.innerHTML = `\n        <a href=\"watch.html?id=${video.id}\">\n            <div class=\"related-thumb\">\n                ${thumbUrl}\n                ${video.duration ? `<span class=\"duration\">${formatDuration(video.duration)}</span>` : ''}\n            </div>\n            <div class=\"related-info\">\n                <div class=\"related-title\">${escapeHtml(video.title)}</div>\n                <div class=\"related-channel\">${formatViews(video.views)} 回視聴</div>\n                <div class=\"related-date\">${formatDate(video.created_at)}</div>\n            </div>\n        </a>\n    `;\n    return div;\n}\n\n/** HTMLエスケープ */\nfunction escapeHtml(str) {\n    const div = document.createElement('div');\n    div.textContent = str;\n    return div.innerHTML;\n}\n"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":4.095},"memory_usage":2097152,"script":"tool_history.php"}
