{"timestamp":"2026-04-19 14:01:49","level":"INFO","level_num":1,"pid":214527,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"/vibe_coding/mytube2/js/app_fixed.js","content":"/** アプリケーションロジック */\n\nconsole.log('app.js loaded');\n\n// ページタイプを判定\nconst PAGE_NAME = window.location.pathname.split('/').pop().split('?')[0] || '';\nconsole.log('PAGE_NAME:', PAGE_NAME);\n\n// API共通関数\nasync function apiRequest(url, method = 'GET', body = null) {\n    const options = {\n        method,\n        headers: {},\n    };\n    \n    if (body) {\n        if (body instanceof FormData) {\n            options.body = body;\n        } else {\n            options.headers['Content-Type'] = 'application/json';\n            options.body = JSON.stringify(body);\n        }\n    }\n    \n    const response = await fetch(url, options);\n    console.log('API request to', url, 'status:', response.status);\n    \n    if (!response.ok) {\n        response.text().then(text => { throw new Error(text); });\n    }\n    \n    return await response.json();\n}\n\n/** ホーム画面の動画一覧表示 */\nasync function loadVideos() {\n    const list = document.getElementById('video-list');\n    const statusEl = document.getElementById('status');\n    const searchInput = document.getElementById('search-input');\n    const sortSelect = document.getElementById('sort-select');\n    const currentPageEl = document.getElementById('current-page');\n    \n    if (!list) return;\n    \n    let currentPage = 1;\n    let currentSort = 'newest';\n    let currentQuery = '';\n    let totalPages = 1;\n    \n    async function fetchData(page = 1) {\n        let url = 'api/videos.php?page=' + page + '&sort=' + currentSort;\n        if (currentQuery !== '') {\n            url += '&q=' + encodeURIComponent(currentQuery);\n        }\n        \n        try {\n            const response = await apiRequest(url);\n            const videos = response.videos;\n            totalPages = response.total_pages;\n            currentPage = response.current_page;\n            \n            if (currentPageEl) {\n                currentPageEl.textContent = 'ページ ' + currentPage + ' / ' + totalPages;\n            }\n            \n            list.innerHTML = '';\n            videos.forEach(video => {\n                const card = createVideoCard(video);\n                list.appendChild(card);\n            });\n        } catch (error) {\n            showStatus('動画の読み込みに失敗しました', 'error');\n            console.error(error);\n        }\n    }\n    \n    fetchData();\n    if (currentPageEl) currentPageEl.textContent = 'ページ 1 / ' + totalPages;\n    \n    // 検索イベント\n    if (searchInput) {\n        let searchTimeout;\n        searchInput.addEventListener('input', (e) => {\n            clearTimeout(searchTimeout);\n            currentQuery = e.target.value;\n            searchTimeout = setTimeout(() => {\n                fetchData(1);\n            }, 500);\n        });\n    }\n    \n    if (sortSelect) {\n        sortSelect.addEventListener('change', (e) => {\n            currentSort = e.target.value;\n            fetchData(1);\n        });\n    }\n}\n\n/** 動画カードの作成 */\nfunction createVideoCard(video) {\n    const card = document.createElement('div');\n    card.className = 'video-card';\n    card.innerHTML = `\n        <a href=\"watch.html?id=${video.id}\" class=\"video-thumbnail\">\n            <img src=\"${video.thumbnail}\" alt=\"${video.title}\">\n            <span class=\"duration\">${video.duration}</span>\n        </a>\n        <div class=\"video-info\">\n            <h3 class=\"video-title\">${video.title}</h3>\n            <p class=\"video-views\">${formatViews(video.views || 0)}</p>\n            <p class=\"video-time\">${formatDate(video.created_at)}</p>\n        </div>\n    `;\n    return card;\n}\n\n/** 動画アップロード処理 */\nasync function handleUpload() {\n    const fileInput = document.getElementById('video-file');\n    const titleInput = document.getElementById('title-input');\n    const descriptionInput = document.getElementById('description-input');\n    const statusEl = document.getElementById('status');\n    \n    if (!fileInput || !titleInput || !descriptionInput) return;\n    \n    async function uploadFile(file) {\n        const formData = new FormData();\n        formData.append('video_file', file);\n        formData.append('title', titleInput.value);\n        formData.append('description', descriptionInput.value);\n        \n        const response = await apiRequest('/api/upload.php', 'POST', formData);\n        showStatus(`アップロード完了！`, 'success');\n        location.href = 'watch.html?id=' + response.video_id;\n    }\n    \n    fileInput.addEventListener('change', async (e) => {\n        const file = e.target.files[0];\n        if (!file) return;\n        \n        showStatus('アップロード中...', 'info');\n        \n        // 画像ファイルの場合\n        if (file.type.startsWith('image/')) {\n            const formData = new FormData();\n            formData.append('video_file', file);\n            formData.append('title', titleInput.value);\n            formData.append('description', descriptionInput.value);\n            \n            const response = await apiRequest('/api/upload.php', 'POST', formData);\n            showStatus(`アップロード完了！`, 'success');\n            location.href = 'watch.html?id=' + response.video_id;\n            return;\n        }\n        \n        // 動画ファイルの場合\n        try {\n            const thumbnailData = await videoToThumbnail(file);\n            formData.append('thumbnail', thumbnailData.thumbnailBlob, 'thumbnail.png');\n            await uploadFile(file);\n        } catch (error) {\n            showStatus('動画の読み込みに失敗しました', 'error');\n            console.error(error);\n        }\n    });\n}\n\n/** 動画をキャプチャ → サムネイルに変換 */\nfunction videoToThumbnail(videoFile) {\n    return new Promise((resolve, reject) => {\n        const video = document.createElement('video');\n        video.preload = 'metadata';\n        video.muted = true;\n        video.src = URL.createObjectURL(videoFile);\n        \n        video.onloadedmetadata = () => {\n            video.currentTime = 1;\n        };\n        \n        video.onseeked = () => {\n            const canvas = document.createElement('canvas');\n            canvas.width = video.videoWidth;\n            canvas.height = video.videoHeight;\n            \n            const ctx = canvas.getContext('2d');\n            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);\n            \n            canvas.toBlob((blob) => {\n                resolve({\n                    thumbnailBlob: blob,\n                    duration: video.duration\n                });\n                URL.revokeObjectURL(video.src);\n            }, 'image/png');\n        };\n        \n        video.onerror = () => reject(new Error('動画の読取に失敗しました'));\n    });\n}\n\n/** watch.htmlでの動画読み込み */\nasync function loadVideo() {\n    const player = document.getElementById('player');\n    const titleEl = document.getElementById('watch-title');\n    const viewsEl = document.getElementById('watch-views');\n    const dateEl = document.getElementById('watch-date');\n    const durationEl = document.getElementById('watch-duration');\n    const descEl = document.getElementById('watch-description');\n    const likeBtn = document.getElementById('like-btn');\n    const likeCountEl = document.getElementById('like-count');\n    const container = document.getElementById('video-container');\n    \n    // URLパラメータからvideo_idを取得\n    const urlParams = new URLSearchParams(window.location.search);\n    const videoId = urlParams.get('id');\n    console.log('Loading video with ID:', videoId);\n    \n    if (!videoId) {\n        showStatus('動画が見つかりません', 'error');\n        return;\n    }\n    \n    try {\n        const response = await apiRequest('/api/videos.php?page=1&sort=newest');\n        const videos = response.videos;\n        const video = videos.find(v => v.id === parseInt(videoId));\n        \n        if (!video) {\n            if (container) container.style.display = 'none';\n            showStatus('動画が見つかりません', 'error');\n            return;\n        }\n        \n        if (container) container.style.display = 'block';\n        \n        // 動画情報\n        if (titleEl) titleEl.textContent = video.title;\n        if (viewsEl) viewsEl.textContent = formatViews(video.views || 0);\n        if (dateEl) dateEl.textContent = formatDate(video.created_at);\n        if (durationEl) durationEl.textContent = video.duration;\n        if (descEl) descEl.textContent = video.description || '説明はありません';\n        \n        // 動画プレイヤーに設定\n        if (player && video.file_path) {\n            player.src = `uploads/${video.file_path}`;\n            player.load();\n            console.log('Video src set to:', player.src);\n        }\n        \n        // いいね表示\n        if (likeCountEl) likeCountEl.textContent = (video.likes || 0).toString();\n        \n        // いいねイベント\n        if (likeBtn) {\n            likeBtn.addEventListener('click', async () => {\n                if (likeBtn.classList.contains('liked')) return;\n                \n                likeBtn.classList.add('liked');\n                const currentLikes = parseInt(likeCountEl.textContent) || 0;\n                likeCountEl.textContent = (currentLikes + 1).toString();\n                \n                try {\n                    await apiRequest('/api/like.php', 'POST', {\n                        video_id: videoId\n                    });\n                } catch (error) {\n                    showStatus('いいねに失敗しました', 'error');\n                }\n            });\n        }\n        \n        // コメント読み込み\n        loadComments(videoId);\n        \n        // サイドロード（関連動画）\n        loadRelatedVideos();\n        \n    } catch (error) {\n        showStatus('動画の読み込みに失敗しました', 'error');\n        console.error(error);\n        if (container) container.style.display = 'none';\n    }\n}\n\n/** Related (関連動画) */\nasync function loadRelatedVideos() {\n    const relatedList = document.getElementById('sidebar');\n    if (!relatedList) return;\n    \n    try {\n        relatedList.innerHTML = '';\n        const urlParams = new URLSearchParams(window.location.search);\n        const currentVideoId = urlParams.get('id');\n        \n        const response = await apiRequest('/api/videos.php?page=1');\n        const videos = response.videos;\n        const relatedVideos = videos.filter(v => v.id !== parseInt(currentVideoId)).slice(0, 10);\n        \n        relatedVideos.forEach(video => {\n            const relatedCard = document.createElement('div');\n            relatedCard.className = 'related-video';\n            relatedCard.innerHTML = `\n                <a href=\"watch.html?id=${video.id}\" class=\"video-thumbnail\">\n                    <img src=\"${video.thumbnail}\" alt=\"${video.title}\">\n                    <span class=\"duration\">${video.duration}</span>\n                </a>\n                <div class=\"video-info\">\n                    <h3 class=\"video-title\">${video.title}</h3>\n                    <p class=\"video-views\">${formatViews(video.views || 0)}</p>\n                </div>\n            `;\n            relatedList.appendChild(relatedCard);\n        });\n    } catch (error) {\n        console.error('関連動画の読み込みに失敗しました:', error);\n    }\n}\n\n/** コメント読み込み */\nasync function loadComments(videoId) {\n    const commentList = document.getElementById('comment-list');\n    if (!commentList) return;\n    \n    try {\n        commentList.innerHTML = '';\n        const url = `/api/comments.php?video_id=${videoId}`;\n        const response = await apiRequest(url);\n        \n        if (response.comments && response.comments.length > 0) {\n            response.comments.forEach(comment => {\n                const commentEl = document.createElement('div');\n                commentEl.className = 'comment-item';\n                commentEl.innerHTML = `\n                    <div class=\"comment-author\">\n                        <strong>${comment.user_name}</strong>\n                        <span class=\"comment-date\">${formatDate(comment.created_at)}</span>\n                    </div>\n                    <p class=\"comment-text\">${comment.text}</p>\n                `;\n                commentList.appendChild(commentEl);\n            });\n        }\n    } catch (error) {\n        console.error('コメントの読み込みに失敗しました:', error);\n    }\n}\n\n/** コメント投稿 */\nasync function addComment() {\n    const nameInput = document.getElementById('comment-name');\n    const textInput = document.getElementById('comment-text');\n    const videoId = new URLSearchParams(window.location.search).get('id');\n    \n    if (!nameInput || !textInput) return;\n    \n    const name = nameInput.value.trim();\n    const text = textInput.value.trim();\n    \n    if (!name || !text) {\n        showStatus('名前とコメントを入力してください', 'error');\n        return;\n    }\n    \n    try {\n        await apiRequest('/api/comments.php', 'POST', {\n            video_id: videoId,\n            user_name: name,\n            text: text\n        });\n        \n        showStatus('コメントを投稿しました', 'success');\n        textInput.value = '';\n        \n        // コメントを再読み込み\n        loadComments(videoId);\n    } catch (error) {\n        showStatus('コメントの投稿に失敗しました', 'error');\n        console.error(error);\n    }\n}\n\n/** ステータスメッセージ表示 */\nfunction showStatus(message, type = 'info') {\n    let statusEl = document.getElementById('status');\n    if (!statusEl) {\n        statusEl = document.createElement('div');\n        statusEl.id = 'status';\n        document.body.style.position = 'relative';\n        document.body.insertBefore(statusEl, document.body.firstChild);\n        statusEl.style.position = 'fixed';\n        statusEl.style.top = '20px';\n        statusEl.style.left = '50%';\n        statusEl.style.transform = 'translateX(-50%)';\n        statusEl.style.zIndex = '9999';\n        statusEl.style.padding = '10px 20px';\n        statusEl.style.borderRadius = '5px';\n        statusEl.style.fontSize = '14px';\n        statusEl.style.fontWeight = 'bold';\n        statusEl.style.boxShadow = '0 2px 5px rgba(0,0,0,0.2)';\n    }\n    \n    const colors = {\n        info: '#3498db',\n        success: '#2ecc71',\n        error: '#e74c3c',\n        warning: '#f39c12'\n    };\n    \n    statusEl.textContent = message;\n    statusEl.className = 'status-message';\n    statusEl.style.backgroundColor = colors[type] || colors.info;\n    statusEl.style.display = 'block';\n    \n    // 3秒後に非表示\n    setTimeout(() => {\n        if (statusEl) statusEl.style.display = 'none';\n    }, 3000);\n}\n\n/** 日付を日本時間でフォーマット */\nfunction formatDate(dateStr) {\n    if (dateStr === '現在' || !dateStr) return '現在';\n    try {\n        const date = new Date(dateStr);\n        const year = date.getFullYear();\n        const month = String(date.getMonth() + 1).padStart(2, '0');\n        const day = String(date.getDate()).padStart(2, '0');\n        const hours = String(date.getHours()).padStart(2, '0');\n        const minutes = String(date.getMinutes()).padStart(2, '0');\n        return `${year}/${month}/${day} ${hours}:${minutes}`;\n    } catch (e) {\n        return dateStr;\n    }\n}\n\n/** 再生回数をフォーマット */\nfunction formatViews(views) {\n    if (views >= 1000000) {\n        return (views / 1000000).toFixed(1) + 'M 回再生';\n    }\n    if (views >= 1000) {\n        return (views / 1000).toFixed(1) + 'K 回再生';\n    }\n    return views + ' 回再生';\n}\n\n// DOMContentLoadedで初期化\ndocument.addEventListener('DOMContentLoaded', () => {\n    console.log('DOM Content Loaded');\n    console.log('Loading function for PAGE_NAME:', PAGE_NAME);\n    \n    switch (PAGE_NAME) {\n        case 'index.html':\n        case 'index.php':\n        case '':\n            loadVideos();\n            if (document.getElementById('video-file')) handleUpload();\n            break;\n        case 'watch.html':\n            loadVideo();\n            break;\n        default:\n            console.log('Unknown page:', PAGE_NAME);\n            break;\n    }\n});"},"status":"approved","result":{"status":"success","path":"vibe_coding/mytube2/js/app_fixed.js","message":"ファイルを作成しました"},"approvalTime":1.938},"memory_usage":2097152,"script":"tool_history.php"}
