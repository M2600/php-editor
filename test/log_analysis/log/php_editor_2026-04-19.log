{"timestamp":"2026-04-19 11:24:06","level":"INFO","level_num":1,"pid":83015,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/likes.php","content":"<?php\nrequire_once __DIR__ . '/config.php';\n\nheader('Content-Type: application/json');\n\n$input = json_decode(file_get_contents('php://input'), true);\n$jsonFile = DATA_PATH . '/likes.json';\n\n// 初期化\nif (!file_exists($jsonFile)) {\n    file_put_contents($jsonFile, json_encode(['likes' => []], JSON_PRETTY_PRINT));\n}\n\n$data = json_decode(file_get_contents($jsonFile), true);\n$action = $_GET['action'] ?? '';\n$videoId = $input['video_id'] ?? $_GET['video_id'] ?? null;\n$method = $_SERVER['REQUEST_METHOD'];\n\nif ($videoId !== null && $action === 'toggle') {\n    $userId = md5($_SERVER['REMOTE_ADDR'] . $_SERVER['HTTP_USER_AGENT']);\n    $liked = false;\n    \n    if ($method === 'POST') {\n        // いいね済かどうか確認\n        $found = false;\n        foreach ($data['likes'] as $i => $like) {\n            if ($like['video_id'] === $videoId && $like['user_id'] === $userId) {\n                unset($data['likes'][$i]);\n                $found = true;\n                break;\n            }\n        }\n        if (!$found) {\n            $data['likes'][] = [\n                'video_id' => $videoId,\n                'user_id' => $userId,\n                'created_at' => date('Y-m-d H:i:s')\n            ];\n            $liked = true;\n        }\n        data_save('likes', $data['likes']);\n    }\n    \n    $count = count(array_filter($data['likes'], fn($l) => $l['video_id'] === $videoId));\n    echo json_encode(['liked' => $liked, 'count' => $count, 'video_id' => $videoId]);\n} else {\n    // いいね数の取得\n    $count = count(array_filter($data['likes'], fn($l) => $l['video_id'] === $videoId));\n    echo json_encode(['count' => $count, 'video_id' => $videoId]);\n}\n?>"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":3.259},"memory_usage":2097152,"script":"tool_history.php"}
