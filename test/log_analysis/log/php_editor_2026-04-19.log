{"timestamp":"2026-04-19 10:19:01","level":"INFO","level_num":1,"pid":83013,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/upload.php","content":"<?php\n/** 動画アップロード API */\nrequire_once __DIR__ . '/config.php';\n\n// POSTリクエストのみ許可\nif ($_SERVER['REQUEST_METHOD'] !== 'POST') {\n    jsonResponseError('POSTメソッドのみ許可されています', 405);\n}\n\n// ファイルエラーチェック\nif (!isset($_FILES['video_file']) || $_FILES['video_file']['error'] !== UPLOAD_ERR_OK) {\n    jsonResponseError('ファイルのアップロードに失敗しました。', 400);\n}\n\n$file = $_FILES['video_file'];\n\n// 拡張子チェック\n$ext = strtolower(pathinfo($file['name'], PATHINFO_EXTENSION));\nif (!in_array($ext, ALLOWED_EXTENSIONS)) {\n    jsonResponseError('許可されていないファイル形式です', 400);\n}\n\n// 容量チェック\nif ($file['size'] > MAX_UPLOAD_SIZE) {\n    jsonResponseError('ファイルサイズが制限を超えています', 400);\n}\n\n// メタ情報収集\n$title = isset($_POST['title']) ? trim($_POST['title']) : '';\n$description = isset($_POST['description']) ? trim($_POST['description']) : '';\n\n// 動画の長さの取得（ffmpegがある場合のみ）\n$duration = getVideoDuration($file['tmp_name']);\n\n// ファイル保存\n$filename = date('Ymd_His') . '_' . uniqid() . '.' . $ext;\n$destination = UPLOADS_DIR . '/' . $filename;\nif (!move_uploaded_file($file['tmp_name'], $destination)) {\n    jsonResponseError('ファイルの保存に失敗しました。', 500);\n}\n\n// JSONファイルに追記\n$videos = readJsonFile(VIDEOS_JSON, []);\n$videoId = generateVideoId();\n\n$videos['videos'][] = [\n    'id' => $videoId,\n    'title' => $title,\n    'description' => $description,\n    'filename' => $filename,\n    'thumbnail' => null,\n    'duration' => $duration,\n    'file_size' => $file['size'],\n    'views' => 0,\n    'likes' => 0,\n    'created_at' => date('Y-m-d H:i:s'),\n    'uploaded_by' => null,\n    'tags' => []\n];\n\nwriteJsonFile(VIDEOS_JSON, $videos);\n\n/** 動画の長さを取得 */\nfunction getVideoDuration($filePath) {\n    if (!function_exists('shell_exec')) return '';\n    $command = \"ffmpeg -i \" . escapeshellarg($filePath) . \" 2>&1 | grep Duration | awk '{print \\$2}' | tr -d ','\";\n    $output = shell_exec($command);\n    if ($output) {\n        $parts = explode(':', trim($output));\n        return (int)$parts[0] * 3600 + (int)$parts[1] * 60 + (int)$parts[2];\n    }\n    return '';\n}\n\n/** ランダムな動画ID生成 */\nfunction generateVideoId() {\n    $chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';\n    $id = '';\n    for ($i = 0; $i < 12; $i++) {\n        $id .= $chars[rand(0, strlen($chars) - 1)];\n    }\n    return $id;\n}\n\njsonResponse([\n    'success' => true,\n    'video_id' => $videoId,\n    'message' => '動画がアップロードされました'\n]);"},"status":"approved","result":{"status":"success","path":"vibe_coding/mytube2/api/upload.php","message":"ファイルを作成しました"},"approvalTime":2.276},"memory_usage":2097152,"script":"tool_history.php"}
