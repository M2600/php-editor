{"timestamp":"2026-04-19 10:48:01","level":"INFO","level_num":1,"pid":83012,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/likes.php","content":"<?php\nrequire_once __DIR__ . '/config.php';\n\nheader('Content-Type: application/json');\n\nfunction getIpAddress() {\n    if (!empty($_SERVER['HTTP_X_FORWARDED_FOR'])) {\n        return explode(',', $_SERVER['HTTP_X_FORWARDED_FOR'])[0];\n    }\n    return $_SERVER['REMOTE_ADDR'];\n}\n\nfunction getUserId() {\n    return getIpAddress();\n}\n\n$method = $_SERVER['REQUEST_METHOD'];\n$action = $_GET['action'] ?? '';\n\nswitch ($method) {\n    case 'GET':\n        // いいね数の取得\n        $videoId = $_GET['video_id'] ?? '';\n        if (!$videoId) {\n            echo json_encode(['error' => 'video_idが必要です']);\n            exit;\n        }\n        \n        $likesFile = DATA_PATH . '/likes.json';\n        $likesData = json_decode(file_get_contents($likesFile), true) ?: ['likes' => []];\n        \n        $likeCount = count(array_filter($likesData['likes'], function($like) use ($videoId) {\n            return $like['video_id'] === $videoId;\n        }));\n        \n        echo json_encode([\n            'video_id' => $videoId,\n            'like_count' => $likeCount,\n            'liked' => false // クライアント側で確認する\n        ]);\n        break;\n        \n    case 'POST':\n        // いいねの追加/キャンセル\n        $input = json_decode(file_get_contents('php://input'), true);\n        $videoId = $input['video_id'] ?? '';\n        \n        if (!$videoId) {\n            echo json_encode(['error' => 'video_idが必要です']);\n            exit;\n        }\n        \n        $userId = getUserId();\n        $likesFile = DATA_PATH . '/likes.json';\n        $likesData = json_decode(file_get_contents($likesFile), true) ?: ['likes' => []];\n        \n        // いいね済みチェック\n        $existingIndex = null;\n        foreach ($likesData['likes'] as $index => $like) {\n            if ($like['video_id'] === $videoId && $like['user_id'] === $userId) {\n                $existingIndex = $index;\n                break;\n            }\n        }\n        \n        if ($existingIndex !== null) {\n            // いいねキャンセル\n            unset($likesData['likes'][$existingIndex]);\n            $likesData['likes'] = array_values($likesData['likes']); // インデックスを再設定\n            $liked = false;\n        } else {\n            // いいね追加\n            $likesData['likes'][] = [\n                'video_id' => $videoId,\n                'user_id' => $userId,\n                'created_at' => date('Y-m-d H:i:s')\n            ];\n            $liked = true;\n        }\n        \n        file_put_contents($likesFile, json_encode($likesData, JSON_PRETTY_PRINT));\n        \n        $likeCount = count($likesData['likes']);\n        \n        echo json_encode([\n            'video_id' => $videoId,\n            'like_count' => $likeCount,\n            'liked' => $liked\n        ]);\n        break;\n        \n    default:\n        echo json_encode(['error' => '不正なリクエスト']);\n        break;\n}\n?>"},"status":"approved","result":{"status":"success","path":"vibe_coding/mytube2/api/likes.php","message":"ファイルを作成しました"},"approvalTime":82.395},"memory_usage":2097152,"script":"tool_history.php"}
