{"timestamp":"2026-04-19 10:23:40","level":"INFO","level_num":1,"pid":83009,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"js/app.js","content":"/** アプリケーションロジック */\n\n// ページタイプを判定\nconst PAGE_TYPE = window.location.pathname.split('/').pop() || 'index.html';\n\n/** 動画一覧ページ用 */\nasync function loadVideos() {\n    const container = document.getElementById('video-list');\n    if (!container) return;\n    \n    try {\n        const searchParams = window.location.search;\n        const response = await apiRequest(`/api/videos.php${searchParams}`);\n        \n        container.innerHTML = '';\n        \n        if (response.videos.length === 0) {\n            container.innerHTML = '<p>動画が見つかりません</p>';\n            return;\n        }\n        \n        response.videos.forEach(video => {\n            const card = createVideoCard(video);\n            container.appendChild(card);\n        });\n    } catch (error) {\n        container.innerHTML = `<p>動画の読み込みに失敗しました: ${escapeHtml(error.message)}</p>`;\n    }\n}\n\n/** アップロードページ用 */\nasync function handleUpload() {\n    const form = document.getElementById('upload-form');\n    const fileInfo = document.getElementById('file-info');\n    \n    if (!form) return;\n    \n    form.addEventListener('submit', async (e) => {\n        // 動画ファイルサイズ制限（50MB）\n        const MAX_SIZE = 50 * 1024 * 1024;\n        if (form.video_file.files[0]?.size > MAX_SIZE) {\n            showStatus('ファイルサイズが大きすぎます', 'error');\n            return;\n        }\n        \n        // 動画ファイルの有効なフォーマット\n        const video_types = form.video_file.validity.validTypes || ['MP4', 'WebM', 'MOV', 'FLV'];\n        const file = form.video_file.files[0];\n        if (!file?.type.startsWith('video/') || !video_types.includes(file.type)) {\n            showStatus('有効な動画ファイル（MP4, WebM）を選択してください', 'error');\n            return;\n        }\n        \n        const formData = new FormData();\n        formData.append('video_file', file);\n        formData.append('title', form.title.value);\n        formData.append('description', form.description.value);\n        \n        showStatus('アップロード中...', 'loading');\n        \n        try {\n            const response = await apiRequest('/api/upload.php', {\n                method: 'POST',\n                body: formData,\n            });\n            \n            showStatus('アップロードしました！', 'success');\n            form.reset();\n            fileInfo.textContent = '';\n            \n            // 動画詳細ページにリダイレクト\n            setTimeout(() => {\n                window.location.href = `watch.html?id=${response.video_id}`;\n            }, 1000);\n        } catch (error) {\n            showStatus(`アップロードに失敗しました: ${escapeHtml(error.message)}`, 'error');\n        }\n    });\n}\n\n/** 動画閲覧ページ用 */\nasync function loadVideo() {\n    const videoPlayer = document.getElementById('video-player');\n    const videoInfoTitle = document.getElementById('video-title');\n    const videoInfoViews = document.getElementById('video-views');\n    const videoInfoTime = document.getElementById('video-time');\n    const videoDescription = document.getElementById('video-description');\n    const relatedList = document.getElementById('related-list');\n    \n    if (!videoPlayer) return;\n    \n    // URLパラメータからvideo_idを取得\n    const urlParams = new URLSearchParams(window.location.search);\n    const videoId = urlParams.get('id');\n    if (!videoId) {\n        showStatus('動画が見つかりません', 'error');\n        return;\n    }\n    \n    // ビュー数をインクリメント\n    try {\n        const response = await apiRequest(`/api/videos.php?id=${videoId}`);\n        const video = response?.video;\n        \n        if (!video) {\n            showStatus('動画が見つかりません', 'error');\n            return;\n        }\n        \n        // 動画情報\n        videoInfoTitle.textContent = video.title;\n        videoInfoViews.textContent = formatViews(video.views);\n        videoInfoTime.textContent = formatDate(video.created_at);\n        videoDescription.textContent = video.description || '説明はありません';\n        \n        // 動画プレイヤーに設定\n        videoPlayer.src = `/uploads/${video.filename}`;\n        \n        // サムネイルを設定\n        const thumb = document.getElementById('video-thumbnail');\n        if (thumb) {\n            thumb.src = video.thumbnail;\n        }\n        \n        // ウェブプレイヤーに設定\n        loadRelatedVideos();\n    } catch (error) {\n        showStatus('動画の読み込みに失敗しました', 'error');\n    }\n}\n\n/** Related (関連動画) */\nasync function loadRelatedVideos() {\n    const relatedList = document.getElementById('related-list');\n    if (!relatedList) return;\n    \n    try {\n        const response = await apiRequest('/api/videos.php');\n        relatedList.innerHTML = '';\n        \n        // video_playerのid以外の動画を関連動画として表示\n        const videoId = new URLSearchParams(window.location.search).get('id');\n        \n        response.videos\n            .filter(v => v.id !== videoId)\n            .slice(0, 5) // 最大5件\n            .forEach(video => {\n                const card = createRelatedVideoCard(video);\n                relatedList.appendChild(card);\n            });\n    } catch (error) {\n        relatedList.innerHTML = `<p>関連動画の読み込みに失敗しました</p>`;\n    }\n}\n\n/** ステータスメッセージの表示 */\nfunction showStatus(message, type = 'info') {\n    statusEl.textContent = message;\n    statusEl.className = `status status-${type}`;\n    statusEl.style.display = 'block';\n    \n    // 3秒後に非表示\n    if (type !== 'success' && type !== 'error') {\n        setTimeout(() => {\n            statusEl.style.display = 'none';\n        }, 3000);\n    }\n}\n\n// init\ndocument.addEventListener('DOMContentLoaded', () => {\n    if (PAGE_TYPE === 'index.html') {\n        loadVideos();\n    } else if (PAGE_TYPE === 'upload.html') {\n        handleUpload();\n    } else if (PAGE_TYPE === 'watch.html') {\n        loadVideo();\n    }\n});"},"status":"approved","result":{"status":"success","path":"vibe_coding/mytube2/js/app.js","message":"ファイルを作成しました"},"approvalTime":3.767},"memory_usage":2097152,"script":"tool_history.php"}
