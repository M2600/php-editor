{"timestamp":"2026-04-19 10:22:38","level":"INFO","level_num":1,"pid":83016,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"js/main.js","content":"/** 共通関数 */\n\n/** 動画の長さをフォーマット */\nfunction formatDuration(sec) {\n    const h = Math.floor(sec / 3600);\n    const m = Math.floor((sec % 3600) / 60);\n    const s = Math.floor(sec % 60);\n    if (h > 0) {\n        return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;\n    }\n    return `${m}:${String(s).padStart(2, '0')}`;\n}\n\n/** 再生回数をフォーマット */\nfunction formatViews(num) {\n    if (num >= 1000000) {\n        return `${(num / 1000000).toFixed(1)}M回再生`;\n    }\n    if (num >= 1000) {\n        return `${(num / 1000).toFixed(1)}K回再生`;\n    }\n    return `${num}回再生`;\n}\n\n/** 日付をフォーマット */\nfunction formatDate(dateStr) {\n    const date = new Date(dateStr);\n    const now = new Date();\n    const diff = now - date;\n    const days = Math.floor(diff / (1000 * 60 * 60 * 24));\n    if (days < 1) {\n        const hours = Math.floor(diff / (1000 * 60 * 60));\n        const mins = Math.floor(diff / (1000 * 60));\n        if (hours > 0) return `${hours}時間前にアップロード`;\n        return `${mins}分前にアップロード`;\n    }\n    if (days < 30) return `${days}日前`;\n    if (days < 365) return `${Math.floor(days / 30)}ヶ月前`;\n    return `${Math.floor(days / 365)}年前`;\n}\n\n/** 動画カードの生成 */\nfunction createVideoCard(video) {\n    const div = document.createElement('div');\n    div.className = 'video-card';\n    \n    const thumbUrl = video.thumbnail\n        ? `<img src=\"${video.thumbnail}\" style=\"width: 100%; height: 100%; object-fit: cover;\" />`\n        : `<div style=\"width: 100%; height: 100%; background: #ccc; display: flex; align-items: center; justify-content: center; color: #666; font-size: 24px;\">▶</div>`;\n    \n    div.innerHTML = `\n        <a href=\"watch.html?id=${video.id}\">\n            <div class=\"video-thumbnail\">\n                ${thumbUrl}\n                ${video.duration ? `<span class=\"duration\" style=\"position: absolute; bottom: 10px; right: 10px; background: rgba(0,0,0,0.8); color: #fff; font-size: 12px; padding: 2px 4px; border-radius: 2px;\">${formatDuration(video.duration)}</span>` : ''}\n            </div>\n            <div class=\"video-info\">\n                <div class=\"video-title\">${escapeHtml(video.title)}</div>\n                <div class=\"video-meta\">\n                    <span>${formatViews(video.views)}</span>\n                    <span>•</span>\n                    <span>${formatDate(video.created_at)}</span>\n                </div>\n            </div>\n        </a>\n    `;\n    return div;\n}\n\n/** サイドバー用動画カードの生成 */\nfunction createRelatedVideoCard(video) {\n    const div = document.createElement('div');\n    div.className = 'related-video';\n    \n    const thumbUrl = video.thumbnail\n        ? `<img src=\"${video.thumbnail}\" style=\"width: 100%; height: 100%; object-fit: cover;\" />`\n        : `<div></div>`;\n    \n    div.innerHTML = `\n        <a href=\"watch.html?id=${video.id}\">\n            <div class=\"related-thumb\">\n                ${thumbUrl}\n            </div>\n            <div class=\"related-info\">\n                <div class=\"related-title\">${escapeHtml(video.title)}</div>\n                <div class=\"related-channel\">${formatViews(video.views)}</div>\n                <div class=\"related-channel\">${formatDate(video.created_at)}</div>\n            </div>\n        </a>\n    `;\n    return div;\n}\n\n/** HTMLエスケープ */\nfunction escapeHtml(str) {\n    const div = document.createElement('div');\n    div.textContent = str;\n    return div.innerHTML;\n}\n\n/** APIリクエストのヘルパー */\nasync function apiRequest(url, options = {}) {\n    const defaultOptions = {\n        headers: {\n            'Content-Type': 'application/json',\n        },\n    };\n    const response = await fetch(url, { ...defaultOptions, ...options });\n    if (!response.ok) {\n        const errorData = await response.json().catch(() => ({ message: 'APIエラー' }));\n        throw new Error(errorData.message || 'APIエラーが発生しました');\n    }\n    return response.json();\n}"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":2.67},"memory_usage":2097152,"script":"tool_history.php"}
