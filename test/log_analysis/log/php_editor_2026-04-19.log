iv class=\"video-thumbnail video-thumbnail\">\n                ${video.thumbnail\n                    ? `<img src=\"${video.thumbnail}\" alt=\"${video.title}\">`\n                    : `<img src=\"images/default-thumbnail.png\" alt=\"再生\">`\n                }\n                <span class=\"play-icon\" style=\"position: absolute; bottom: 10px; color: #fff; font-size: 16px; text-shadow: 0 1px 3px rgba(0,0,0,0.6);\">▶</span>\n                ${video.duration ? `<span class=\"duration-badge\" style=\"position: absolute; bottom: 10px; right: 10px; background: rgba(0,0,0,0.8); color: #fff; font-size: 12px; padding: 2px 4px; border-radius: 4px;\">${formatDuration(video.duration)}</span>` : ''}\n            </div>\n            <div class=\"video-info\">\n                <div class=\"video-title\">${video.title}</div>\n                <div class=\"video-meta\">\n                    <span>${formatViews(video.views)}回再生</span>\n                    <span>•</span>\n                    <span>${formatDate(video.created_at)}</span>\n                </div>\n            </div>\n        </a>\n    `;\n    return div;\n}\n\n/** サイドバー用の動画カードの生成 */\nfunction createRelatedVideoCard(video) {\n    const div = document.createElement('div');\n    div.className = 'related-video';\n    div.innerHTML = `\n        <a href=\"watch.html?id=${video.id}\" style=\"text-decoration: none; color: inherit;\">\n            <div class=\"video-thumbnail video-thumbnail\">\n                ${video.thumbnail\n                    ? `<img src=\"${video.thumbnail}\" alt=\"${video.title}\">`\n                    : `<div class=\"video-thumbnail\" style=\"width: 100%; height: 100%; background: #ccc; display: flex; align-items: center; justify-content: center;\"></div>`\n                }\n                ${video.duration ? `<span class=\"duration-badge\" style=\"position: absolute; bottom: 4px; right: 4px; background: rgba(0,0,0,0.8); color: #fff; font-size: 10px; padding: 1px 3px; border-radius: 2px;\">${formatDuration(video.duration)}</span>` : ''}\n            </div>\n            <div class=\"related-info\">\n                <div class=\"related-title\">${video.title}</div>\n                <div class=\"channel\">視聴回数: ${formatViews(video.views)} 回</div>\n                <div class=\"related-channel\">${formatDate(video.created_at)}</div>\n            </div>\n        </a>\n    `;\n    return div;\n}\n\n/** HTMLエスケープ */\nfunction escapeHtml(str) {\n    const div = document.createElement('div');\n    div.textContent = str;\n    return div.innerHTML;\n}"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":13.6},"memory_usage":2097152,"script":"tool_history.php"}
