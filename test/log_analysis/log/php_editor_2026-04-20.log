{"timestamp":"2026-04-20 09:47:24","level":"INFO","level_num":1,"pid":3612,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"web/main.js","content":"/**\n * aichat - web/main.js\n * \n * 複数AI対話フレームワーク v4\n * メインロジック（JS）:\n * - chatHistory管理\n * - LLM呼び出し（POST /llm/chat through PHP）\n * - エージェント人格/役割の管理\n * - ストリーミング表示\n */\n\n(function() {\n    'use strict';\n\n     // ===== 設定・状態 =====\n    const CONFIG = {\n         apiKey: null,          // 後ほどserverから読み込み（PHP側で管理）\n         baseUrl: '',\n        model: 'gpt-4o-mini',\n        temperature: 0.7,\n        agentNum: 3,\n        systemPromptTemplate: 'あなたは{{role}}です。',\n    };\n\n     const chatHistory = []; // [{role: 'system'|'user'|'assistant', content: ''}]\n    let isStreaming = false;\n     let abortController = null;\n\n     // エージェント名（簡易生成）\n     function getAgentLabels(count) {\n        return Array.from({length: count}, (_, i) => `Agent ${String.fromCharCode(65 + i)}`);\n    }\n\n    // ===== DOM参照 =====\n    const $configPanel = document.getElementById('config-panel');\n     const $chatPanel   = document.getElementById('chat-panel');\n    const $topicInput  = document.getElementById('topic-input');\n    const $agentNum    = document.getElementById('agent-num');\n    const $agentNumVal = document.getElementById('agent-num-value' || 'agent-num-val'); // fallback\n     const $urlInput    = document.getElementById('api-url');\n    const $modelInput  = document.getElementById('model-select');\n    const $systemPrompt= document.getElementById('system-prompt');\n    const $startBtn    = document.getElementById('start-btn');\n     const $chatHistory = document.getElementById('chat-history');\n    const $modelChange      = document.getElementById('model-change' || 'model-select');       // fallback\n    const $resetBtn         = document.getElementById('reset-btn');\n    const $userInput        = document.getElementById('user-input');\n     const $sendBtn          = document.getElementById('send-btn');\n\n    \n    // ===== イベント: 初期設定画面 =====\n    \n    // エージェント数スライダー\n     $agentNum.addEventListener('input', () => {\n         CONFIG.agentNum = parseInt($agentNum.value);\n        $agentNumVal.textContent = CONFIG.agentNum;\n    });\n\n    $startBtn.addEventListener('click', startConversation);\n\n    function startConversation() {\n         // 設定を反映\n        CONFIG.baseUrl = $urlInput.value || '';\n        CONFIG.model   = $modelInput.value || 'gpt-4o-mini';\n        CONFIG.agentNum = parseInt($agentNum.value) || 3;\n        CONFIG.systemPromptTemplate = $systemPrompt.value || 'あなたは{{role}}です。';\n\n         // chatHistoryクリア\n        chatHistory.length = 0;\n\n         // systemメッセージ追加（エージェント指示付き）\n        const agents = getAgentLabels(CONFIG.agentNum);\n        const agentsText = agents.join(', ');\n        const systemMsg = `${CONFIG.systemPromptTemplate.replace('{{role}}', '複数AIエージェントの1つ')}`;\n         chatHistory.push({ role: 'system', content: `あなたは${agentsText}を含む複数のAIエージェントです。トピック: ${$topicInput.value || '自由会話'}`);\n\n        // UI切替\n         $configPanel.classList.add('hidden');\n    \t$chatPanel.classList.remove('hidden');\n\n         // 最初のLLM呼び出し\n        sendMessage();\n    }\n\n    // ===== イベント: チャット画面 =====\n    \n    // 送信ボタンのみ実装（Enterはform submitで制御可）\n    $sendBtn.addEventListener('click', () => {\n        if (isStreaming) return;\n        const text = $userInput.value.trim();\n        if (!text) return;\n\n         chatHistory.push({ role: 'user', content: text });\n        renderMessages();\n        sendMessage(text); // LLM応答取得（人間メッセージも追加済）\n    });\n\n    // Enter送信（Shift+Enterは改行）\n    $userInput.addEventListener('keydown', (e) => {\n        if (e.key === 'Enter' && !e.shiftKey) {\n            e.preventDefault();\n            $sendBtn.click();\n        }\n    });\n\n     $resetBtn.addEventListener('click', resetConversation);\n\n    function resetConversation() {\n        chatHistory.length = 0;\n        $chatHistory.innerHTML = '';\n        $configPanel.classList.remove('hidden');\n        $chatPanel.classList.add('hidden');\n    }\n\n    // ===== LLM呼び出し（ストリーミング） =====\n    \n    async function sendMessage(userMessage = null) {\n         if (isStreaming) return;\n        isStreaming = true;\n\n        // 人間メッセージを追加済みならskip\n        let payload = [...chatHistory];\n        if (userMessage && !payload[payload.length - 1]?.role === 'user') {\n             chatHistory.push({ role: 'user', content: userMessage });\n            payload.push({ role: 'user', content: userMessage });\n        }\n\n         // UI初期化（ストリーミング表示用）\n        const agentLabels = getAgentLabels(CONFIG.agentNum);\n        let lastLabel = agentLabels[payload.length % CONFIG.agentNum]; // 簡易ローテーション\n\n        createStreamingElement(lastLabel);\n\n        try {\n             const response = await fetch('/llm/chat', {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({\n                    messages: payload,\n                    options: {\n                         model: CONFIG.model,\n                        temperature: 1.0 // シンプル化のため固定\n                     }\n                 })\n             });\n\n            if (!response.ok) {\n            \tthrow new Error(`HTTP ${response.status}`);\n            }\n\n            // Stream処理 (Server-Sent Events互換形式を想定)\n            const reader = response.body.getReader();\n            const decoder = new TextDecoder();\n            let fullContent = '';\n\n            while (true) {\n                const { done, value } = await reader.read();\n                if (done) break;\n                \n                const chunk = decoder.decode(value);\n                const lines = chunk.split('\\n');\n                \n                 for (const line of lines) {\n                     if (!line.startsWith('data: ')) continue;\n                    let data = line.slice(6);\n\n                    if (data === '[DONE_START]') continue;\n                    if (data === '[DONE]') break;\n\n                    try {\n                        const parsed = JSON.parse(data);\n                        if (parsed.choices?.[0]?.delta?.content) {\n                            fullContent += parsed.choices[0].delta.content;\n                            updateStreamingText(fullContent);\n                        } else if (typeof data === 'string' && data !== '') {\n                             // fallback: 直接テキスト追加\n                        \tfullContent += data + '\\n';\n                    \t\tupdateStreamingText(fullContent);\n                        }\n                \t} catch (e) {\n                    \t\tconsole.warn('Parse error', e, data.slice(0, 50));\n                \t}\n                }\n            }\n\n            // LLM応答をhistoryに追加\n             chatHistory.push({ role: 'assistant', content: fullContent.trim() });\n        } catch (err) {\n        \tconsole.error('LLM呼び出しエラー:', err);\n            chatHistory.push({ \n                role: 'system', \n                content: `⚠️ Error: ${err.message || 'failed to call LLM'}` \n            });\n            renderMessages();\n        } finally {\n            isStreaming = false;\n        }\n    }\n\n    // ===== UIヘルパー =====\n    \n     function createStreamingElement(label) {\n         $chatHistory.innerHTML += `\n             <div class=\"message agent\" id=\"streaming-msg\">\n                 <strong>${label}:</strong> <span class=\"content\"></span><span class='cursor'>|</span>\n             </div>\n         `;\n        window.scrollTo(0, document.body.scrollHeight);\n    }\n\n    function updateStreamingText(content) {\n        const el = document.querySelector('#streaming-msg .content');\n        if (el) el.textContent = content;\n    }\n\n    function renderMessages() {\n        $chatHistory.innerHTML = '';\n        \n         chatHistory.forEach((msg, i) => {\n             if (msg.role === 'system') return; // systemはスキップするか別扱い\n            \n            const div = document.createElement('div');\n            div.className = `message ${msg.role}`;\n             div.textContent = `${msg.role}: ${msg.content}`;\n            $chatHistory.appendChild(div);\n        });\n\n         window.scrollTo(0, document.body.scrollHeight);\n    }\n\n     // 初期化（例: 設定読み込みなど）\n    \n})();\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/aichat/web/main.js","message":"ファイルを作成しました"},"approvalTime":31.83},"memory_usage":2097152,"script":"tool_history.php"}
