{"timestamp":"2026-04-20 10:26:09","level":"INFO","level_num":1,"pid":3617,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"server.php","content":"<?php\n/**\n * aichat server.php\n * \n * 役割:\n * - 静的ファイル（index.html, style.css, main.js）の提供\n * - POST /llm/chat エンドポイントでのLLM API呼び出し\n */\n\n// --- CORS設定 ---\nheader('Access-Control-Allow-Origin: *');\nheader('Access-Control-Allow-Methods: GET, POST, OPTIONS');\nheader('Access-Control-Allow-Headers: Content-Type');\n\nif ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {\n    http_response_code(200);\n    exit;\n}\n\n// --- ルーティング ---\n$scriptDir = dirname(__FILE__);\n\n$isLlmRoute = (isset($_GET['route']) && $_GET['route'] === '/llm/chat');\n\n// LLMチャットエンドポイント\nif ($isLlmRoute && $_SERVER['REQUEST_METHOD'] === 'POST') {\n    handleLLMChat($scriptDir);\n    exit;\n}\n\n// 静的ファイル提供エンドポイント\n$uri = $_SERVER['REQUEST_URI'];\nif (isset($_GET['route']) && $_GET['route'] !== '/llm/chat') {\n    serveStaticFile($uri);\n    exit;\n}\n\nserveStaticFile($uri);\nexit;\n\n/**\n * LLM API呼び出し\n */\nfunction handleLLMChat($scriptDir)\n{\n    // リクエストボディの読み取り\n    $rawInput = file_get_contents('php://input');\n    $data = json_decode($rawInput, true);\n\n    if (!$data || !isset($data['messages'])) {\n        http_response_code(400);\n        echo json_encode(['error' => 'messages is required']);\n        exit;\n    }\n\n    $messages = $data['messages'];\n    $options = $data['options'] ?? [];\n\n    // シークレットファイルの読み取り\n    $secretsPath = $scriptDir . '/.env/secrets.json';\n    if (!file_exists($secretsPath) || !is_readable($secretsPath)) {\n        http_response_code(500);\n        echo json_encode(['error' => 'secrets.json not found or not readable']);\n        exit;\n    }\n\n    $json = file_get_contents($secretsPath);\n    if ($json === false) {\n        http_response_code(500);\n        echo json_encode(['error' => 'failed to read secrets.json']);\n        exit;\n    }\n\n    $secrets = json_decode($json, true);\n    if (!is_array($secrets)) {\n        http_response_code(500);\n        echo json_encode(['error' => 'invalid secrets.json format']);\n        exit;\n    }\n\n    // シークレットの抽出\n    $apiKey = $secrets['api_key'] ?? '';\n    $baseUrl = $secrets['base_url'] ?? 'https://api.openai.com/v1';\n    $defaultModel = $secrets['model'] ?? 'gpt-3.5-turbo';\n    $defaultTemperature = $secrets['temperature'] ?? 0.7;\n\n    if (empty($apiKey)) {\n        http_response_code(500);\n        echo json_encode(['error' => 'API key not configured']);\n        exit;\n    }\n\n    $model = $options['model'] ?? $defaultModel;\n    $temp = $options['temperature'] ?? $defaultTemperature;\n    $apiUrl = rtrim($baseUrl, '/') . '/chat/completions';\n\n    // cURLでLLMを呼び出し（ストリーミング対応）\n    $payload = [\n        'model' => $model,\n        'messages' => $messages,\n        'temperature' => $temp,\n        'stream' => true,\n    ];\n\n    $ch = curl_init();\n    curl_setopt_array($ch, [\n        CURLOPT_URL => $apiUrl,\n        CURLOPT_RETURNTRANSFER => false,\n        CURLOPT_POST => true,\n        CURLOPT_POSTFIELDS => json_encode($payload),\n        CURLOPT_HTTPHEADER => [\n            'Content-Type: application/json',\n            'Authorization: Bearer ' . $apiKey,\n        ],\n        CURLOPT_SSL_VERIFYPEER => false,\n    ]);\n\n    // ストリーミングレスポンスヘッダ\n    header('Content-Type: text/event-stream');\n    header('Cache-Control: no-cache');\n    header('Connection: keep-alive');\n    header('X-Accel-Buffering: no'); // Nginx用バッファ無効化\n\n    ob_implicit_flush(true);\n\n    if (curl_exec($ch) === false) {\n        curl_close($ch);\n        http_response_code(502);\n        $err = curl_error($ch);\n        echo \"data: \" . json_encode(['error' => $err]) . \"\\n\\n\";\n    } else {\n        curl_close($ch);\n    }\n}\n\n/**\n * 静的ファイルを提供する\n */\nfunction serveStaticFile($uri)\n{\n    $uri = str_replace('/index.html', '/', $uri);\n    \n    if ($uri === '/') {\n        $file = __DIR__ . '/web/index.html';\n    } elseif ($uri === '/style.css') {\n        $file = __DIR__ . '/web/style.css';\n    } elseif ($uri === '/main.js') {\n        $file = __DIR__ . '/web/main.js';\n    } else {\n        // 必要に応じて追加static\n        return false;\n    }\n\n    if (!file_exists($file)) {\n        return false;\n    }\n\n    $finfo = new finfo(FILEINFO_MIME_TYPE);\n    $mime = $finfo->file($file);\n\n    header('Content-Type: ' . $mime);\n    readfile($file);\n}"},"status":"error","result":{"error":"file_already_exists"},"approvalTime":6.215},"memory_usage":2097152,"script":"tool_history.php"}
