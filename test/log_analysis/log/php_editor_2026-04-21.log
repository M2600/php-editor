{"timestamp":"2026-04-21 12:24:45","level":"INFO","level_num":1,"pid":55748,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"editFileByReplace","parameters":{"filename":"config.php","searchText":"define('RATE_LIMIT_SECONDS', 60); // リクエスト間隔（制限用）\ndefine('RATE_LIMIT_FILE', __DIR__ . '/data/rate_limit.txt');\n\n/**\n * API レスポンスを返す\n */\nfunction sendResponse($success, $data = null, $message = '') {\n    header('Content-Type: application/json; charset=utf-8');\n    \n    $response = [\n        'success' => $success\n     ];\n    \n    if ($data !== null) {\n        $response['data'] = $data;\n     }\n    \n    if (!empty($message)) {\n        $response['message'] = $message;\n     }\n    \n    echo json_encode($response, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);\n    exit;\n}\n\n/**\n * エラーレスポンスを返す\n */\nfunction sendError($code, $message) {\n    sendResponse(false, ['code' => $code, 'message' => $message], '');\n}\n\n/**\n * データファイルをロード\n */\nfunction loadPosts() {\n    if (!file_exists(DATA_FILE)) {\n        return initPostsFile();\n     }\n    \n    $content = file_get_contents(DATA_FILE);\n    $data = json_decode($content, true);\n    \n    if ($data === null) {\n        return initPostsFile();\n     }\n    \n    return $data;\n}\n\n/**\n * データファイルに保存\n */\nfunction savePosts($data, $lock = true) {\n    global $LOCK_FILE;\n    \n     // 簡易なファイルロック\n    if ($lock) {\n        file_put_contents(DATA_FILE, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE), LOCK_EX);\n     } else {\n        file_put_contents(DATA_FILE, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE));\n     }\n    \n    return true;\n}","replaceText":"define('RATE_LIMIT_SECONDS', 60); // リクエスト間隔（制限用）\ndefine('RATE_LIMIT_FILE', __DIR__ . '/data/rate_limit.txt');\n\n/**\n * API レスポンスを返す\n */\nfunction sendResponse($success, $data = null, $message = '') {\n    header('Content-Type: application/json; charset=utf-8');\n    \n    $response = [\n        'success' => $success\n     ];\n    \n    if ($data !== null) {\n        $response['data'] = $data;\n     }\n    \n    if (!empty($message)) {\n        $response['message'] = $message;\n     }\n    \n    echo json_encode($response, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);\n    exit;\n}\n\n/**\n * エラーレスポンスを返す\n */\nfunction sendError($code, $message) {\n    sendResponse(false, ['code' => $code, 'message' => $message], '');\n}\n\n/**\n * データファイルをロード\n */\nfunction loadPosts() {\n    if (!file_exists(DATA_FILE)) {\n        return initPostsFile();\n     }\n    \n    $content = file_get_contents(DATA_FILE);\n    $data = json_decode($content, true);\n    \n    if ($data === null) {\n        return initPostsFile();\n     }\n    \n    return $data;\n}\n\n/**\n * データファイルに保存（簡易ロック付き）\n */\nfunction savePosts($data, $lock = true) {\n     // 簡易なファイルロックで同時書き込み防止\n    if ($lock) {\n        file_put_contents(DATA_FILE, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE), LOCK_EX);\n     } else {\n        file_put_contents(DATA_FILE, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE));\n     }\n    \n    return true;\n}","options":[],"hints":["完全一致検索です。属性差分がある場合は options.regex=true を検討してください","複数行ブロックがずれている可能性があります。見出し単位で再検索するか editFileByLines も検討してください"]},"status":"no_change","result":null,"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
