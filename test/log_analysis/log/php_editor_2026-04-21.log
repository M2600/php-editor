{"timestamp":"2026-04-21 12:24:09","level":"INFO","level_num":1,"pid":55760,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/handlers/comments.php","content":"<?php\n/**\n * コメント処理ハンドラ\n */\n\nrequire_once __DIR__ . '/../config.php';\n\n// レート制限チェック\ncheckRateLimit();\n\n$method = $_SERVER['REQUEST_METHOD'];\n$action = $_GET['action'] ?? '';\n$threadId = $_GET['threadId'] ?? null;\n\n// データロード（参照ではなくコピー）\n$data = loadPosts();\n\nswitch ($method) {\n    case 'GET':\n        if ($action === 'list' && $threadId) {\n            getCommentsList($data, $threadId);\n         } else {\n            sendError('INVALID_REQUEST', '無効なリクエストです: threadId が必須です');\n         }\n        break;\n\n    case 'POST':\n        if ($action === 'create' && $threadId) {\n            createComment($data, $threadId);\n         } else {\n            sendError('INVALID_ACTION', '無効なアクションです: threadId が必須です');\n         }\n        break;\n\n    default:\n        sendError('METHOD_NOT_ALLOWED', '許可されていないメソッドです');\n}\n\n/**\n * 特定スレッドのコメント一覧を取得\n */\nfunction getCommentsList($data, $threadId) {\n     if (!isset($data['threads'][$threadId])) {\n         sendError('THREAD_NOT_FOUND', 'スレッドが見つかりませんでした: threadId=' . $threadId);\n      }\n    \n     $comments = $data['threads'][$threadId]['comments'] ?? [];\n     // 追加順（最新が先）にソート済みであることを仮定\n    \n    sendResponse(true, [\n         'comments' => array_values($comments), // キーをリセットして配列化\n          'count' => count($comments)\n     ], 'コメント一覧を取得しました:');\n}\n\n/**\n * 新しいコメントを作成\n */\nfunction createComment(&$data, $threadId) {\n      if (!isset($data['threads'][$threadId])) {\n         sendError('THREAD_NOT_FOUND', 'スレッドが見つかりませんでした: threadId=' . $threadId);\n      }\n    \n       $input = json_decode(file_get_contents('php://input'), true);\n    \n     if (!$input) {\n        sendError('INVALID_INPUT', 'リクエストボディが無効です');\n      }\n    \n     // 入力検証\n     $content = trim($input['content'] ?? '');\n     $author = trim($input['author'] ?? '匿名');\n    \n    if (empty($content)) {\n         sendError('MISSING_CONTENT', 'コメント内容を入力してください');\n      }\n    \n     // 文字数制限チェック\n    if (mb_strlen($content) > ALLOWED_CHARACTERS) {\n        sendError('TOO_LONG_CONTENT', \"本文は {$ALLOWED_CHARACTERS} 文字以内でください\");\n      }\n    \n     // エスケープ処理\n     $content = escapeHtml($content);\n     $author = escapeHtml($author);\n    \n     // コメント作成\n     $commentId = generateId();\n     $newComment = [\n         'id' => $commentId,\n          'content' => $content,\n         'author' => $author,\n         'createdAt' => getCurrentTime()\n      ];\n    \n      // スレッドのコメント配列に追加（最新が最前）\n     if (!isset($data['threads'][$threadId]['comments'])) {\n         $data['threads'][$threadId]['comments'] = [];\n      }\n    \n      array_unshift($data['threads'][$threadId]['comments'], $newComment);\n    \n    savePosts($data);\n    \n    sendResponse(true, [\n         'comment' => $newComment,\n          'message' => 'コメントが投稿されました: ID=' . $commentId\n     ], 'コメント成功');\n}\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/test1/api/handlers/comments.php","message":"ファイルを作成しました"},"approvalTime":28.54},"memory_usage":2097152,"script":"tool_history.php"}
