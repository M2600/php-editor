{"timestamp":"2026-04-21 12:22:34","level":"INFO","level_num":1,"pid":55757,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/handlers/threads.php","content":"<?php\n/**\n * スレッド処理ハンドラ\n */\n\nrequire_once __DIR__ . '/../config.php';\n\n// レート制限チェック\ncheckRateLimit();\n\n$method = $_SERVER['REQUEST_METHOD'];\n$action = $_GET['action'] ?? '';\n$id = $_GET['id'] ?? null;\n\n// データロード\n$data = loadPosts();\n\nswitch ($method) {\n    case 'GET':\n        if ($action === 'list') {\n            getThreadsList($data);\n        } elseif ($action === 'detail' && $id) {\n            getThreadDetail($data, $id);\n        } else {\n            sendError('INVALID_REQUEST', '無効なリクエストです');\n        }\n        break;\n\n    case 'POST':\n        if ($action === 'create') {\n            createThread($data);\n        } else {\n            sendError('INVALID_ACTION', '無効なアクションです');\n        }\n        break;\n\n    case 'DELETE':\n        if ($action === 'delete' && $id) {\n            deleteThread($data, $id);\n        } else {\n            sendError('INVALID_ACTION', '削除機能は管理者のみです（未実装）:');\n        }\n        break;\n\n    default:\n        sendError('METHOD_NOT_ALLOWED', '許可されていないメソッドです:');\n}\n\n/**\n * スレッド一覧を取得\n */\nfunction getThreadsList($data) {\n    $threads = $data['threads'] ?? [];\n    $settings = $data['settings'] ?? ['maxThreadsPerPage' => 10];\n    \n    // ページネーション（パラメータ付き）\n    $page = max(1, (int)$_GET['page'] ?? 1);\n    $limit = $settings['maxThreadsPerPage'];\n    \n    $total = count($threads);\n    $offset = ($page - 1) * $limit;\n    $paginated = array_slice($threads, $offset, $limit, true);\n    \n    // ID順にソート（最新が先）\n    krsort($paginated);\n    \n    sendResponse(true, [\n        'threads' => $paginated,\n        'pagination' => [\n            'page' => $page,\n            'limit' => $limit,\n            'total' => $total,\n            'pages' => ceil($total / $limit)\n        ]\n    ], 'スレッド一覧を取得しました:');\n}\n\n/**\n * スレッド詳細を取得\n */\nfunction getThreadDetail($data, $id) {\n    $threads = $data['threads'] ?? [];\n    \n    if (!isset($threads[$id])) {\n        sendError('THREAD_NOT_FOUND', 'スレッドが見つかりませんでした:');\n     }\n    \n    // コメントを含む完全なスレッド情報を返す\n    sendResponse(true, [\n        'thread' => $threads[$id]\n    ], 'スレッド詳細を取得しました:');\n}\n\n/**\n * 新しいスレッドを作成\n */\nfunction createThread(&$data) {\n     $input = json_decode(file_get_contents('php://input'), true);\n    \n    if (!$input) {\n        sendError('INVALID_INPUT', 'リクエストボディが無効です:');\n     }\n    \n    // 入力検証\n    $title = trim($input['title'] ?? '');\n    $content = trim($input['content'] ?? '');\n    $author = trim($input['author'] ?? '匿名');\n    \n    if (empty($title)) {\n        sendError('MISSING_TITLE', 'タイトルを入力してください:');\n     }\n    \n    if (empty($content)) {\n         sendError('MISSING_CONTENT', '本文を入力してください:');\n     }\n    \n    // 文字数制限チェック\n    if (mb_strlen($title) > 200) {\n        sendError('TOO_LONG_TITLE', 'タイトルは 200 文字以内でください:');\n     }\n    \n    if (mb_strlen($content) > ALLOWED_CHARACTERS) {\n         sendError('TOO_LONG_CONTENT', \"本文は {$ALLOWED_CHARACTERS} 文字以内でください:\");\n     }\n    \n    // エスケープ処理\n    $title = escapeHtml($title);\n    $content = escapeHtml($content);\n    $author = escapeHtml($author);\n    \n    // スレッド作成\n    $id = generateId();\n     $threads = $data['threads'] ?? [];\n    \n     $threads[$id] = [\n        'id' => $id,\n         'title' => $title,\n        'content' => $content,\n        'author' => $author,\n        'createdAt' => getCurrentTime(),\n        'comments' => []\n     ];\n    \n    // サポート順（最新が先）のためキーを割り当てる\n    ksort($threads);\n    arsort($threads, SORT_NUMERIC);\n    $data['threads'] = array_reverse($threads, true);\n    \n    savePosts($data);\n    \n    sendResponse(true, [\n        'thread' => $ threads[$id],\n        'message' => 'スレッドが作成されました: ID=' . $id\n    ], '投稿成功:');\n}\n\n/**\n * スレッドを削除（管理者用）\n */\nfunction deleteThread(&$data, $id) {\n    // 注：実際の運用では API キーや認証が必要\n     if (isset($data['threads'][$id])) {\n         unset($data['threads'][$id]);\n         savePosts($data);\n         \n        sendResponse(true, ['message' => '削除しました: ID=' . $id], '削除成功');\n     } else {\n        sendError('THREAD_NOT_FOUND', 'スレッドが見つかりませんでした:');\n     }\n}\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/test1/api/handlers/threads.php","message":"ファイルを作成しました"},"approvalTime":25.754},"memory_usage":2097152,"script":"tool_history.php"}
