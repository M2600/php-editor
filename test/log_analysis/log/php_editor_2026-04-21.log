{"timestamp":"2026-04-21 12:21:18","level":"INFO","level_num":1,"pid":55756,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"config.php","content":"<?php\n/**\n * 掲示板システム - 設定ファイル\n */\n\n// エラー表示オフ（本番環境では推奨）\nerror_reporting(E_ALL);\nini_set('display_errors', 1);\n\n// JSON データファイルのパス\ndefine('DATA_FILE', __DIR__ . '/data/posts.json');\n\n// 設定\ndefine('MAX_THREADS_PER_PAGE', 10);\ndefine('ALLOWED_CHARACTERS', 5000);\ndefine('RATE_LIMIT_SECONDS', 60); // リクエスト間隔（制限用）\ndefine('RATE_LIMIT_FILE', __DIR__ . '/data/rate_limit.txt');\n\n/**\n * API レスポンスを返す\n */\nfunction sendResponse($success, $data = null, $message = '') {\n    header('Content-Type: application/json; charset=utf-8');\n    \n    $response = [\n        'success' => $success\n    ];\n    \n    if ($data !== null) {\n        $response['data'] = $data;\n    }\n    \n    if (!empty($message)) {\n        $response['message'] = $message;\n    }\n    \n    echo json_encode($response, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);\n    exit;\n}\n\n/**\n * エラーレスポンスを返す\n */\nfunction sendError($code, $message) {\n    sendResponse(false, ['code' => $code, 'message' => $message], '');\n}\n\n/**\n * データファイルをロード\n */\nfunction loadPosts() {\n    if (!file_exists(DATA_FILE)) {\n        return initPostsFile();\n    }\n    \n    $content = file_get_contents(DATA_FILE);\n    $data = json_decode($content, true);\n    \n    if ($data === null) {\n        return initPostsFile();\n    }\n    \n    return $data;\n}\n\n/**\n * データファイルに保存\n */\nfunction savePosts($data, $lock = true) {\n    global $LOCK_FILE;\n    \n    // 簡易なファイルロック\n    if ($lock) {\n        file_put_contents(DATA_FILE, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE), LOCK_EX);\n    } else {\n        file_put_contents(DATA_FILE, json_encode($data, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE));\n    }\n    \n    return true;\n}\n\n/**\n * 初期データの作成\n */\nfunction initPostsFile() {\n    $default = [\n        'threads' => [],\n        'settings' => [\n            'maxThreadsPerPage' => MAX_THREADS_PER_PAGE,\n            'allowedCharacters' => ALLOWED_CHARACTERS\n        ]\n    ];\n    \n    savePosts($default);\n    return $default;\n}\n\n/**\n * ユーザー入力のエスケープ（XSS 対策）\n */\nfunction escapeHtml($text) {\n    return htmlspecialchars($text, ENT_QUOTES, 'UTF-8');\n}\n\n/**\n * 一意な ID を生成\n */\nfunction generateId() {\n    return bin2hex(random_bytes(16));\n}\n\n/**\n * ISO8601 フォーマットの現在時刻を取得\n */\nfunction getCurrentTime() {\n    return date('c');\n}\n\n/**\n * レート制限をチェック（簡易版）\n */\nfunction checkRateLimit($userId = null) {\n    $ip = $_SERVER['REMOTE_ADDR'] ?? 'unknown';\n    $identifier = $userId ?: $ip;\n    \n    if (!file_exists(RATE_LIMIT_FILE)) {\n        file_put_contents(RATE_LIMIT_FILE, json_encode([]));\n    }\n    \n    $limits = json_decode(file_get_contents(RATE_LIMIT_FILE), true) ?? [];\n    $lastRequest = $limits[$identifier] ?? 0;\n    $now = time();\n    \n    if ($now - $lastRequest < RATE_LIMIT_SECONDS) {\n        sendError('RATE_LIMITED', 'リクエストが早すぎます。後でお試しください:');\n    }\n    \n    // アップデート\n    $limits[$identifier] = $now;\n    file_put_contents(RATE_LIMIT_FILE, json_encode($limits));\n    return true;\n}\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/test1/config.php","message":"ファイルを作成しました"},"approvalTime":140.769},"memory_usage":2097152,"script":"tool_history.php"}
