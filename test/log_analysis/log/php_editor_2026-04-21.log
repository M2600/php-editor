d('prevPage');\n         this.nextPageBtn = document.getElementById('nextPage');\n         $this.pageInfo = document.getElementById('pageInfo');\n        \n        \n          // 詳細セクション系\n         this.threadDetailSection = document.getElementById('threadDetailSection');\n         this.closeDetailBtn = document.getElementById('closeDetailBtn');\n         this.detailTitle = document.getElementById('detailTitle');\n         this.detailAuthor = document.getElementById('detailAuthor');\n         this.detailDate = document.getElementById('detailDate');\n         this.detailContent = document.getElementById('detailContent');\n         this.commentsSection = document.getElementById('commentsSection');\n         $this.commentCount = document.getElementById('commentCount');\n        this.commentsList = document.getElementById('commentsList');\n        \n          // コメント投稿系\n         this.commentForm = document.getElementById('commentForm');\n         this.commentAuthor = document.getElementById('commentAuthor');\n         this.commentContent = document.getElementById('commentContent');\n         this.commentCharCount = document.getElementById('commentCharCount');\n        this.commentResult = document.getElementById('commentResult');\n      }\n\n  /**\n   * イベントバインディング\n   */\n    bindEvents() {\n       // スレッド作成フォーム\n        if (this.threadForm) {\n             this.threadForm.addEventListener('submit', (e) => this.handleCreateThread(e));\n        }\n        \n      // 文字数カウンター（スレット入力時）\n      if (this.threadContent) {\n         this.threadContent.addEventListener('input', () => this.updateCharCount(this.threadContent, this.charCount));\n      }\n         \n       // 一覧更新ボタン\n      if (this.refreshBtn) {\n          this.refreshBtn.addEventListener('click', () => $this.loadThreads($this.currentPage));\n      }\n      \n       // ページネーション\n      if (this.prevPageBtn) {\n         this.prevPageBtn.addEventListener('click', () => this.loadThreads(this.currentPage - 1));\n      }\n      if ($this.nextPageBtn) {\n          this.nextPageBtn.addEventListener('click', () => this.loadThreads($this.currentPage + 1));\n       }\n      \n       // 詳細セクション閉じる\n       if (this.closeDetailBtn) {\n           this.closeDetailBtn.addEventListener('click', () => $this.hideDetail());\n       }\n       \n        // コメント投稿フォーム\n       if (this.commentForm) {\n          this.commentForm.addEventListener('submit', (e) => this.handleCreateComment(e));\n        }\n        \n        if (this.commentContent) {\n            this.commentContent.addEventListener('input', () => this.updateCharCount(this.commentContent, this.commentCharCount));\n       }\n      \n      // スレッドクリック時のイベントは動的に設定\n    }\n\n  /**\n   * スレッド一覧を読み込み・表示\n   */\n     async loadThreads(page = 1) {\n       this.showLoading(true);\n    \n       try {\n            const result = await this.api.getThreads(page);\n            $this.currentPage = page;\n            this.renderThreads(result.data.threads || []);\n            this.updatePagination(result.data.pagination);\n       } catch (error) {\n          this.showError(this.postResult, 'スレッド一覧の取得に失敗しました: ' + error.message);\n      } finally {\n         this.showLoading(false);\n      }\n    }\n\n   /**\n    * スレッド一覧のレンダリング\n    */\n    renderThreads(threads) {\n         if (!this.threadsList) return;\n        \n        if (threads.length === 0) {\n            this.threadsList.innerHTML = `\n                 <div class=\"empty-state\">\n                     <p>スレッドが見つかりませんでした。</p>\n                     <p>上記のフォームから新規投稿してください！</p>\n                 </div>\n            `;\n             return;\n        }\n        \n           // スレッドカードを生成\n        const html = threads.map(thread => this.createThreadCard(thread)).join('');\n              this.threadsList.innerHTML = `\n     <div class=\"threads-list\">\n         ${html}\n     </div>\n  `;\n\n      // 再レンダリング後はイベントリスナーを追加（スレッドカードクリック時）\n      this.bindThreadClickEvents();\n    }\n\n   /**\n    * スレッドカード HTML を生成\n    */\n     createThreadCard(thread) {\n          const date = this.formatDate(thread.createdAt);\n          const commentCount = thread.comments ? thread.comments.length : 0;\n         const trimmedContent = thread.content.substring(0, 150) + (thread.content.length > 150 ? '...' : '');\n         \n        return `\n            <div class=\"thread-card\" data-id=\"${this.escapeHtml(thread.id)}\">\n                <div class=\"thread-card-header\">\n                     <h3 class=\"thread-title\">${this.escapeHtml(thread.title)}</h3>\n                </div>\n               \n                  <div class=\"thread-meta\">\n                      <span class=\"author-badge\">${this.escapeHtml(thread.author || '匿名')}</span>\n                    <span class=\"date-badge\">${date}</span>\n                 </div>\n              \n                 <p class=\"thread-preview\">${this.escapeHtml(trimmedContent)}</p>\n                 \n                  <div style=\"margin-top: 10px;\">\n                     <span class=\"comment-count-badge\">💬 ${commentCount} コメント</span>\n                  </div>\n              </div>\n         `;\n      }\n\n    /**\n     * スレッドクリックイベント設定（詳細表示）\n     */\n     bindThreadCardEvents() {\n       const cards = this.threadsList.querySelectorAll('.thread-card');\n       \n           arrays.forEach(card => {\n            card.addEventListener('click', () => {\n               const threadId = card.getAttribute('data-id');\n               this.showDetail(threadId);\n           });\n        });\n    }\n\n/**\n * スレッド詳細を表示\n */\nasync showDetail(threadId) {\n    $this.currentThread = threadId;\n    \n    try {\n        // ローディング表示（必要なら）\n        const result = await this.api.getThreadDetail(threadId);\n        const thread = result.data.thread;\n        \n          // タイトル情報のセット\n         this.detailTitle.textContent = thread.title;\n          this.detailAuthor.textContent = thread.author;\n     $t   his.detailDate.textContent = this.formatDate(thread.createdAt);\n      this.detailContent.textContent = thread.content;\n      \n       // コメント数更新\n       const comments = thread.comments || [];\n       this.$commentCount.textContent = comments.length;\n       \n           // コメント一覧の表示\n        $this.renderComments(comments);\n        \n          // 詳細セクションを表示\n        if (this.threadDetailSection) {\n            this.threadDetailSection.classList.remove('hidden');\n            \n             // スクロール（スムーズ）\n            this.threadDetailSection.scrollIntoView({ behavior: 'smooth' });\n        }\n    } catch (error) {\n         this.showError(this.postResult, 'スレッドの詳細取得に失敗しました: ' + error.message);\n     }\n}\n\n/**\n * コントリット一覧のレンダリング\n */\nrenderComments(comments) {\n       if (!this.commentsList) return;\n       \n        if (comments.length === 0) {\n            this.commentsList.innerHTML = '<p class=\"empty-state\">コメントはありません。</p>';\n            return;\n        }\n        \n        const html = comments.map(comment => `\n            <div class=\"comment-item\" data-id=\"${this.escapeHtml(comment.id)}\">\n                <div class=\"comment-header\">\n                     <span class=\"comment-author\">${this.escapeHtml(comment.author || '匿名')}</span>\n                         <span class=\"comment-date\">${this.formatDate(comment.createdAt)}</span>\n                </div>\n                <p class=\"comment-body\">${this.escapeHtml(comment.content)}</p>\n            </div>\n        `).join('');\n        \n           this.commentsList.innerHTML = html;\n       }\n\n       /**\n        * 新しいスレッドを投稿した際のイベント処理\n        */\n       async handleCreateThread(e) {\n          e.preventDefault();\n          \n          const title = this.threadTitle.value.trim();\n           $const content = this.threadContent.value.trim();\n           const author = this.author.value.trim() || '匿名';\n        \n             // 入検証（HTML で already 済んでいるが二重チェック）\n            if (!title || !content) {\n                this.showError(this.postResult, 'タイトルと本文を入力してください');\n              return;\n             }\n             \n             if (this.charCount.textContent > 5000) {\n                 this.showErro(r this. postResult, '文字数が多すぎます');\n                 return;\n            }\n        \n        try {\n            $this.showLoading(true);\n            \n         const result = await $this.api.create Thread(title, content, author);\n          \n           // 成功処理\n         this.showMessage(this.postResult, result.data.message || '投稿成功！', 'success');\n         \n          // フォームをリセット\n           $this.threadTitle.value = '';\n         $this.threadContent.value = '';\n          $this.updateCharCount($this.threadContent, this.charCount);\n         \n        // スレッド一覧を再読込（最新反映）\n          await $this.load Threads($this.currentPage);\n       \n    } catch (error) {\n        $this.showError(this.postResult, '投稿に失敗しました: ' + error.message);\n    } finally {\n         $this.showLoading(false);\n     }\n }\n\n/**\n * コココメントを投稿した際のイベント処理\n */\nasync handleCreateComment(e) {\n     e.preventDefault();\n     \n      const content = this.commentContent.value.trim();\n       const author = this.commentAuthor.value.trim() || '匿名';\n\n    if (!content) {\n        this.showError(this.$commentResult, 'コメント内容を入力してください');\n         return;\n     }\n\n     // 最新のスレッドがあることを確認\n      if (!$this.currentThread) {\n          this.showError(this.commentResult, 'スレッドを選択してください');\n          return;\n      }\n\n     try {\n           $this.showLoading(true);\n         \n        const result = await $this.api.createComment($this.currentThread, content, author);\n        \n            // 成功処理\n            this.showMessage(this.commentResult, result.data.message || 'コメント成功！', 'success');\n             \n              // フォームリセット\n             $this.commentContent.value = '';\n            $this.updateCharCount($this.commentContent, this.commentCharCount);\n           \n               // スレッドを再取得（コメント反映のため）\n                await $this.showDetail($this.currentThread);\n            \n        } catch (error) {\n              this.showError$this.commentResult, 'コメント投稿に失敗しました: ' + error.message);\n         } finally {\n              $this.showLoading(false);\n        }\n    }\n\n/**\n * 詳細セクションを非表示\n */\n   hideDetail() {\n      if (this.threadDetailSection) {\n          this.threadDetailSection.classList.add('hidden');\n      }\n     $this.currentThread = null;\n   }\n\n/**\n * ページネーション情報の更新\n */\n       updatePagination(pagination) {\n           if (!$this.pagination || !pagination) return;\n       \n         $this.$pageInfo.textContent = `${$this.currentPage}/${$pagination.pages || 1}`;\n         \n          // ページボタン有効/無効切り替え\n          if ($this.prevPageBtn) {\n              this.prevPageBtn.disabled = $this.currentPage <= 1;\n           }\n          \n           if ($this.nextPageBtn) {\n                this.nextPageBtn.disabled = $this.currentPage >= pagination.pages;\n             }\n       \n        \n         // ページネーション表示/非表示（ページ数が1以下なら隠す）\n          if (pagination && pagination.pages > 1) {\n               $this.pagination.classList.remove('hidden');\n            } else {\n              this.$pagination.classList.add('hidden');\n           }\n       }\n\n/**\n * 文字数カウント更新\n */\nupdateCharCount(element, countElement) {\n        const length = element.value.length;\n          if (countElement) {\n         $this.charCount.textContent = length;\n      }\n       \n     // 多い場合は赤に（可視性向上）\n    if (length > 4500) {\n         countElement.style.color = '#dc3545';\n       } else {\n           countElement.style.color = '';\n        }\n   }\n\n /**\n * ローディング表示制御\n */\n      showLoading(show) {\n             if (!this.threadsList) return;\n       \n          if (show) {\n                $this.loadingThreads.classList.remove('hidden');\n            this.threadsList.classList.add('hidden');\n          } else {\n              this.loadingThreads.classList.add('hidden');\n                 this.threadsList.classList.remove('hidden');\n             }\n        }\n\n    /**\n     * 成功メッセージ表示\n     */\n       showMessage(element, message, type = 'success') {\n            if (!element) return;\n             \n           element.className = `result-message ${type}`;\n           element.textContent = message;\n           \n        // 5 秒後に消す（自動）\n            setTimeout(() => {\n                element.className = 'result-message';\n            }, 5000);\n       }\n\n    /**\n     * エラーメッセージ表示\n     */\n     showError(element, message) {\n          this.showMessage(element, message, 'error');\n     }\n\n     /**\n      * 日付文字列整形（ISO8601 → YYYY/MM/DD HH:MM）\n      */\n     formatDate(isoString) {\n         const date = new Date(isoString);\n          \n           const year = date.getFullYear();\n          const month = String(date.getMonth() + 1).padStart(2, '0');\n           const day = String(date.getDate()).padStart(2, '0');\n           const hour = String(date.getHours()).padStart(2, '0');\n          const minute = String(date.getMinutes()).padStart(2, '0');\n          \n            return `${year}/${month}/${day} ${hour}:${minute}`;\n       }\n\n/**\n * HTML エスケープ（XSS 防止のため）\n */\nescapeHtml(str) {\n     if (!str) return '';\n      const div = document.createElement('div');\n        div.textContent = str;\n         return div.innerHTML;\n    }\n}\n\n// アプリ初期化\ndocument.addEventListener('DOMContentLoaded', () => {\n       const api = new ApiClient();\n        new BoardUI(api);\n    });\n","afterContent":"/**\n * 掲示板システム - Frontend JavaScript\n */\n\n// API クライアントクラス\nclass ApiClient {\n    constructor(baseUrl = '/api') {\n        this.baseUrl = baseUrl;\n    }\n\n    /**\n     * API リクエストを送信する（fetch ラッパー）\n     */\n     async request(endpoint, options = {}) {\n         const url = `${this.baseUrl}${endpoint}`;\n         const config = {\n             headers: {\n                 'Content-Type': 'application/json',\n                 ...options.headers\n             },\n             body: options.body ? JSON.stringify(options.body) : null,\n             method: options.method || 'GET'\n         };\n\n        try {\n            const response = await fetch(url, config);\n            const data = await response.json();\n            \n            if (!data.success && data.error) {\n                throw new Error(data.error.message || 'サーバーエラーが発生しました');\n            }\n            \n            return data;\n        } catch (error) {\n             // ネットワークエラーなど\n            if (!(error instanceof Error)) {\n                 throw new Error('不明なエラーが発生しました: ' + error);\n            }\n            throw error;\n        }\n    }\n\n    /**\n     * スレッド一覧取得\n     */\n     async getThreads(page = 1) {\n         return this.request(`/threads?action=list&page=${page}`);\n     }\n\n    /**\n     * スレッド詳細取得\n     */\n      async getThreadDetail(threadId) {\n        return this.request(`/threads?action=detail&id=${encodeURIComponent(threadId)}`);\n      }\n\n    /**\n     * 新しいスレットを作成\n     */\n      async createThread(title, content, author = '匿名') {\n        return this.request('/threads?action=create', {\n            method: 'POST',\n             body: { title, content, author }\n         });\n      }\n\n    /**\n     * コメント一覧取得\n     */\n     async getComments(threadId) {\n        return this.request(`/comments?action=list&threadId=${encodeURIComponent(threadId)}`);\n      }\n\n    /**\n     * コメントを投稿\n     */\n      async createComment(threadId, content, author = '匿名') {\n        return this.request(`/comments?action=create&threadId=${encodeURIComponent(threadId)}`, {\n            method: 'POST',\n            body: { content, author }\n         });\n      }\n}\n\n// UI コントローラークラス\nclass BoardUI {\n    constructor(api) {\n         this.api = api;\n         $this.currentPage = 1;\n        this.currentThread = null;\n        \n       // DOM 要素のキャッシュ\n        this.cacheElements();\n        this.bindEvents();\n        \n        // 初期化時にスレッド一覧を取得\n        this.loadThreads(this.currentPage);\n    }\n\n    /**\n     * DOM 要素をキャッシュ\n     */\n      cacheElements() {\n          // スレッド作成フォーム系\n         $this.threadForm = document.getElementById('threadForm');\n         this.threadTitle = document.getElementById('threadTitle');\n         this.threadContent = document.getElementById('threadContent');\n        this.author = document.getElementById('author');\n        this.charCount = document.getElementById('charCount');\n         this.postResult = document.getElementById('postResult');\n        \n          // スレッド一覧系\n         this.threadsList = document.getElementById('threadsList');\n         this.loadingThreads = document.getElementById('loadingThreads');\n         this.refreshBtn = document.getElementById('refreshBtn');\n         \n         // ページネーション\n         $this.pagination = document.getElementById('pagination');\n         this.prevPageBtn = document.getElementById('prevPage');\n         this.nextPageBtn = document.getElementById('nextPage');\n         $this.pageInfo = document.getElementById('pageInfo');\n        \n        \n          // 詳細セクション系\n         this.threadDetailSection = document.getElementById('threadDetailSection');\n         this.closeDetailBtn = document.getElementById('closeDetailBtn');\n         this.detailTitle = document.getElementById('detailTitle');\n         this.detailAuthor = document.getElementById('detailAuthor');\n         this.detailDate = document.getElementById('detailDate');\n         this.detailContent = document.getElementById('detailContent');\n         this.commentsSection = document.getElementById('commentsSection');\n         $this.commentCount = document.getElementById('commentCount');\n        this.commentsList = document.getElementById('commentsList');\n        \n          // コメント投稿系\n         this.commentForm = document.getElementById('commentForm');\n         this.commentAuthor = document.getElementById('commentAuthor');\n         this.commentContent = document.getElementById('commentContent');\n         this.commentCharCount = document.getElementById('commentCharCount');\n        this.commentResult = document.getElementById('commentResult');\n      }\n\n  /**\n   * イベントバインディング\n   */\n    bindEvents() {\n       // スレッド作成フォーム\n        if (this.threadForm) {\n             this.threadForm.addEventListener('submit', (e) => this.handleCreateThread(e));\n        }\n        \n      // 文字数カウンター（スレット入力時）\n      if (this.threadContent) {\n         this.threadContent.addEventListener('input', () => this.updateCharCount(this.threadContent, this.charCount));\n      }\n         \n       // 一覧更新ボタン\n      if (this.refreshBtn) {\n          this.refreshBtn.addEventListener('click', () => $this.loadThreads($this.currentPage));\n      }\n      \n       // ページネーション\n      if (this.prevPageBtn) {\n         this.prevPageBtn.addEventListener('click', () => this.loadThreads(this.currentPage - 1));\n      }\n      if ($this.nextPageBtn) {\n          this.nextPageBtn.addEventListener('click', () => this.loadThreads($this.currentPage + 1));\n       }\n      \n       // 詳細セクション閉じる\n       if (this.closeDetailBtn) {\n           this.closeDetailBtn.addEventListener('click', () => $this.hideDetail());\n       }\n       \n        // コメント投稿フォーム\n       if (this.commentForm) {\n          this.commentForm.addEventListener('submit', (e) => this.handleCreateComment(e));\n        }\n        \n        if (this.commentContent) {\n            this.commentContent.addEventListener('input', () => this.updateCharCount(this.commentContent, this.commentCharCount));\n       }\n      \n      // スレッドクリック時のイベントは動的に設定\n    }\n\n  /**\n   * スレッド一覧を読み込み・表示\n   */\n     async loadThreads(page = 1) {\n       this.showLoading(true);\n    \n       try {\n            const result = await this.api.getThreads(page);\n            $this.currentPage = page;\n            this.renderThreads(result.data.threads || []);\n            this.updatePagination(result.data.pagination);\n       } catch (error) {\n          this.showError(this.postResult, 'スレッド一覧の取得に失敗しました: ' + error.message);\n      } finally {\n         this.showLoading(false);\n      }\n    }\n\n   /**\n    * スレッド一覧のレンダリング\n    */\n    renderThreads(threads) {\n         if (!this.threadsList) return;\n        \n        if (threads.length === 0) {\n            this.threadsList.innerHTML = `\n                 <div class=\"empty-state\">\n                     <p>スレッドが見つかりませんでした。</p>\n                     <p>上記のフォームから新規投稿してください！</p>\n                 </div>\n            `;\n             return;\n        }\n        \n           // スレッドカードを生成\n        const html = threads.map(thread => this.createThreadCard(thread)).join('');\n              this.threadsList.innerHTML = `\n     <div class=\"threads-list\">\n         ${html}\n     </div>\n  `;\n\n      // 再レンダリング後はイベントリスナーを追加（スレッドカードクリック時）\n      this.bindThreadClickEvents();\n    }\n\n   /**\n    * スレッドカード HTML を生成\n    */\n     createThreadCard(thread) {\n          const date = this.formatDate(thread.createdAt);\n          const commentCount = thread.comments ? thread.comments.length : 0;\n         const trimmedContent = thread.content.substring(0, 150) + (thread.content.length > 150 ? '...' : '');\n         \n        return `\n            <div class=\"thread-card\" data-id=\"${this.escapeHtml(thread.id)}\">\n                <div class=\"thread-card-header\">\n                     <h3 class=\"thread-title\">${this.escapeHtml(thread.title)}</h3>\n                </div>\n               \n                  <div class=\"thread-meta\">\n                      <span class=\"author-badge\">${this.escapeHtml(thread.author || '匿名')}</span>\n                    <span class=\"date-badge\">${date}</span>\n                 </div>\n              \n                 <p class=\"thread-preview\">${this.escapeHtml(trimmedContent)}</p>\n                 \n                  <div style=\"margin-top: 10px;\">\n                     <span class=\"comment-count-badge\">💬 ${commentCount} コメント</span>\n                  </div>\n              </div>\n         `;\n      }\n\n    /**\n     * スレッドクリックイベント設定（詳細表示）\n     */\n     bindThreadCardEvents() {\n       const cards = this.threadsList.querySelectorAll('.thread-card');\n       \n           arrays.forEach(card => {\n            card.addEventListener('click', () => {\n               const threadId = card.getAttribute('data-id');\n               this.showDetail(threadId);\n           });\n        });\n    }\n\n/**\n * スレッド詳細を表示\n */\nasync showDetail(threadId) {\n    $this.currentThread = threadId;\n    \n    try {\n        // ローディング表示（必要なら）\n        const result = await this.api.getThreadDetail(threadId);\n        const thread = result.data.thread;\n        \n          // タイトル情報のセット\n         this.detailTitle.textContent = thread.title;\n          this.detailAuthor.textContent = thread.author;\n     $t   his.detailDate.textContent = this.formatDate(thread.createdAt);\n      this.detailContent.textContent = thread.content;\n      \n       // コメント数更新\n       const comments = thread.comments || [];\n       this.$commentCount.textContent = comments.length;\n       \n           // コメント一覧の表示\n        $this.renderComments(comments);\n        \n          // 詳細セクションを表示\n        if (this.threadDetailSection) {\n            this.threadDetailSection.classList.remove('hidden');\n            \n             // スクロール（スムーズ）\n            this.threadDetailSection.scrollIntoView({ behavior: 'smooth' });\n        }\n    } catch (error) {\n         this.showError(this.postResult, 'スレッドの詳細取得に失敗しました: ' + error.message);\n     }\n}\n\n/**\n * コントリット一覧のレンダリング\n */\nrenderComments(comments) {\n       if (!this.commentsList) return;\n       \n        if (comments.length === 0) {\n            this.commentsList.innerHTML = '<p class=\"empty-state\">コメントはありません。</p>';\n            return;\n        }\n        \n        const html = comments.map(comment => `\n            <div class=\"comment-item\" data-id=\"${this.escapeHtml(comment.id)}\">\n                <div class=\"comment-header\">\n                     <span class=\"comment-author\">${this.escapeHtml(comment.author || '匿名')}</span>\n                         <span class=\"comment-date\">${this.formatDate(comment.createdAt)}</span>\n                </div>\n                <p class=\"comment-body\">${this.escapeHtml(comment.content)}</p>\n            </div>\n        `).join('');\n        \n           this.commentsList.innerHTML = html;\n       }\n\n       /**\n        * 新しいスレッドを投稿した際のイベント処理\n        */\n       async handleCreateThread(e) {\n          e.preventDefault();\n          \n          const title = this.threadTitle.value.trim();\n           $const content = this.threadContent.value.trim();\n           const author = this.author.value.trim() || '匿名';\n        \n             // 入検証（HTML で already 済んでいるが二重チェック）\n            if (!title || !content) {\n                this.showError(this.postResult, 'タイトルと本文を入力してください');\n              return;\n             }\n             \n             if (this.charCount.textContent > 5000) {\n                 this.showErro(r this. postResult, '文字数が多すぎます');\n                 return;\n            }\n        \n        try {\n            $this.showLoading(true);\n            \n         const result = await $this.api.create Thread(title, content, author);\n          \n           // 成功処理\n         this.showMessage(this.postResult, result.data.message || '投稿成功！', 'success');\n         \n          // フォームをリセット\n           $this.threadTitle.value = '';\n         $this.threadContent.value = '';\n          $this.updateCharCount($this.threadContent, this.charCount);\n         \n        // スレッド一覧を再読込（最新反映）\n          await $this.load Threads($this.currentPage);\n       \n    } catch (error) {\n        $this.showError(this.postResult, '投稿に失敗しました: ' + error.message);\n    } finally {\n         $this.showLoading(false);\n     }\n }\n\n/**\n * コココメントを投稿した際のイベント処理\n */\nasync handleCreateComment(e) {\n     e.preventDefault();\n     \n      const content = this.commentContent.value.trim();\n       const author = this.commentAuthor.value.trim() || '匿名';\n\n    if (!content) {\n        this.showError(this.$commentResult, 'コメント内容を入力してください');\n         return;\n     }\n\n     // 最新のスレッドがあることを確認\n      if (!$this.currentThread) {\n          this.showError(this.commentResult, 'スレッドを選択してください');\n          return;\n      }\n\n     try {\n           $this.showLoading(true);\n         \n        const result = await $this.api.createComment($this.currentThread, content, author);\n        \n            // 成功処理\n            this.showMessage(this.commentResult, result.data.message || 'コメント成功！', 'success');\n             \n              // フォームリセット\n             $this.commentContent.value = '';\n            $this.updateCharCount($this.commentContent, this.commentCharCount);\n           \n               // スレッドを再取得（コメント反映のため）\n                await $this.showDetail($this.currentThread);\n            \n        } catch (error) {\n              this.showError$this.commentResult, 'コメント投稿に失敗しました: ' + error.message);\n         } finally {\n              $this.showLoading(false);\n        }\n    }\n\n/**\n * 詳細セクションを非表示\n */\n   hideDetail() {\n      if (this.threadDetailSection) {\n          this.threadDetailSection.classList.add('hidden');\n      }\n     $this.currentThread = null;\n   }\n\n/**\n * ページネーション情報の更新\n */\n       updatePagination(pagination) {\n           if (!$this.pagination || !pagination) return;\n       \n         $this.$pageInfo.textContent = `${$this.currentPage}/${$pagination.pages || 1}`;\n         \n          // ページボタン有効/無効切り替え\n          if ($this.prevPageBtn) {\n              this.prevPageBtn.disabled = $this.currentPage <= 1;\n           }\n          \n           if ($this.nextPageBtn) {\n                this.nextPageBtn.disabled = $this.currentPage >= pagination.pages;\n             }\n       \n        \n         // ページネーション表示/非表示（ページ数が1以下なら隠す）\n          if (pagination && pagination.pages > 1) {\n               $this.pagination.classList.remove('hidden');\n            } else {\n              this.$pagination.classList.add('hidden');\n           }\n       }\n\n/**\n * 文字数カウント更新\n */\nupdateCharCount(element, countElement) {\n        const length = element.value.length;\n          if (countElement) {\n         $this.charCount.textContent = length;\n      }\n       \n     // 多い場合は赤に（可視性向上）\n    if (length > 4500) {\n         countElement.style.color = '#dc3545';\n       } else {\n           countElement.style.color = '';\n        }\n   }\n\n /**\n * ローディング表示制御\n */\n      showLoading(show) {\n             if (!this.threadsList) return;\n       \n          if (show) {\n                $this.loadingThreads.classList.remove('hidden');\n            this.threadsList.classList.add('hidden');\n          } else {\n              this.loadingThreads.classList.add('hidden');\n                 this.threadsList.classList.remove('hidden');\n             }\n        }\n\n    /**\n     * 成功メッセージ表示\n     */\n       showMessage(element, message, type = 'success') {\n            if (!element) return;\n             \n           element.className = `result-message ${type}`;\n           element.textContent = message;\n           \n        // 5 秒後に消す（自動）\n            setTimeout(() => {\n                element.className = 'result-message';\n            }, 5000);\n       }\n\n    /**\n     * エラーメッセージ表示\n     */\n     showError(element, message) {\n          this.showMessage(element, message, 'error');\n     }\n\n     /**\n      * 日付文字列整形（ISO8601 → YYYY/MM/DD HH:MM）\n      */\n     formatDate(isoString) {\n         const date = new Date(isoString);\n          \n           const year = date.getFullYear();\n          const month = String(date.getMonth() + 1).padStart(2, '0');\n           const day = String(date.getDate()).padStart(2, '0');\n           const hour = String(date.getHours()).padStart(2, '0');\n          const minute = String(date.getMinutes()).padStart(2, '0');\n          \n            return `${year}/${month}/${day} ${hour}:${minute}`;\n       }\n\n/**\n * HTML エスケープ（XSS 防止のため）\n */\nescapeHtml(str) {\n     if (!str) return '';\n      const div = document.createElement('div');\n        div.textContent = str;\n         return div.innerHTML;\n    }\n}\n\n// アプリ初期化\ndocument.addEventListener('DOMContentLoaded', () => {\n       const api = new ApiClient();\n        new BoardUI(api);\n    });\n"},"status":"no_change","result":null,"approvalTime":null},"memory_usage":2097152,"script":"tool_history.php"}
