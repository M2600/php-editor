{"timestamp":"2026-04-22 00:13:25","level":"INFO","level_num":1,"pid":55755,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/handlers/threads.php","content":"<?php\n// スレッド処理ハンドラー\n\nrequire_once __DIR__ . '/../config.php';\n\n$method = $_SERVER['REQUEST_METHOD'];\n$action = $_GET['action'] ?? '';\n$id = isset($_GET['id']) ? (int)$_GET['id'] : null;\n$input = json_decode(file_get_contents('php://input'), true) ?: [];\n\nswitch ($action) {\n    case 'list':\n        // スレッド一覧取得\n        handleListThreads();\n        break;\n    \n    case 'create':\n        // 新規スレッド作成\n        if ($method !== 'POST') {\n            errorResponse('Method not allowed', 405);\n        }\n        handleCreateThread($input);\n        break;\n    \n    case 'get':\n        // 個別スレッド取得\n        if (!$id) {\n            errorResponse('Thread ID is required');\n        }\n        handleGetThread($id);\n        break;\n    \n    case 'update':\n        // スレッド更新\n        if ($method !== 'POST') {\n            errorResponse('Method not allowed', 405);\n        }\n        if (!$id) {\n            errorResponse('Thread ID is required');\n        }\n        handleUpdateThread($id, $input);\n        break;\n    \n    case 'delete':\n        // スレッド削除\n        if ($method !== 'POST') {\n            errorResponse('Method not allowed', 405);\n        }\n        if (!$id) {\n            errorResponse('Thread ID is required');\n        }\n        handleDeleteThread($id);\n        break;\n    \n    case 'comments':\n        // スレッドのコメント一覧取得\n        if (!$id) {\n            errorResponse('Thread ID is required');\n        }\n        handleGetThreadComments($id);\n        break;\n    \n    default:\n        // デフォルト：スレッド一覧\n        handleListThreads();\n}\n\n// スレッド一覧取得\nfunction handleListThreads() {\n    $data = loadPosts();\n    $threads = array_values($data['threads']);\n    rsort($threads); // 最新順\n    \n    jsonResponse([\n        'success' => true,\n        'data' => $threads,\n        'count' => count($threads)\n    ]);\n}\n\n// 新規スレッド作成\nfunction handleCreateThread($input) {\n    $title = sanitizeInput($input['title'] ?? '');\n    $content = sanitizeInput($input['content'] ?? '');\n    \n    if (empty($title)) {\n        errorResponse('Title is required');\n    }\n    \n    $data = loadPosts();\n    \n    $threadId = generateUniqueId($data['threads']);\n    $timestamp = time();\n    \n    $newThread = [\n        'id' => $threadId,\n        'title' => $title,\n        'content' => $content,\n        'created_at' => $timestamp,\n        'updated_at' => $timestamp,\n        'comments_count' => 0\n    ];\n    \n    $data['threads'][$threadId] = $newThread;\n    \n    if (savePosts($data)) {\n        jsonResponse([\n            'success' => true,\n            'message' => 'Thread created successfully',\n            'data' => $newThread\n        ]);\n    } else {\n        errorResponse('Failed to create thread', 500);\n    }\n}\n\n// 個別スレッド取得\nfunction handleGetThread($id) {\n    $data = loadPosts();\n    \n    if (!isset($data['threads'][$id])) {\n        errorResponse('Thread not found', 404);\n    }\n    \n    jsonResponse([\n        'success' => true,\n        'data' => $data['threads'][$id]\n    ]);\n}\n\n// スレッド更新\nfunction handleUpdateThread($id, $input) {\n    $data = loadPosts();\n    \n    if (!isset($data['threads'][$id])) {\n        errorResponse('Thread not found', 404);\n    }\n    \n    $title = sanitizeInput($input['title'] ?? '');\n    $content = sanitizeInput($input['content'] ?? '');\n    \n    if (empty($title)) {\n        errorResponse('Title is required');\n    }\n    \n    $timestamp = time();\n    $data['threads'][$id] = [\n        'id' => $id,\n        'title' => $title,\n        'content' => $content,\n        'created_at' => $data['threads'][$id]['created_at'],\n        'updated_at' => $timestamp,\n        'comments_count' => countCommentsByThread($data, $id)\n    ];\n    \n    if (savePosts($data)) {\n        jsonResponse([\n            'success' => true,\n            'message' => 'Thread updated successfully',\n            'data' => $data['threads'][$id]\n        ]);\n    } else {\n        errorResponse('Failed to update thread', 500);\n    }\n}\n\n// スレッド削除\nfunction handleDeleteThread($id) {\n    $data = loadPosts();\n    \n    if (!isset($data['threads'][$id])) {\n        errorResponse('Thread not found', 404);\n    }\n    \n    // 関連コメントも削除\n    $data['comments'] = array_filter(\n        $data['comments'],\n        function($comment) use ($id) {\n            return $comment['thread_id'] !== $id;\n        }\n    );\n    \n    unset($data['threads'][$id]);\n    \n    if (savePosts($data)) {\n        jsonResponse([\n            'success' => true,\n            'message' => 'Thread and its comments deleted successfully'\n        ]);\n    } else {\n        errorResponse('Failed to delete thread', 500);\n    }\n}\n\n// スレッドのコメント一覧取得\nfunction handleGetThreadComments($threadId) {\n    $data = loadPosts();\n    \n    $comments = array_values(array_filter(\n        $data['comments'],\n        function($comment) use ($threadId) {\n            return $comment['thread_id'] === $threadId;\n        }\n    ));\n    \n    // 投稿日順（最新順）\n    rsort($comments);\n    \n    jsonResponse([\n        'success' => true,\n        'data' => $comments,\n        'count' => count($comments)\n    ]);\n}\n\n// ユークイッド生成\nfunction generateUniqueId($items) {\n    do {\n        $id = bin2hex(random_bytes(8));\n    } while (isset($items[$id]));\n    \n    return $id;\n}\n\n// スレッドのコメント数カウント\nfunction countCommentsByThread($data, $threadId) {\n    return count(array_filter(\n        $data['comments'],\n        function($comment) use ($threadId) {\n            return $comment['thread_id'] === $threadId;\n        }\n    ));\n}\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/test1/api/handlers/threads.php","message":"ファイルを作成しました"},"approvalTime":353.659},"memory_usage":2097152,"script":"tool_history.php"}
