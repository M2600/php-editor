{"timestamp":"2026-04-22 00:15:39","level":"INFO","level_num":1,"pid":55752,"user_id":"dev","message":"AI_TOOL_EXECUTION","context":{"tool":"createFile","parameters":{"filename":"api/handlers/comments.php","content":"<?php\n// コメント処理ハンドラー\n\nrequire_once __DIR__ . '/../config.php';\n\n$method = $_SERVER['REQUEST_METHOD'];\n$action = $_GET['action'] ?? '';\n$id = isset($_GET['id']) ? (int)$_GET['id'] : null;\nThreadId = isset($_GET['thread_id']) ? sanitizeInput($_GET['thread_id']) : null;\n$input = json_decode(file_get_contents('php://input'), true) ?: [];\n\nswitch ($action) {\n    case 'create':\n         // 新規コメント作成\n        if ($method !== 'POST') {\n            errorResponse('Method not allowed', 405);\n         }\n        handleCreateComment($threadId, $input);\n        break;\n    \n    case 'get':\n         // 個別コメント取得\n        if (!$id) {\n            errorResponse('Comment ID is required');\n         }\n        handleGetComment($id);\n        break;\n    \n    case 'update':\n         // コメント更新\n        if ($method !== 'POST') {\n            errorResponse('Method not allowed', 405);\n         }\n        if (!$id) {\n            errorResponse('Comment ID is required');\n         }\n        handleUpdateComment($id, $input);\n        break;\n    \n    case 'delete':\n         // コメント削除\n        if ($method !== 'POST') {\n            errorResponse('Method not allowed', 405);\n         }\n        if (!$id) {\n            errorResponse('Comment ID is required');\n         }\n        handleDeleteComment($id);\n        break;\n    \n    default:\n        errorResponse('Invalid action', 400);\n}\n\n// 新規コメント作成\nfunction handleCreateComment($threadId, $input) {\n     if (empty($threadId)) {\n        errorResponse('Thread ID is required');\n     }\n    \n     $content = sanitizeInput($input['content'] ?? '');\n    if (empty($content)) {\n        errorResponse('Content is required');\n     }\n    \n     $data = loadPosts();\n    \n     // スレッドが存在するか確認\n    if (!isset($data['threads'][$threadId])) {\n        errorResponse('Thread not found', 404);\n     }\n    \n     $commentId = generateUniqueIdForComments($data['comments']);\n     $timestamp = time();\n    \n     $newComment = [\n         'id' => $commentId,\n         'thread_id' => $threadId,\n         'content' => $content,\n         'created_at' => $timestamp,\n         'updated_at' => $timestamp\n     ];\n    \n     $data['comments'][$commentId] = $newComment;\n     \n      // スレッドのコメント数更新\n    if (isset($data['threads'][$threadId])) {\n        $data['threads'][$threadId]['comments_count'] = countCommentsByThread($data, $threadId);\n     }\n    \n    if (savePosts($data)) {\n        jsonResponse([\n             'success' => true,\n             'message' => 'Comment created successfully',\n             'data' => $newComment\n         ]);\n     } else {\n        errorResponse('Failed to create comment', 500);\n     }\n}\n\n// 個別コメント取得\nfunction handleGetComment($id) {\n     $data = loadPosts();\n    \n    if (!isset($data['comments'][$id])) {\n        errorResponse('Comment not found', 404);\n     }\n    \n    jsonResponse([\n         'success' => true,\n         'data' => $data['comments'][$id]\n     ]);\n}\n\n// コメント更新\nfunction handleUpdateComment($id, $input) {\n     $data = loadPosts();\n    \n    if (!isset($data['comments'][$id])) {\n        errorResponse('Comment not found', 404);\n     }\n    \n     $content = sanitizeInput($input['content'] ?? '');\n    if (empty($content)) {\n        errorResponse('Content is required');\n     }\n    \n     $timestamp = time();\n     $data['comments'][$id] = [\n         'id' => $id,\n         'thread_id' => $data['comments'][$id]['thread_id'],\n         'content' => $content,\n         'created_at' => $data['comments'][$id]['created_at'],\n         'updated_at' => $timestamp\n     ];\n    \n    if (savePosts($data)) {\n        jsonResponse([\n             'success' => true,\n             'message' => 'Comment updated successfully',\n             'data' => $data['comments'][$id]\n         ]);\n     } else {\n        errorResponse('Failed to update comment', 500);\n     }\n}\n\n// コメント削除\nfunction handleDeleteComment($id) {\n     $data = loadPosts();\n    \n    if (!isset($data['comments'][$id])) {\n        errorResponse('Comment not found', 404);\n     }\n    \n     // スレッドのコメント数更新\n    if (isset($data['threads'][$data['comments'][$id]['thread_id']])) {\n        $threadId = $data['comments'][$id]['thread_id'];\n        unset($data['comments'][$id]);\n        $data['threads'][$threadId]['comments_count'] = countCommentsByThread($data, $threadId);\n     } else {\n        unset($data['comments'][$id]);\n     }\n    \n    if (savePosts($data)) {\n        jsonResponse([\n             'success' => true,\n             'message' => 'Comment deleted successfully'\n         ]);\n     } else {\n        errorResponse('Failed to delete comment', 500);\n     }\n}\n\n// コメント用ユニーク ID 生成\nfunction generateUniqueIdForComments($items) {\n    do {\n         $id = 'c_' . bin2hex(random_bytes(8));\n     } while (isset($items[$id]));\n    \n    return $id;\n}\n\n// スレッドのコメント数カウント\nfunction countCommentsByThread($data, $threadId) {\n    return count(array_filter(\n         $data['comments'],\n        function($comment) use ($threadId) {\n            return $comment['thread_id'] === $threadId;\n         }\n     ));\n}\n"},"status":"approved","result":{"status":"success","path":"vibe_coding/test1/api/handlers/comments.php","message":"ファイルを作成しました"},"approvalTime":85.968},"memory_usage":2097152,"script":"tool_history.php"}
